---
import { getLangFromUrl, t } from '../i18n';
const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const isEN = lang === 'en';
const home = isEN ? '/en/' : '/';
const contact = 'mailto:nico@multaenhavo.com';
const legal = isEN ? '/en/site-notice' : '/impressum';
const privacy = isEN ? '/en/privacy-policy' : '/datenschutz';
const isHomeActive = currentPath === '/' || currentPath === '/en/' || currentPath === '/en';
const isLegalActive = currentPath.includes('impressum') || currentPath.includes('site-notice');
const isPrivacyActive = currentPath.includes('datenschutz') || currentPath.includes('privacy-policy');
---

<nav class="lp-nav" aria-label="Main navigation">
  <div class="lp-nav__island">
    <a href={home} class="lp-nav__brand" aria-label="LumeraPixel Home">
      <img src="/logos/lplogo-black.svg" alt="LumeraPixel" class="lp-nav__logo" id="navBrandLogo" />
    </a>

    <div class="lp-nav__links" id="navLinks">
      <a href={home} class={`lp-nav__link ${isHomeActive ? 'is-active' : ''}`}>
        <img src="/logos/phosphoricons/white/house.svg" class="lp-nav__link-icon" alt="" aria-hidden="true" />
        <span class="lp-nav__link-text">{t(lang, 'nav.home')}</span>
      </a>
      <a href={contact} class="lp-nav__link">
        <img src="/logos/phosphoricons/white/envelope-simple.svg" class="lp-nav__link-icon" alt="" aria-hidden="true" />
        <span class="lp-nav__link-text">{t(lang, 'nav.contact')}</span>
      </a>
      <a href={legal} class={`lp-nav__link ${isLegalActive ? 'is-active' : ''}`}>
        <img src="/logos/phosphoricons/white/address-book-tabs.svg" class="lp-nav__link-icon" alt="" aria-hidden="true" />
        <span class="lp-nav__link-text">{t(lang, 'nav.legal')}</span>
      </a>
      <a href={privacy} class={`lp-nav__link ${isPrivacyActive ? 'is-active' : ''}`}>
        <img src="/logos/phosphoricons/white/lock-key.svg" class="lp-nav__link-icon" alt="" aria-hidden="true" />
        <span class="lp-nav__link-text">{t(lang, 'nav.privacy')}</span>
      </a>
    </div>

    <div class="lp-nav__controls">
      <button class="lp-nav__quick-btn" id="themeQuickToggle" aria-label="Theme wechseln">
        <img src="/logos/phosphoricons/white/moon.svg" class="lp-nav__quick-icon" id="themeQuickIcon" alt="" />
      </button>
      <button class="lp-nav__quick-btn" id="langQuickToggle" aria-label="Sprache wechseln">
        <span class="lp-nav__quick-label" id="langQuickLabel">DE</span>
      </button>
    </div>
  </div>
</nav>

<style>
  .lp-nav {
    --lp-glass-black-bg: #000000;
    --lp-glass-black-border: #E31C8D;
    --lp-ui-border: #bfbfbf;
    position: fixed;
    top: var(--gap-sm);
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    pointer-events: none;
    width: max-content;
    max-width: calc(100vw - (2 * var(--gap-sm)));
  }

  .lp-nav__island {
    pointer-events: all;
  }

  .lp-nav__island {
    width: auto;
    display: grid;
    grid-template-columns: auto auto auto;
    align-items: center;
    gap: 0.34rem;
    padding: 0.32rem 0.38rem;
    background: var(--lp-glass-black-bg);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-radius: 0 14px 0 14px;
    border: 2.7px solid var(--lp-glass-black-border);
  }

  .lp-nav__brand {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 3rem;
    padding: 0 0.55rem;
    border-radius: 0 14px 0 14px;
    background: var(--lp-glass-black-bg);
    border: 2.7px solid var(--lp-ui-border);
    flex-shrink: 0;
    box-sizing: border-box;
  }
  .lp-nav__brand:hover {
    border-color: #E31C8D;
  }

  .lp-nav__logo {
    height: 1.95rem;
    width: auto;
    display: block;
  }

  .lp-nav__links {
    display: grid;
    grid-template-columns: repeat(4, minmax(8.5rem, 9.7rem));
    justify-content: center;
    gap: 0.34rem;
    flex: none;
  }

  .lp-nav__link {
    font-family: 'Satoshi';
    font-weight: 500;
    font-size: clamp(0.78rem, 0.95vw, 0.95rem);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #ffffff;
    width: 100%;
    height: 3rem;
    padding: 0 0.5rem;
    border-radius: 0 14px 0 14px;
    background: var(--lp-glass-black-bg);
    border: 2.7px solid var(--lp-ui-border);
    transition: background var(--quick);
    white-space: nowrap;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .lp-nav__link:hover,
  .lp-nav__link.is-active {
    background: #000000;
    border-color: #E31C8D;
  }

  .lp-nav__link:not(:hover):not(.is-active) {
    border-color: var(--lp-ui-border);
  }

  .lp-nav__controls {
    width: auto;
    display: flex;
    flex-direction: row;
    gap: 0.35rem;
    padding: 0;
  }

  .lp-nav__quick-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    height: 3rem;
    padding: 0 0.6rem;
    border-radius: 0 14px 0 14px;
    background: var(--lp-glass-black-bg);
    border: 2.7px solid var(--lp-ui-border);
    color: #ffffff;
    transition: background var(--quick);
    cursor: pointer;
    box-sizing: border-box;
  }
  .lp-nav__quick-btn:hover {
    background: #000000;
    border-color: #E31C8D;
  }

  .lp-nav__quick-btn:not(:hover) {
    border-color: var(--lp-ui-border);
  }

  .lp-nav__quick-icon {
    width: 1.4rem;
    height: 1.4rem;
    pointer-events: none;
  }

  .lp-nav__link-icon {
    display: none;
    width: 1.4rem;
    height: 1.4rem;
    pointer-events: none;
    flex-shrink: 0;
  }

  .lp-nav__quick-label {
    font-family: 'Satoshi';
    font-weight: 500;
    font-size: 1.12rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    opacity: 1;
    pointer-events: none;
  }

  @media (max-width: 820px) {
    .lp-nav {
      width: calc(100vw - (2 * var(--gap-xs)));
      left: var(--gap-xs);
      right: var(--gap-xs);
      transform: none;
      top: var(--gap-xs);
    }

    .lp-nav__island {
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 0.34rem;
    }

    .lp-nav__links {
      display: flex;
      flex-direction: row;
      justify-content: center;
      gap: 0.34rem;
    }

    .lp-nav__link {
      width: 3rem;
      min-width: 3rem;
      padding: 0;
    }

    .lp-nav__link-text {
      display: none;
    }

    .lp-nav__link-icon {
      display: block;
    }

    .lp-nav__controls {
      width: auto;
      flex-direction: row;
    }
  }
</style>

<style is:global>
  [data-theme="dark"] .lp-nav__island {
    background: var(--lp-glass-black-bg);
    border-color: var(--lp-glass-black-border);
    border-radius: 0 14px 0 14px;
  }

  [data-theme="dark"] .lp-nav__brand,
  [data-theme="dark"] .lp-nav__link,
  [data-theme="dark"] .lp-nav__quick-btn {
    border-radius: 0 14px 0 14px;
  }

  [data-theme="light"] .lp-nav__island,
  [data-theme="light"] .lp-nav__brand,
  [data-theme="light"] .lp-nav__link,
  [data-theme="light"] .lp-nav__quick-btn {
    --lp-ui-border: #404040;
    background: #ffffff;
    color: #000000;
  }
  [data-theme="light"] .lp-nav__island {
    border-color: #E31C8D;
  }
  [data-theme="light"] .lp-nav__link:hover,
  [data-theme="light"] .lp-nav__link.is-active,
  [data-theme="light"] .lp-nav__quick-btn:hover,
  [data-theme="light"] .lp-nav__brand:hover {
    background: #ffffff;
    color: #000000;
    border-color: #E31C8D;
  }
  [data-theme="light"] .lp-nav__quick-label {
    color: #000000;
  }
  [data-theme="light"] .lp-nav__quick-icon,
  [data-theme="light"] .lp-nav__link-icon {
    filter: invert(1);
  }

</style>

<script>
  const WHITE_ICON_BASE = '/logos/phosphoricons/white';
  const themeBtn = document.getElementById('themeQuickToggle') as HTMLButtonElement;
  const themeIcon = document.getElementById('themeQuickIcon') as HTMLImageElement;
  const navBrandLogo = document.getElementById('navBrandLogo') as HTMLImageElement;
  const langBtn = document.getElementById('langQuickToggle') as HTMLButtonElement;
  const langLabel = document.getElementById('langQuickLabel') as HTMLElement;
  const THEME_KEY = 'lp-theme-mode';
  const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
  const storedTheme = localStorage.getItem(THEME_KEY);
  const prefersDark = mediaQuery.matches;
  let currentMode = storedTheme === 'dark' || storedTheme === 'light'
    ? storedTheme
    : (prefersDark ? 'dark' : 'light');

  function updateThemeButton(mode: string) {
    if (!themeBtn || !themeIcon) return;
    themeIcon.src = mode === 'dark'
      ? `${WHITE_ICON_BASE}/moon.svg`
      : `${WHITE_ICON_BASE}/sun.svg`;
    themeBtn.setAttribute('aria-label', mode === 'dark' ? 'Dark Mode aktiv' : 'Light Mode aktiv');
  }

  if (themeIcon && !themeIcon.src.includes('/logos/phosphoricons/white/')) {
    const current = themeIcon.getAttribute('src') || '';
    themeIcon.src = current.replace('/logos/phosphoricons/', `${WHITE_ICON_BASE}/`);
  }

  function applyTheme(mode: string) {
    document.documentElement.setAttribute('data-theme', mode);
    (window as any).__updateFavicon?.(mode);
    updateThemeButton(mode);
    if (navBrandLogo) {
      navBrandLogo.src = mode === 'dark' ? '/logos/lplogo-white.svg' : '/logos/lplogo-black.svg';
    }
  }

  function toggleMode() {
    currentMode = currentMode === 'dark' ? 'light' : 'dark';
    localStorage.setItem(THEME_KEY, currentMode);
    applyTheme(currentMode);
  }
  themeBtn?.addEventListener('click', toggleMode);

  mediaQuery.addEventListener('change', (e) => {
    const saved = localStorage.getItem(THEME_KEY);
    if (saved === 'dark' || saved === 'light') return;
    currentMode = e.matches ? 'dark' : 'light';
    applyTheme(currentMode);
  });

  const path = window.location.pathname;
  const isPathEN = path.startsWith('/en');
  const enToDe: Record<string, string> = {
    '/en/': '/',
    '/en/site-notice': '/impressum',
    '/en/privacy-policy': '/datenschutz'
  };
  const deToEn: Record<string, string> = {
    '/': '/en/',
    '/impressum': '/en/site-notice',
    '/datenschutz': '/en/privacy-policy'
  };

  const storedLang = localStorage.getItem('lp-lang-mode');
  const browserLang = (navigator.language || '').toLowerCase().startsWith('en') ? 'en' : 'de';
  let currentLangMode = storedLang === 'de' || storedLang === 'en'
    ? storedLang
    : browserLang;

  if (!storedLang) {
    if (currentLangMode === 'en' && !isPathEN) {
      window.location.href = deToEn[path] ?? `/en${path === '/' ? '/' : path}`;
    } else if (currentLangMode === 'de' && isPathEN) {
      window.location.href = enToDe[path] ?? (path.replace(/^\/en/, '') || '/');
    }
  }

  function updateLangButton(mode: string) {
    if (!langLabel || !langBtn) return;
    langLabel.textContent = mode.toUpperCase();
    langBtn.setAttribute('aria-label', mode === 'de' ? 'Deutsch aktiv' : 'English active');
    document.documentElement.setAttribute('lang', mode);
  }
  updateLangButton(currentLangMode);

  langBtn?.addEventListener('click', () => {
    const mode = currentLangMode === 'de' ? 'en' : 'de';
    localStorage.setItem('lp-lang-mode', mode);
    currentLangMode = mode;
    updateLangButton(mode);

    if (mode === 'en' && !isPathEN) {
      window.location.href = deToEn[path] ?? `/en${path === '/' ? '/' : path}`;
    } else if (mode === 'de' && isPathEN) {
      window.location.href = enToDe[path] ?? (path.replace(/^\/en/, '') || '/');
    }
  });

  applyTheme(currentMode);
</script>
