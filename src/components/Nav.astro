---
import { getLangFromUrl, t } from '../i18n';
const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const isEN = lang === 'en';
const home = isEN ? '/en/' : '/';
const contact = 'mailto:nico@multaenhavo.com';
const legal = isEN ? '/en/site-notice' : '/impressum';
const privacy = isEN ? '/en/privacy-policy' : '/datenschutz';
const isHomActive = currentPath === '/' || currentPath === '/en/' || currentPath === '/en';
const isLegalActive = currentPath.includes('impressum') || currentPath.includes('site-notice');
const isPrivacyActive = currentPath.includes('datenschutz') || currentPath.includes('privacy-policy');
---
<nav class="lp-nav">
  <div class="lp-nav__island">
    <div class="lp-nav__row lp-nav__row--top">
      <a href={home} class="lp-nav__brand" aria-label="LumeraPixel Home">
        <img src="/logos/lplong-rainbow.svg" alt="LumeraPixel" class="lp-nav__logo" />
      </a>
      <div class="lp-nav__top-actions">
        <button class="lp-nav__settings-btn" id="settingsToggle" aria-label="Settings">
          <img src="/logos/phosphoricons/gear-six-thin.svg" class="lp-nav__settings-icon" alt="" />
        </button>
        <button class="lp-nav__burger" id="navBurger" aria-label="Menü öffnen" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
    <div class="lp-nav__row lp-nav__row--bottom">
      <div class="lp-nav__links" id="navLinks">
        <a href={home} class={`lp-nav__link ${isHomActive ? 'is-active' : ''}`}>{t(lang, 'nav.home')}</a>
        <a href={contact} class="lp-nav__link">{t(lang, 'nav.contact')}</a>
        <a href={legal} class={`lp-nav__link ${isLegalActive ? 'is-active' : ''}`}>{t(lang, 'nav.legal')}</a>
        <a href={privacy} class={`lp-nav__link ${isPrivacyActive ? 'is-active' : ''}`}>{t(lang, 'nav.privacy')}</a>
        <button class="lp-nav__settings-btn lp-nav__settings-btn--desktop" id="settingsToggleDesktop" aria-label="Settings">
          <img src="/logos/phosphoricons/gear-six-thin.svg" class="lp-nav__settings-icon" alt="" />
        </button>
      </div>
    </div>
  </div>
  <div class="lp-nav__controls" id="navControls">
    <div class="lp-nav__pill" id="themeToggle" role="group" aria-label="Theme wählen">
      <div class="toggle-indicator" id="toggleIndicator"></div>
      <button class="toggle-btn" id="btn-dark" data-mode="dark" aria-label="Dark"><img src="/logos/phosphoricons/moon-thin.svg" class="toggle-icon" alt="" /></button>
      <button class="toggle-btn" id="btn-auto" data-mode="auto" aria-label="Auto"><img src="/logos/phosphoricons/sun-horizon-thin.svg" class="toggle-icon" alt="" /></button>
      <button class="toggle-btn" id="btn-light" data-mode="light" aria-label="Light"><img src="/logos/phosphoricons/sun-thin.svg" class="toggle-icon" alt="" /></button>
    </div>
    <div class="lp-nav__pill" id="langToggle" role="group" aria-label="Language">
      <div class="toggle-indicator" id="langIndicator"></div>
      <a href="/" class="toggle-btn" id="btn-lang-de" data-lang="de" aria-label="Deutsch"><span class="toggle-label">DE</span></a>
      <button class="toggle-btn" id="btn-lang-auto" data-lang="auto" aria-label="Auto"><img src="/logos/phosphoricons/translate-thin.svg" class="toggle-icon" alt="" /></button>
      <a href="/en/" class="toggle-btn" id="btn-lang-en" data-lang="en" aria-label="English"><span class="toggle-label">EN</span></a>
    </div>
  </div>
</nav>

<style>
  .lp-nav {
    position: fixed;
    top: var(--gap-sm);
    left: var(--gap-sm);
    right: var(--gap-sm);
    z-index: 100;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: center;
    gap: 8px;
    pointer-events: none;
  }
  .lp-nav__island,
  .lp-nav__controls,
  .lp-nav__burger {
    pointer-events: all;
  }
  .lp-nav__island {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: 0.55rem 1.4rem;
    background: rgba(6,7,8,0.82);
    backdrop-filter: blur(27px);
    -webkit-backdrop-filter: blur(27px);
    border-radius: 14px;
    border: 2.7px solid rgba(0,0,0,0.37);
    box-shadow: 0 8px 32px 0 rgba(31,38,135,0.27);
    transition: background 0.3s ease, border-color 0.3s ease;
    align-self: auto;
    position: relative;
  }
  .lp-nav__row {
    display: flex;
    flex-direction: row;
    align-items: center;
  }
  .lp-nav__row--top {
    justify-content: center;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid transparent;
    border-image: linear-gradient(277deg, #ff0000, #ff7700, #ffee00, #00cc00, #0088ff, #8800ff) 1;
    margin-bottom: 0.3rem;
  }
  .lp-nav__row--bottom {
    justify-content: center;
  }
  .lp-nav__logo {
    height: 2.6rem;
    width: auto;
    opacity: 0.9;
    transition: opacity var(--quick);
    flex-shrink: 0;
  }
  .lp-nav__brand:hover .lp-nav__logo { opacity: 0.65; }
  .lp-nav__links {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    justify-content: center;
  }
  .lp-nav__link {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(0.88rem, 1.1vw, 1.05rem);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.9);
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    transition: color var(--quick);
    white-space: nowrap;
  }
  .lp-nav__link:hover {
    background: rgba(128,128,128,0.10);
  }
  .lp-nav__link.is-active {
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
  }

  /* Desktop: top-actions (Mobile-only) verstecken */
  .lp-nav__top-actions { display: none; }

  .lp-nav__settings-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    align-self: stretch;
    cursor: pointer;
    border-radius: 6px;
    padding: 0.25rem;
    flex-shrink: 0;
    transition: background var(--quick);
    box-sizing: border-box;
  }
  .lp-nav__settings-btn:hover { background: rgba(128,128,128,0.12); }
  .lp-nav__settings-icon {
    width: 27px;
    height: 27px;
    display: block;
    filter: invert(1);
    opacity: 0.8;
    max-width: none !important;
    max-height: none !important;
    object-fit: contain;
    transition: transform 0.3s ease;
  }
  .lp-nav__settings-btn.is-active .lp-nav__settings-icon { transform: rotate(90deg); }
  .lp-nav__controls {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 3px;
    width: 12rem;
    height: var(--nav-h);
    box-sizing: border-box;
    background: rgba(6,7,8,0.82);
    backdrop-filter: blur(27px);
    -webkit-backdrop-filter: blur(27px);
    border-radius: 14px;
    border: 2.7px solid rgba(0,0,0,0.37);
    box-shadow: 0 8px 32px 0 rgba(31,38,135,0.27);
    transition: background 0.3s ease, border-color 0.3s ease, opacity 0.2s ease;
    position: fixed;
    top: var(--gap-sm);
    right: var(--gap-sm);
    opacity: 0;
    pointer-events: none;
    z-index: 98;
  }
  .lp-nav__controls.is-open {
    opacity: 1;
    pointer-events: all;
  }
  .lp-nav__pill {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    padding: 3px;
    gap: 0;
    position: relative;
    box-sizing: border-box;
    background: rgba(255,255,255,0.06);
    border-radius: 9px;
    min-height: 0;
  }
  .toggle-indicator {
    position: absolute;
    top: 3px;
    bottom: 3px;
    border-radius: 7px;
    transition: left 0.22s ease, width 0.22s ease;
    pointer-events: none;
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
    z-index: 0;
  }
  .toggle-btn {
    flex: 1;
    cursor: pointer;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: 7px;
    padding: 6px;
    box-sizing: border-box;
    min-width: 2.4rem;
    min-height: 0;
    transition: background var(--quick);
  }
  .toggle-btn:hover { background: rgba(128,128,128,0.10); }
  a.toggle-btn { text-decoration: none; }
  .toggle-icon {
    width: 100%;
    height: 100%;
    max-width: none !important;
    max-height: none !important;
    display: block;
    object-fit: contain;
    opacity: 0.5;
    filter: invert(1);
    transition: opacity 0.2s;
    pointer-events: none;
    flex-shrink: 0;
  }
  .toggle-btn.is-active .toggle-icon { opacity: 1; }
  .toggle-label {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0.5;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    pointer-events: none;
    transition: opacity var(--quick);
    filter: invert(1);
  }
  .toggle-btn.is-active .toggle-label { opacity: 1; }
  .lp-nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 6px;
    transition: background var(--quick);
    flex-shrink: 0;
  }
  .lp-nav__burger span {
    display: block; width: 20px; height: 2px;
    background: linear-gradient(to right, #ff0000, #ff7700, #ffee00, #00cc00, #0088ff, #8800ff);
    border-radius: 1px;
    transition: transform var(--flow), opacity var(--quick);
  }
  .lp-nav__burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .lp-nav__burger.is-open span:nth-child(2) { opacity: 0; }
  .lp-nav__burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 640px) {
    .lp-nav { left: var(--gap-xs); right: var(--gap-xs); top: var(--gap-xs); justify-content: stretch; }
    .lp-nav__island { flex: 1; padding: 0.35rem 0.9rem; }
    .lp-nav__row--top {
      justify-content: space-between;
      align-items: center;
      padding-bottom: 0;
      border-bottom: none;
      margin-bottom: 0;
    }
    .lp-nav__top-actions { display: flex; align-items: center; gap: 0.25rem; }
    .lp-nav__settings-btn--desktop { display: none; }
    .lp-nav__logo { height: 1.8rem; }
    .lp-nav__burger { display: flex; }
    .lp-nav__row--bottom {
      display: none;
      top: calc(var(--gap-xs) + var(--nav-h) + 0.4rem);
      left: var(--gap-xs);
      right: var(--gap-xs);
    }
    .lp-nav__row--bottom.is-open { display: flex; }
    .lp-nav__controls {
      position: fixed;
      top: calc(var(--gap-xs) + var(--nav-h) + 0.4rem);
      left: var(--gap-xs);
      right: var(--gap-xs);
      width: auto;
      height: auto;
      opacity: 0;
      pointer-events: none;
      flex-direction: column;
      gap: 4px;
      padding: 4px;
    }
    .lp-nav__controls.is-open { opacity: 1; pointer-events: all; }
    .lp-nav__pill { flex: none; height: 3.5rem; }
    .toggle-btn { align-items: center; justify-content: center; min-width: 0; min-height: 0; padding: 0; }
    .toggle-icon { width: 3rem; height: 3rem; flex-shrink: 0; }
    .lp-nav__links {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px;
      padding: 4px;
      border-top: none;
      margin-top: 0.4rem;
      width: 100%;
      background: rgba(6,7,8,0.82);
      backdrop-filter: blur(27px);
      -webkit-backdrop-filter: blur(27px);
      border-radius: 14px;
      border: 2.7px solid rgba(0,0,0,0.37);
      box-shadow: 0 8px 32px 0 rgba(31,38,135,0.27);
      box-sizing: border-box;
    }
    .lp-nav__link {
      height: 3rem;
      align-content: center;
      padding: 0.5rem 0.4rem;
      letter-spacing: 0.08em;
      border-radius: 9px;
      text-align: center;
      background: rgba(255,255,255,0.06);
    }
  }
</style>

<style is:global>
  [data-theme="light"] .lp-nav__island { background: rgba(235,240,245,0.92); border-color: rgba(200,210,220,0.6); }
  [data-theme="dark"] .lp-nav__island { background: rgba(6,7,8,0.82); border-color: rgba(0,0,0,0.37); }
  [data-theme="light"] .lp-nav__link { color: rgba(10,10,15,0.8); }
  [data-theme="dark"] .lp-nav__link { color: rgba(255,255,255,0.9); }
  [data-theme="light"] .lp-nav__link:hover,
  [data-theme="dark"] .lp-nav__link:hover { background: rgba(128,128,128,0.10); }
  [data-theme="light"] .lp-nav__link.is-active {
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
  }
  [data-theme="dark"] .lp-nav__link.is-active {
    background: linear-gradient(277deg, rgba(255,0,0,0.32), rgba(255,119,0,0.32), rgba(255,238,0,0.32), rgba(0,204,0,0.32), rgba(0,136,255,0.32), rgba(136,0,255,0.32));
  }
  [data-theme="dark"] .toggle-indicator {
    background: linear-gradient(277deg, rgba(255,0,0,0.32), rgba(255,119,0,0.32), rgba(255,238,0,0.32), rgba(0,204,0,0.32), rgba(0,136,255,0.32), rgba(136,0,255,0.32));
  }
  [data-theme="light"] .lp-nav__links { border-color: rgba(200,210,220,0.6); }
  @media (max-width: 640px) {
    [data-theme="light"] .lp-nav__links { background: rgba(235,240,245,0.92); }
  }
  [data-theme="light"] .lp-nav__controls { background: rgba(235,240,245,0.92); border-color: rgba(200,210,220,0.6); }
  [data-theme="dark"] .lp-nav__controls { background: rgba(6,7,8,0.82); border-color: rgba(0,0,0,0.37); }
  [data-theme="light"] .lp-nav__pill { background: rgba(0,0,0,0.06); }
  [data-theme="dark"] .lp-nav__pill { background: rgba(255,255,255,0.06); }
  [data-theme="dark"] .toggle-btn { color: rgba(255,255,255,0.6); }
  [data-theme="light"] .toggle-btn { color: rgba(10,10,15,0.6); }
  [data-theme="light"] .lp-nav__settings-icon { filter: invert(0); }
  [data-theme="light"] .toggle-icon { filter: invert(0); }
  [data-theme="light"] .toggle-label { filter: invert(0); }
</style>

<script>
  const burger = document.getElementById('navBurger');
  const links = document.getElementById('navLinks');
  const rowBottom = document.querySelector('.lp-nav__row--bottom') as HTMLElement;
  burger?.addEventListener('click', () => {
    const open = burger.classList.toggle('is-open');
    rowBottom?.classList.toggle('is-open', open);
    burger.setAttribute('aria-expanded', String(open));
  });

  const ind = document.getElementById('toggleIndicator') as HTMLElement;
  const btns = ['dark','auto','light'].map(m => document.getElementById('btn-' + m) as HTMLElement);

  function applyTheme(mode: string) {
    const html = document.documentElement;
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = mode === 'auto' ? (prefersDark ? 'dark' : 'light') : mode;
    html.setAttribute('data-theme', theme);
    (window as any).__updateFavicon?.(theme);
    updateToggle(currentMode, false);
    updateLangToggle(currentLangMode);
  }
  function getBtnSize(pill: HTMLElement) { return pill.offsetWidth / 3; }
  function updateToggle(mode: string, animate = true) {
    const idx = ['dark','auto','light'].indexOf(mode);
    const pill = document.getElementById('themeToggle') as HTMLElement;
    if (!pill) return;
    const btnSize = getBtnSize(pill);
    if (!animate) ind.style.transition = 'none';
    ind.style.width = btnSize + 'px';
    ind.style.left = (idx * btnSize) + 'px';
    if (!animate) requestAnimationFrame(() => { ind.style.transition = ''; });
    btns.forEach((btn, i) => {
      btn.classList.toggle('is-active', i === idx);
    });
  }
  let currentMode = localStorage.getItem('lp-theme-mode') || 'auto';
  function setMode(mode: string) {
    currentMode = mode;
    localStorage.setItem('lp-theme-mode', mode);
    applyTheme(mode);
    updateToggle(mode);
  }
  btns.forEach((btn, i) => { btn?.addEventListener('click', () => setMode(['dark','auto','light'][i])); });

  const langInd = document.getElementById('langIndicator') as HTMLElement;
  const langBtns = ['de','auto','en'].map(l => document.getElementById('btn-lang-' + l) as HTMLElement);
  function updateLangToggle(mode: string) {
    const idx = ['de','auto','en'].indexOf(mode);
    const pill = document.getElementById('langToggle') as HTMLElement;
    if (!langInd || !pill) return;
    const btnSize = getBtnSize(pill);
    langInd.style.width = btnSize + 'px';
    langInd.style.left = (idx * btnSize) + 'px';
    langBtns.forEach((btn, i) => {
      btn?.classList.toggle('is-active', i === idx);
    });
  }
  let currentLangMode = localStorage.getItem('lp-lang-mode') || 'auto';
  requestAnimationFrame(() => updateLangToggle(currentLangMode));
  langBtns.forEach((btn, i) => {
    btn?.addEventListener('click', (e) => {
      const mode = ['de','auto','en'][i];
      e.preventDefault();
      if (mode === 'auto') {
        localStorage.removeItem('lp-lang-mode');
        currentLangMode = 'auto';
        updateLangToggle('auto');
        const preferDE = (navigator.language || navigator.languages?.[0] || 'de').toLowerCase().startsWith('de');
        const curIsEN = window.location.pathname.startsWith('/en');
        const p = window.location.pathname;
        const enToDe = {'/en/':'/','/en/site-notice':'/impressum','/en/privacy-policy':'/datenschutz'};
        const deToEn = {'/':'/en/','/impressum':'/en/site-notice','/datenschutz':'/en/privacy-policy'};
        if (preferDE && curIsEN) { window.location.href = enToDe[p] ?? (p.replace(/^\/en/, '') || '/'); }
        else if (!preferDE && !curIsEN) { window.location.href = deToEn[p] ?? ('/en' + (p === '/' ? '/' : p)); }
        return;
      }
      localStorage.setItem('lp-lang-mode', mode);
      currentLangMode = mode;
      updateLangToggle(mode);
      const p2 = window.location.pathname;
      const isEN = p2.startsWith('/en');
      const enToDe2 = {'/en/':'/','/en/site-notice':'/impressum','/en/privacy-policy':'/datenschutz'};
      const deToEn2 = {'/':'/en/','/impressum':'/en/site-notice','/datenschutz':'/en/privacy-policy'};
      if (mode === 'en' && !isEN) { window.location.href = deToEn2[p2] ?? ('/en' + (p2 === '/' ? '/' : p2)); }
      else if (mode === 'de' && isEN) { window.location.href = enToDe2[p2] ?? (p2.replace(/^\/en/, '') || '/'); }
    });
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (currentMode === 'auto') applyTheme('auto');
  });

  const settingsBtn = document.getElementById('settingsToggle') as HTMLElement;
  const settingsBtnDesktop = document.getElementById('settingsToggleDesktop') as HTMLElement;
  const navControls = document.getElementById('navControls') as HTMLElement;

  const allSettingsBtns = [settingsBtn, settingsBtnDesktop].filter(Boolean);

  function openSettings() {
    navControls?.classList.add('is-open');
    allSettingsBtns.forEach(btn => btn?.classList.add('is-active'));
    updateToggle(currentMode, false);
    updateLangToggle(currentLangMode);
  }
  function closeSettings() {
    navControls?.classList.remove('is-open');
    allSettingsBtns.forEach(btn => btn?.classList.remove('is-active'));
  }
  allSettingsBtns.forEach(btn => {
    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      navControls?.classList.contains('is-open') ? closeSettings() : openSettings();
    });
  });
  document.addEventListener('click', (e) => {
    if (navControls?.classList.contains('is-open')) {
      const clickedBtn = allSettingsBtns.some(btn => btn?.contains(e.target as Node));
      if (!navControls.contains(e.target as Node) && !clickedBtn) {
        closeSettings();
      }
    }
  });
  navControls?.querySelectorAll('.toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => setTimeout(closeSettings, 150));
  });
  updateToggle(currentMode, false);
  if (currentMode !== 'auto') applyTheme(currentMode);
</script>