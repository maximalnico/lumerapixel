---
import { getLangFromUrl, t } from '../i18n';
const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const isEN = lang === 'en';
const home = isEN ? '/en/' : '/';
const contact = 'mailto:nico@multaenhavo.com';
const legal = isEN ? '/en/site-notice' : '/impressum';
const privacy = isEN ? '/en/privacy-policy' : '/datenschutz';
const isHomeActive = currentPath === '/' || currentPath === '/en/' || currentPath === '/en';
const isLegalActive = currentPath.includes('impressum') || currentPath.includes('site-notice');
const isPrivacyActive = currentPath.includes('datenschutz') || currentPath.includes('privacy-policy');
---

<nav class="lp-nav" aria-label="Main navigation">
  <div class="lp-nav__island">
    <a href={home} class="lp-nav__brand" aria-label="LumeraPixel Home">
      <img src="/logos/lplogo.svg" alt="LumeraPixel" class="lp-nav__logo" />
    </a>

    <div class="lp-nav__links" id="navLinks">
      <a href={home} class={`lp-nav__link ${isHomeActive ? 'is-active' : ''}`}>
        <img src="/logos/phosphoricons/caret-right-thin.svg" class="lp-nav__link-icon" alt="" />
        <span>{t(lang, 'nav.home')}</span>
      </a>
      <a href={contact} class="lp-nav__link">
        <img src="/logos/phosphoricons/caret-right-thin.svg" class="lp-nav__link-icon" alt="" />
        <span>{t(lang, 'nav.contact')}</span>
      </a>
      <a href={legal} class={`lp-nav__link ${isLegalActive ? 'is-active' : ''}`}>
        <img src="/logos/phosphoricons/caret-right-thin.svg" class="lp-nav__link-icon" alt="" />
        <span>{t(lang, 'nav.legal')}</span>
      </a>
      <a href={privacy} class={`lp-nav__link ${isPrivacyActive ? 'is-active' : ''}`}>
        <img src="/logos/phosphoricons/caret-right-thin.svg" class="lp-nav__link-icon" alt="" />
        <span>{t(lang, 'nav.privacy')}</span>
      </a>
    </div>
  </div>

  <div class="lp-nav__controls">
    <div class="lp-nav__pill" id="themeToggle" role="group" aria-label="Theme wählen">
      <div class="toggle-indicator" id="toggleIndicator"></div>
      <button class="toggle-btn" id="btn-dark" data-mode="dark" aria-label="Dark">
        <img src="/logos/phosphoricons/moon-thin.svg" class="toggle-icon" alt="" />
      </button>
      <button class="toggle-btn" id="btn-light" data-mode="light" aria-label="Light">
        <img src="/logos/phosphoricons/sun-thin.svg" class="toggle-icon" alt="" />
      </button>
    </div>

    <div class="lp-nav__pill" id="langToggle" role="group" aria-label="Language">
      <div class="toggle-indicator" id="langIndicator"></div>
      <a href="/" class="toggle-btn" id="btn-lang-de" data-lang="de" aria-label="Deutsch">
        <span class="toggle-label">DE</span>
      </a>
      <a href="/en/" class="toggle-btn" id="btn-lang-en" data-lang="en" aria-label="English">
        <span class="toggle-label">EN</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .lp-nav {
    position: fixed;
    top: var(--gap-sm);
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.45rem;
    pointer-events: none;
    width: min(96vw, 62rem);
  }

  .lp-nav__island,
  .lp-nav__controls {
    pointer-events: all;
  }

  .lp-nav__island {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-radius: 10px 0 10px 0;
    border: 2.7px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
  }

  .lp-nav__brand {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.55rem;
    border-radius: 10px 0 10px 0;
    background: rgba(255, 255, 255, 0.06);
    transition: background var(--quick);
    flex-shrink: 0;
  }

  .lp-nav__brand:hover {
    background: linear-gradient(277deg, rgba(255,0,0,0.15), rgba(255,119,0,0.15), rgba(255,238,0,0.15), rgba(0,204,0,0.15), rgba(0,136,255,0.15), rgba(136,0,255,0.15));
  }

  .lp-nav__logo {
    height: 2.35rem;
    width: auto;
    opacity: 0.92;
    display: block;
  }

  .lp-nav__links {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.35rem;
    flex: 1;
  }

  .lp-nav__link {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(0.67rem, 0.8vw, 0.82rem);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text);
    padding: 0.58rem 0.8rem;
    border-radius: 10px 0 10px 0;
    background: rgba(255, 255, 255, 0.06);
    transition: background var(--quick);
    white-space: nowrap;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.38rem;
  }

  .lp-nav__link-icon {
    width: 0.95rem;
    height: 0.95rem;
    opacity: 0.82;
    filter: invert(1);
    flex-shrink: 0;
  }

  .lp-nav__link:hover,
  .lp-nav__link.is-active {
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
  }

  .lp-nav__controls {
    width: 8.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.3rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-radius: 10px 0 10px 0;
    border: 2.7px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
  }

  .lp-nav__pill {
    display: flex;
    align-items: stretch;
    position: relative;
    padding: 2px;
    border-radius: 10px 0 10px 0;
    background: rgba(255,255,255,0.06);
  }

  .toggle-indicator {
    position: absolute;
    top: 2px;
    bottom: 2px;
    border-radius: 10px 0 10px 0;
    transition: left 0.2s ease, width 0.2s ease;
    pointer-events: none;
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
    z-index: 0;
  }

  .toggle-btn {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px 0 10px 0;
    padding: 0.45rem;
    position: relative;
    z-index: 1;
    text-decoration: none;
  }

  .toggle-btn:hover {
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
  }

  .toggle-icon {
    width: 1.15rem;
    height: 1.15rem;
    opacity: 0.55;
    filter: invert(1);
    pointer-events: none;
  }

  .toggle-label {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: #fff;
    opacity: 0.6;
    pointer-events: none;
  }

  .toggle-btn.is-active .toggle-icon,
  .toggle-btn.is-active .toggle-label {
    opacity: 1;
  }

  @media (max-width: 820px) {
    .lp-nav {
      width: calc(100vw - (2 * var(--gap-xs)));
      left: var(--gap-xs);
      right: var(--gap-xs);
      transform: none;
      top: var(--gap-xs);
      align-items: stretch;
      flex-direction: column;
    }

    .lp-nav__island {
      flex-direction: column;
      align-items: stretch;
      gap: 0.35rem;
    }

    .lp-nav__brand {
      justify-content: flex-start;
    }

    .lp-nav__links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lp-nav__link {
      font-size: 0.86rem;
      letter-spacing: 0.08em;
    }

    .lp-nav__controls {
      width: 100%;
      flex-direction: row;
    }

    .lp-nav__pill {
      flex: 1;
    }
  }
</style>

<style is:global>
  [data-theme="dark"] .lp-nav {
    --nav-surface-1: rgba(20, 24, 34, 0.95);
    --nav-surface-2: rgba(11, 13, 21, 0.96);
    --pinky-nav: rgba(227, 28, 141, 0.62);
  }

  [data-theme="dark"] .lp-nav__island,
  [data-theme="dark"] .lp-nav__controls {
    background: linear-gradient(165deg, var(--nav-surface-1), var(--nav-surface-2));
    border-color: rgba(255,255,255,0.22);
    border-radius: 14px 0 14px 0;
    box-shadow: 0 14px 28px rgba(0,0,0,0.45);
  }

  [data-theme="dark"] .lp-nav__brand,
  [data-theme="dark"] .lp-nav__link,
  [data-theme="dark"] .lp-nav__pill,
  [data-theme="dark"] .toggle-btn,
  [data-theme="dark"] .toggle-indicator {
    border-radius: 10px 0 10px 0;
  }

  [data-theme="dark"] .lp-nav__link:hover,
  [data-theme="dark"] .lp-nav__link.is-active,
  [data-theme="dark"] .toggle-btn:hover {
    background: linear-gradient(155deg, rgba(46, 10, 35, 0.88), rgba(18, 20, 34, 0.93));
    box-shadow: inset 0 0 0 1px var(--pinky-nav), 0 6px 15px rgba(0,0,0,0.45);
  }

  [data-theme="dark"] .toggle-indicator {
    background: linear-gradient(145deg, rgba(227,28,141,0.48), rgba(255,255,255,0.12));
  }

  [data-theme="light"] .toggle-icon { filter: invert(0); }
  [data-theme="light"] .toggle-label { color: #0a0a0f; }
  [data-theme="light"] .lp-nav__link-icon { filter: invert(0); }
</style>

<script>
  const ind = document.getElementById('toggleIndicator') as HTMLElement;
  const btns = ['dark', 'light'].map((mode) => document.getElementById(`btn-${mode}`) as HTMLElement);

  function getBtnSize(pill: HTMLElement) {
    return pill.offsetWidth / 2;
  }

  function updateToggle(mode: string, animate = true) {
    const idx = ['dark', 'light'].indexOf(mode);
    const pill = document.getElementById('themeToggle') as HTMLElement;
    if (!pill || idx < 0) return;
    const btnSize = getBtnSize(pill);
    if (!animate) ind.style.transition = 'none';
    ind.style.width = `${btnSize}px`;
    ind.style.left = `${idx * btnSize}px`;
    if (!animate) requestAnimationFrame(() => { ind.style.transition = ''; });
    btns.forEach((btn, i) => btn.classList.toggle('is-active', i === idx));
  }

  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  let currentMode = (localStorage.getItem('lp-theme-mode') || (prefersDark ? 'dark' : 'light'));
  if (!['dark', 'light'].includes(currentMode)) currentMode = prefersDark ? 'dark' : 'light';

  function applyTheme(mode: string) {
    document.documentElement.setAttribute('data-theme', mode);
    (window as any).__updateFavicon?.(mode);
    updateToggle(mode, false);
  }

  function setMode(mode: string) {
    currentMode = mode;
    localStorage.setItem('lp-theme-mode', mode);
    applyTheme(mode);
    updateToggle(mode);
  }

  btns.forEach((btn, i) => {
    btn?.addEventListener('click', () => setMode(['dark', 'light'][i]));
  });

  const langInd = document.getElementById('langIndicator') as HTMLElement;
  const langBtns = ['de', 'en'].map((langCode) => document.getElementById(`btn-lang-${langCode}`) as HTMLElement);

  function updateLangToggle(mode: string) {
    const idx = ['de', 'en'].indexOf(mode);
    const pill = document.getElementById('langToggle') as HTMLElement;
    if (!pill || !langInd || idx < 0) return;
    const btnSize = getBtnSize(pill);
    langInd.style.width = `${btnSize}px`;
    langInd.style.left = `${idx * btnSize}px`;
    langBtns.forEach((btn, i) => btn?.classList.toggle('is-active', i === idx));
  }

  let currentLangMode = localStorage.getItem('lp-lang-mode') || (window.location.pathname.startsWith('/en') ? 'en' : 'de');
  if (!['de', 'en'].includes(currentLangMode)) currentLangMode = window.location.pathname.startsWith('/en') ? 'en' : 'de';

  updateLangToggle(currentLangMode);

  langBtns.forEach((btn, i) => {
    btn?.addEventListener('click', (e) => {
      e.preventDefault();
      const mode = ['de', 'en'][i];
      localStorage.setItem('lp-lang-mode', mode);
      currentLangMode = mode;
      updateLangToggle(mode);

      const path = window.location.pathname;
      const isPathEN = path.startsWith('/en');
      const enToDe: Record<string, string> = {
        '/en/': '/',
        '/en/site-notice': '/impressum',
        '/en/privacy-policy': '/datenschutz'
      };
      const deToEn: Record<string, string> = {
        '/': '/en/',
        '/impressum': '/en/site-notice',
        '/datenschutz': '/en/privacy-policy'
      };

      if (mode === 'en' && !isPathEN) {
        window.location.href = deToEn[path] ?? `/en${path === '/' ? '/' : path}`;
      } else if (mode === 'de' && isPathEN) {
        window.location.href = enToDe[path] ?? (path.replace(/^\/en/, '') || '/');
      }
    });
  });

  applyTheme(currentMode);
  requestAnimationFrame(() => {
    updateToggle(currentMode, false);
    updateLangToggle(currentLangMode);
  });
</script>
