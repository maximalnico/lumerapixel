---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; slug: string | undefined; }
const { lang, slug } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const session = allSessions.find((s: any) => s.slug === slug);
if (!session) throw new Error(`Session not found: ${slug}`);

const sorted = [...allSessions].sort((a: any, b: any) => parseDMY(b.date) - parseDMY(a.date));
const idx = sorted.findIndex((s: any) => s.slug === slug);
const prev = sorted[idx + 1] ?? null;
const next = sorted[idx - 1] ?? null;

const title = isEN ? (session.title_en || session.title_de) : (session.title_de || session.title_en);
const subtitle = isEN ? (session.subtitle_en || session.subtitle_de) : (session.subtitle_de || session.subtitle_en);
const category = isEN ? (session.category_en || session.category) : (session.category_de || session.category);
const sessionPath = (s: string) => isEN ? `/en/sessions/${s}` : `/sessions/${s}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

const folder = session.folder;
const photos: string[] = Array.from({ length: session.images }, (_, i) => `${folder}/${String(i).padStart(3, '0')}.webp`);
const [d, m, y] = session.date.split('.');
const dateStr = new Date(+y, +m - 1, +d).toLocaleDateString(dateLocale, { day: '2-digit', month: 'long', year: 'numeric' });

const siteUrl = 'https://lumerapixel.com';
const pageUrl = isEN ? `${siteUrl}/en/sessions/${slug}` : `${siteUrl}/sessions/${slug}`;
const deUrl = `${siteUrl}/sessions/${slug}`;
const enUrl = `${siteUrl}/en/sessions/${slug}`;
const ogImg = photos[0] ? `${siteUrl}${photos[0]}` : `${siteUrl}/logos/lplong.svg`;
---

<Base
  title={`${title} – LumeraPixel`}
  description={subtitle || title}
  ogImage={ogImg}
  ogType="article"
  canonical={pageUrl}
  hreflangDe={deUrl}
  hreflangEn={enUrl}
>
  <Nav />

  {(prev || next) && (
    <div class="session-page-nav">
      <div class="session-page-nav__island">
        {next
          ? <a href={sessionPath(next.slug)} class="session-page-nav__btn session-page-nav__btn--prev" aria-label={isEN ? 'Newer session' : 'Neuere Session'}>
              <img src="/logos/phosphoricons/white/caret-left.svg" alt="" />
              <span>{isEN ? (next.title_en || next.title_de) : (next.title_de || next.title_en)}</span>
            </a>
          : <div />
        }
        {prev
          ? <a href={sessionPath(prev.slug)} class="session-page-nav__btn session-page-nav__btn--next" aria-label={isEN ? 'Older session' : 'Ältere Session'}>
              <span>{isEN ? (prev.title_en || prev.title_de) : (prev.title_de || prev.title_en)}</span>
              <img src="/logos/phosphoricons/white/caret-right.svg" alt="" />
            </a>
          : <div />
        }
      </div>
    </div>
  )}

  <main class="session-page">
    <header class="session-hero">
      <div class="session-hero__body">
        <img src={photos[0]} alt={title} class="session-hero__image" loading="eager" decoding="async" />
        <div class="session-hero__overlay">
          <div class="session-hero__textlab">
            <div class="session-hero__meta">
              <span class="session-hero__meta-row session-hero__meta-row--cat">
                <span class="session-hero__cat">{category}</span>
              </span>
              <span class="session-hero__meta-row session-hero__meta-row--info">
                <span>{session.images} {t(lang, 'session.photos')}</span>
                <span>{dateStr}</span>
              </span>
            </div>
            <h1 class="session-hero__title">{title}</h1>
            {subtitle && <p class="session-hero__sub">{subtitle}</p>}
          </div>
        </div>
      </div>
      <button type="button" id="sessionHeroScrollIndicator" class="session-hero__scroll-indicator" aria-label={isEN ? 'Scroll to photos' : 'Zu den Fotos scrollen'}>
        <img src="/logos/phosphoricons/white/caret-down.svg" alt="" />
      </button>
      {next && (
        <a class="session-hero__side-nav session-hero__side-nav--left" href={sessionPath(next.slug)} aria-label={isEN ? 'Previous session' : 'Vorherige Session'}>
          <img src="/logos/phosphoricons/white/caret-left.svg" alt="" />
        </a>
      )}
      {prev && (
        <a class="session-hero__side-nav session-hero__side-nav--right" href={sessionPath(prev.slug)} aria-label={isEN ? 'Next session' : 'Nächste Session'}>
          <img src="/logos/phosphoricons/white/caret-right.svg" alt="" />
        </a>
      )}
    </header>

    <section id="session-content" class="photo-section" aria-label="Fotos">
      <div class="photo-grid" id="photoGrid">
        {photos.map((src, i) => (
          <button class="photo-item" data-index={i} aria-label={isEN ? `Photo ${i + 1} of ${session.images}` : `Foto ${i + 1} von ${session.images}`}>
            <img src={src} alt={`${title} – ${isEN ? 'Photo' : 'Foto'} ${i + 1}`} loading={i < 4 ? 'eager' : 'lazy'} decoding="async" />
          </button>
        ))}
      </div>
    </section>
  </main>

  <div class="lightbox" id="sessionLightbox" hidden>
    <button class="lightbox__backdrop" id="sessionLightboxBackdrop" aria-label={isEN ? 'Close lightbox' : 'Lightbox schließen'}></button>
    <button class="lightbox__close" id="sessionLightboxClose" aria-label={isEN ? 'Close' : 'Schließen'}>
      <img src="/logos/phosphoricons/white/x.svg" alt="" />
    </button>
    <button class="lightbox__nav lightbox__nav--prev" id="sessionLightboxPrev" aria-label={isEN ? 'Previous photo' : 'Vorheriges Foto'}>
      <img src="/logos/phosphoricons/white/caret-left.svg" alt="" />
    </button>
    <button class="lightbox__nav lightbox__nav--next" id="sessionLightboxNext" aria-label={isEN ? 'Next photo' : 'Nächstes Foto'}>
      <img src="/logos/phosphoricons/white/caret-right.svg" alt="" />
    </button>
    <img class="lightbox__img" id="sessionLightboxImage" src="" alt="" />
    <div class="lightbox__swipe-hint" id="lightboxSwipeHint" aria-hidden="true">
      <img src="/logos/phosphoricons/white/caret-up.svg" alt="" />
      <span>swipe</span>
      <img src="/logos/phosphoricons/white/caret-down.svg" alt="" />
    </div>
  </div>

  <Footer />
</Base>

<style>
  .session-page {
    background: #000;
    min-height: 100svh;
    color: #fff;
    --masonry-gap: 7px;
    --session-border: #bfbfbf;
  }
  .session-hero {
    padding-top: var(--masonry-gap);
    margin: 0 var(--masonry-gap) var(--masonry-gap);
    position: relative;
  }

  .session-hero__body {
    position: relative;
    height: calc(100svh - (var(--masonry-gap) * 2));
    overflow: hidden;
    border-radius: 0 14px 0 14px;
    border: 2.7px solid #E31C8D;
    background: #000;
  }
  .session-hero__image {
    width: 100%; height: 100%; object-fit: cover; display: block;
    filter: grayscale(1) brightness(0.72);
    object-position: center;
  }
  .session-hero__overlay {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    background: linear-gradient(90deg, rgba(0,0,0,.45) 0%, rgba(0,0,0,.15) 25%, rgba(0,0,0,.15) 75%, rgba(0,0,0,.45) 100%);
    padding: 1.2rem;
  }
  .session-hero__textlab {
    width: min(88vw, 44rem);
    border: 2.7px solid #E31C8D;
    border-radius: 0 14px 0 14px;
    background: #000;
    padding: clamp(0.8rem, 1.8vw, 1.2rem) clamp(0.9rem, 2vw, 1.4rem);
    text-align: center;
  }
  .session-hero__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .35rem;
    font-size: .82rem;
    font-weight: 550;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #d0d0d0;
  }
  .session-hero__meta-row {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .6rem;
  }
  .session-hero__cat {
    border: 2.7px solid var(--session-border);
    border-radius: 0 14px 0 14px;
    padding: 0.42rem 0.78rem;
    color: #fff;
    font-weight: 500;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    background: #000;
  }
  .session-hero__title { font-size: clamp(1.9rem, 5vw, 3.7rem); line-height: .95; margin-top: .5rem; font-weight: 750; }
  .session-hero__sub { margin-top: .45rem; color: #ddd; max-width: 52ch; margin-inline: auto; font-weight: 550; }
  .session-hero__scroll-indicator {
    position: absolute;
    left: 50%;
    bottom: 0.85rem;
    transform: translateX(-50%);
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 0 14px 0 14px;
    border: 2.7px solid var(--session-border);
    background: #000;
    display: grid;
    place-items: center;
    z-index: 3;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease;
  }
  .session-hero__scroll-indicator:hover { border-color: #E31C8D; }
  .session-hero__scroll-indicator img { width: 2.7rem; height: 2.7rem; display: block; }

  .photo-section {
    padding: 0 var(--masonry-gap) var(--masonry-gap);
    margin-top: var(--masonry-gap);
  }
  .session-hero__side-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 0 14px 0 14px;
    border: 2.7px solid var(--session-border);
    background: #000;
    display: grid;
    place-items: center;
    z-index: 3;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease;
  }
  .session-hero__side-nav--left { left: 0.85rem; }
  .session-hero__side-nav--right { right: 0.85rem; }
  .session-hero__side-nav:hover { border-color: #E31C8D; }
  .session-hero__side-nav img { width: 2.7rem; height: 2.7rem; display: block; }
  .photo-grid { columns: 5; column-gap: var(--masonry-gap); }
  .photo-item { break-inside: avoid; display: block; width: 100%; margin-bottom: var(--masonry-gap); padding: 0; border: 2.7px solid var(--session-border); border-radius: 0 14px 0 14px; overflow: hidden; background: #000; cursor: zoom-in; }
  .photo-item:hover { border-color: #E31C8D; }
  .photo-item img { width: 100%; display: block; filter: grayscale(1) brightness(0.72); }
  .photo-item:hover img { filter: brightness(0.72); }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: grid;
    place-items: center;
    --session-border: #bfbfbf;
  }
  .lightbox[hidden] { display: none; }
  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(6px);
  }
  .lightbox__img {
    position: relative;
    z-index: 1;
    max-width: min(92vw, 1500px);
    max-height: 88vh;
    object-fit: contain;
    border: 2.7px solid #E31C8D;
    border-radius: 0 14px 0 14px;
    background: #000;
  }
  .lightbox__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    width: 4.4rem;
    height: 4.4rem;
    display: grid;
    place-items: center;
    border: 2.7px solid var(--session-border);
    border-radius: 0 14px 0 14px;
    background: #000;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease;
  }
  .lightbox__close img { width: 2.7rem; height: 2.7rem; }
  .lightbox__close:hover { border-color: #E31C8D; }
  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 4.4rem;
    height: 4.4rem;
    display: grid;
    place-items: center;
    border: 2.7px solid var(--session-border);
    border-radius: 0 14px 0 14px;
    background: #000;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease;
  }
  .lightbox__nav--prev { left: 1rem; }
  .lightbox__nav--next { right: 1rem; }
  .lightbox__nav img { width: 2.7rem; height: 2.7rem; }
  .lightbox__nav:hover { border-color: #E31C8D; }

  .lightbox__swipe-hint {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background: #000;
    border: 2.7px solid var(--session-border);
    border-radius: 0 14px 0 14px;
    padding: 1.2rem 1.8rem;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #fff;
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms ease;
    white-space: nowrap;
  }
  .lightbox__swipe-hint.is-visible { opacity: 1; }
  .lightbox__swipe-hint img { width: 1.8rem; height: 1.8rem; }

  :global([data-theme="light"]) .session-page-nav__island { background: #fff; }
  :global([data-theme="light"]) .session-page-nav__btn { background: #fff; color: #000; border-color: #404040; }
  :global([data-theme="light"]) .session-page-nav__btn img { filter: invert(1); }
  :global([data-theme="light"]) .session-page { background: #fff; color: #000; --session-border: #404040; }
  :global([data-theme="light"]) .photo-item { background: #fff; color: #000; border-color: #404040; }
  :global([data-theme="light"]) .session-hero__textlab { background: #fff; color: #000; border-color: #E31C8D; }
  :global([data-theme="light"]) .session-hero__body { background: #fff; }
  :global([data-theme="light"]) .session-hero__title,
  :global([data-theme="light"]) .session-hero__sub,
  :global([data-theme="light"]) .session-hero__meta { color: #000; }
  :global([data-theme="light"]) .session-hero__cat { color: #000; background: #fff; }
  :global([data-theme="light"]) .session-hero__cat { border-color: #404040; }
  :global([data-theme="light"]) .session-hero__side-nav { background: #fff; }
  :global([data-theme="light"]) .session-hero__scroll-indicator { background: #fff; }
  :global([data-theme="light"]) .lightbox__close { background: #fff; }
  :global([data-theme="light"]) .lightbox__nav { background: #fff; }
  :global([data-theme="light"]) .lightbox { --session-border: #404040; }
  :global([data-theme="light"]) .session-hero__side-nav img,
  :global([data-theme="light"]) .session-hero__scroll-indicator img,
  :global([data-theme="light"]) .lightbox__close img,
  :global([data-theme="light"]) .lightbox__nav img { filter: invert(1); }
  :global([data-theme="light"]) .session-hero__image,
  :global([data-theme="light"]) .photo-item img { filter: grayscale(1); }
  :global([data-theme="light"]) .photo-item:hover img { filter: none; }
  :global([data-theme="light"]) .photo-item:hover,
  :global([data-theme="light"]) .session-hero__scroll-indicator:hover,
  :global([data-theme="light"]) .session-hero__side-nav:hover { border-color: #E31C8D; }

  @media (max-width: 1024px) { .photo-grid { columns: 4; } }
  @media (max-width: 768px) {
    .session-hero__body { height: 78svh; }
    .photo-grid { columns: 3; }
  }
  .session-page-nav { display: none; transition: transform 300ms ease; }
  .session-page-nav.is-hidden { transform: translateY(calc(-100% - 7px)); }

  @media (max-width: 820px) {
    .session-hero__scroll-indicator { display: none; }
    .session-hero__side-nav { display: none; }
    .lightbox__nav { display: none; }
    .lightbox__close { width: 3rem; height: 3rem; }
    .lightbox__close img { width: 1.4rem; height: 1.4rem; }
    .lightbox__swipe-hint { border-color: #E31C8D; }
    .session-hero__overlay { padding: 0.32rem 0.38rem; }
    .session-hero__textlab { width: 100%; }

    .session-page-nav {
      display: block;
      position: fixed;
      top: calc(7px + 3rem + 0.64rem + 6px + 7px);
      left: 7px;
      right: 7px;
      max-width: none;
      z-index: 99;
    }
    .session-page-nav__island {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.34rem;
      padding: 0.32rem 0.38rem;
      background: #000;
      border: 2.7px solid #E31C8D;
      border-radius: 0 14px 0 14px;
    }
    .session-page-nav__btn {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      height: 3rem;
      padding: 0 0.6rem;
      border: 2.7px solid #bfbfbf;
      border-radius: 0 14px 0 14px;
      background: #000;
      color: #fff;
      font-family: 'Satoshi';
      font-size: 0.62rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      overflow: hidden;
      min-width: 0;
    }
    .session-page-nav__btn span {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      flex: 1;
      min-width: 0;
    }
    .session-page-nav__btn--next { justify-content: flex-end; }
    .session-page-nav__btn--next span { text-align: right; }
    .session-page-nav__btn img {
      width: 1.4rem;
      height: 1.4rem;
      flex-shrink: 0;
    }
  }
  @media (max-width: 520px) {
    .photo-grid { columns: 2; }
    .session-hero__meta { font-size: .76rem; }
  }
</style>

<script>
  const sessionScrollBtn = document.getElementById('sessionHeroScrollIndicator') as HTMLButtonElement | null;
  const sessionContent = document.getElementById('session-content');
  const sessionLightbox = document.getElementById('sessionLightbox') as HTMLElement | null;
  const sessionLightboxImg = document.getElementById('sessionLightboxImage') as HTMLImageElement | null;
  const sessionLightboxBackdrop = document.getElementById('sessionLightboxBackdrop') as HTMLButtonElement | null;
  const sessionLightboxClose = document.getElementById('sessionLightboxClose') as HTMLButtonElement | null;
  const sessionLightboxPrev = document.getElementById('sessionLightboxPrev') as HTMLButtonElement | null;
  const sessionLightboxNext = document.getElementById('sessionLightboxNext') as HTMLButtonElement | null;
  const photoButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.photo-item'));
  const photoSources = photoButtons
    .map((btn) => btn.querySelector('img'))
    .filter((img): img is HTMLImageElement => Boolean(img))
    .map((img) => ({ src: img.currentSrc || img.src, alt: img.alt || '' }));
  let currentLightboxIndex = 0;

  sessionScrollBtn?.addEventListener('click', () => {
    if (!sessionContent) return;
    const mainEl = document.querySelector('main');
    const masonryGapRaw = getComputedStyle(mainEl || document.documentElement).getPropertyValue('--masonry-gap');
    const masonryGap = Number.parseFloat(masonryGapRaw) || 0;
    const top = sessionContent.getBoundingClientRect().top + window.scrollY - masonryGap;
    window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
  });

  function showLightboxImage(index: number) {
    if (!sessionLightboxImg || !photoSources.length) return;
    const normalized = (index + photoSources.length) % photoSources.length;
    currentLightboxIndex = normalized;
    sessionLightboxImg.src = photoSources[normalized].src;
    sessionLightboxImg.alt = photoSources[normalized].alt;
  }

  function closeLightbox() {
    if (!sessionLightbox || !sessionLightboxImg) return;
    sessionLightbox.hidden = true;
    sessionLightboxImg.src = '';
    document.body.style.overflow = '';
  }

  photoButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const img = btn.querySelector('img');
      if (!img || !sessionLightbox || !sessionLightboxImg) return;
      const clickedIndex = Number.parseInt(btn.dataset.index || '0', 10) || 0;
      showLightboxImage(clickedIndex);
      sessionLightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    });
  });

  sessionLightboxBackdrop?.addEventListener('click', closeLightbox);
  sessionLightboxClose?.addEventListener('click', closeLightbox);
  sessionLightboxPrev?.addEventListener('click', () => showLightboxImage(currentLightboxIndex - 1));
  sessionLightboxNext?.addEventListener('click', () => showLightboxImage(currentLightboxIndex + 1));
  window.addEventListener('keydown', (event) => {
    if (sessionLightbox?.hidden) return;
    if (event.key === 'Escape') closeLightbox();
    if (event.key === 'ArrowLeft') showLightboxImage(currentLightboxIndex - 1);
    if (event.key === 'ArrowRight') showLightboxImage(currentLightboxIndex + 1);
  });

  // Swipe hint
  const swipeHint = document.getElementById('lightboxSwipeHint');
  const isMobile = () => window.matchMedia('(max-width: 820px)').matches;
  let swipeHintShown = false;
  let swipeHintTimer: ReturnType<typeof setTimeout> | null = null;
  function showSwipeHint() {
    if (!swipeHint || !isMobile() || swipeHintShown) return;
    swipeHintShown = true;
    swipeHint.classList.add('is-visible');
    swipeHintTimer = setTimeout(() => swipeHint.classList.remove('is-visible'), 2000);
  }

  // Touch swipe (vertical, like Instagram)
  let touchStartY = 0;
  sessionLightbox?.addEventListener('touchstart', (e) => {
    touchStartY = (e as TouchEvent).touches[0].clientY;
  }, { passive: true });
  sessionLightbox?.addEventListener('touchend', (e) => {
    const deltaY = (e as TouchEvent).changedTouches[0].clientY - touchStartY;
    if (Math.abs(deltaY) > 50) {
      deltaY < 0
        ? showLightboxImage(currentLightboxIndex + 1)
        : showLightboxImage(currentLightboxIndex - 1);
    }
  }, { passive: true });

  // Show hint on first open
  photoButtons.forEach((btn) => {
    btn.addEventListener('click', () => { showSwipeHint(); });
  });

  // Hide session nav on scroll down, show on scroll up
  const sessionPageNav = document.querySelector('.session-page-nav') as HTMLElement | null;
  let lastScrollY = window.scrollY;
  window.addEventListener('scroll', () => {
    const currentY = window.scrollY;
    if (currentY > lastScrollY && currentY > 80) {
      sessionPageNav?.classList.add('is-hidden');
    } else {
      sessionPageNav?.classList.remove('is-hidden');
    }
    lastScrollY = currentY;
  }, { passive: true });
</script>
