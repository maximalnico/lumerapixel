---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; slug: string | undefined; }
const { lang, slug } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const session = allSessions.find((s: any) => s.slug === slug);
if (!session) throw new Error(`Session not found: ${slug}`);

const sorted = [...allSessions].sort((a: any, b: any) => parseDMY(b.date) - parseDMY(a.date));
const idx = sorted.findIndex((s: any) => s.slug === slug);
const prev = sorted[idx + 1] ?? null;
const next = sorted[idx - 1] ?? null;

const title = isEN ? (session.title_en || session.title_de) : (session.title_de || session.title_en);
const subtitle = isEN ? (session.subtitle_en || session.subtitle_de) : (session.subtitle_de || session.subtitle_en);
const category = isEN ? (session.category_en || session.category) : (session.category_de || session.category);
const navTitle = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const sessionPath = (s: string) => isEN ? `/en/sessions/${s}` : `/sessions/${s}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

const folder = session.folder;
const photos: string[] = Array.from({ length: session.images }, (_, i) => `${folder}/${String(i).padStart(3, '0')}.webp`);
const [d, m, y] = session.date.split('.');
const dateStr = new Date(+y, +m - 1, +d).toLocaleDateString(dateLocale, { day: '2-digit', month: 'long', year: 'numeric' });

const siteUrl = 'https://lumerapixel.com';
const pageUrl = isEN ? `${siteUrl}/en/sessions/${slug}` : `${siteUrl}/sessions/${slug}`;
const deUrl = `${siteUrl}/sessions/${slug}`;
const enUrl = `${siteUrl}/en/sessions/${slug}`;
const ogImg = photos[0] ? `${siteUrl}${photos[0]}` : `${siteUrl}/logos/lplong.svg`;
---

<Base
  title={`${title} – LumeraPixel`}
  description={subtitle || title}
  ogImage={ogImg}
  ogType="article"
  canonical={pageUrl}
  hreflangDe={deUrl}
  hreflangEn={enUrl}
>
  <Nav />

  <main class="session-page">
    <header class="session-hero">
      <div class="session-hero__nav">
        <span>
          {next && (
            <a href={sessionPath(next.slug)} class="session-hero__nav-btn">
              <img src="/logos/phosphoricons/white/caret-left-thin.svg" alt="" aria-hidden="true" class="session-hero__nav-icon" />
              <span>{navTitle(next)}</span>
            </a>
          )}
        </span>
        <span>
          {prev && (
            <a href={sessionPath(prev.slug)} class="session-hero__nav-btn">
              <span>{navTitle(prev)}</span>
              <img src="/logos/phosphoricons/white/caret-right-thin.svg" alt="" aria-hidden="true" class="session-hero__nav-icon" />
            </a>
          )}
        </span>
      </div>

      <div class="session-hero__body">
        <div class="session-hero__preview-wrap">
          <img src={photos[0]} alt={title} class="session-hero__preview" loading="eager" decoding="async" />
        </div>
        <div class="session-hero__text">
          <div class="session-hero__meta">
            <span class="session-hero__cat">{category}</span>
            <span>{session.images} {t(lang, 'session.photos')}</span>
            <span>{dateStr}</span>
          </div>
          <h1 class="session-hero__title">{title}</h1>
          {subtitle && <p class="session-hero__sub">{subtitle}</p>}
        </div>
      </div>
    </header>

    <section class="photo-section" aria-label="Fotos">
      <div class="photo-grid" id="photoGrid">
        {photos.map((src, i) => (
          <button class="photo-item" data-index={i} aria-label={isEN ? `Photo ${i + 1} of ${session.images}` : `Foto ${i + 1} von ${session.images}`}>
            <img src={src} alt={`${title} – ${isEN ? 'Photo' : 'Foto'} ${i + 1}`} loading={i < 4 ? 'eager' : 'lazy'} decoding="async" />
          </button>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .session-page { background: #000; min-height: 100svh; color: #fff; }
  .session-hero {
    padding: calc(var(--nav-h) + 1rem) 7px 1.5rem;
    display: flex; flex-direction: column; gap: 1rem;
  }
  .session-hero__nav { display: flex; justify-content: space-between; gap: .75rem; }
  .session-hero__nav-btn {
    display: inline-flex; align-items: center; gap: .45rem;
    border: 2.7px solid #404040; border-radius: 0 14px 0 14px;
    color: #fff; text-decoration: none; padding: .5rem .85rem;
    background: #000; max-width: 38vw;
  }
  .session-hero__nav-btn:hover { border-color: #E31C8D; }
  .session-hero__nav-icon { width: 16px; height: 16px; }
  .session-hero__body {
    margin: 0 0 0;
    border: 2.7px solid #E31C8D; border-radius: 0 14px 0 14px;
    overflow: hidden;
    display: grid; grid-template-columns: minmax(280px, 1fr) 1fr;
    background: #000;
  }
  .session-hero__preview-wrap { min-height: 280px; }
  .session-hero__preview { width: 100%; height: 100%; object-fit: cover; display: block; }
  .session-hero__text { padding: 1.1rem; display: flex; flex-direction: column; justify-content: center; }
  .session-hero__meta { display: flex; flex-wrap: wrap; gap: .5rem; font-size: .85rem; text-transform: uppercase; letter-spacing: .08em; color: #cfcfcf; }
  .session-hero__cat { border: 2.7px solid #404040; border-radius: 0 14px 0 14px; padding: .05rem .5rem; color: #fff; }
  .session-hero__title { font-size: clamp(2rem, 5vw, 4rem); line-height: .95; margin-top: .6rem; }
  .session-hero__sub { margin-top: .6rem; color: #ddd; max-width: 60ch; }

  .photo-section { padding: 7px; }
  .photo-grid { columns: 5; column-gap: .5rem; }
  .photo-item {
    break-inside: avoid; display: block; width: 100%; margin-bottom: .5rem; padding: 0;
    border: 2.7px solid #404040; border-radius: 0 14px 0 14px;
    overflow: hidden; background: #000; cursor: zoom-in;
  }
  .photo-item:hover { border-color: #E31C8D; }
  .photo-item img { width: 100%; display: block; }

  @media (max-width: 1024px) { .photo-grid { columns: 4; } }
  @media (max-width: 768px) {
    .session-hero__body { grid-template-columns: 1fr; }
    .session-hero__nav-btn { max-width: 45vw; }
    .photo-grid { columns: 3; }
  }
  @media (max-width: 520px) {
    .photo-grid { columns: 2; }
    .session-hero__nav-btn { max-width: 42vw; font-size: .8rem; }
  }
</style>
