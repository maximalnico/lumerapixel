---
import Base from '../../layouts/Base.astro';
import Footer from '../Footer.astro';
import Nav from '../Nav.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const sorted = [...allSessions].sort((a, b) => parseDMY(b.date) - parseDMY(a.date));
const headerSession = sorted[0];
const headerImage = 'https://lumerapixel.b-cdn.net/collage.webp';
const allSessionCovers = sorted.map((s: any) => `${s.folder}/000.webp`).filter(Boolean);
const totalPhotos = allSessions.reduce((s: number, ses: any) => s + (ses.images || 0), 0);
const featuredSessions = allSessions.filter((s: any) => s.featured).length >= 2
  ? allSessions.filter((s: any) => s.featured).slice(0, 2)
  : sorted.slice(0, 2);

// Lang helpers
const st = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const ss = (s: any) => isEN ? (s.subtitle_en || s.subtitle_de) : (s.subtitle_de || s.subtitle_en);
const sc = (s: any) => isEN ? (s.category_en || s.category) : (s.category_de || s.category);
const sessionPath = (slug: string) => isEN ? `/en/sessions/${slug}` : `/sessions/${slug}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';
const sessionCategories = Array.from(new Set(sorted.map((s: any) => sc(s)).filter(Boolean)));

// SEO
const siteUrl = 'https://lumerapixel.com';
const canonicalUrl = isEN ? `${siteUrl}/en/` : `${siteUrl}/`;
const pageTitle = isEN
  ? 'LumeraPixel – Photography by MaximalNico | Lost Places · Automotive · Aerial'
  : 'LumeraPixel – Fotografie von MaximalNico | Lost Places · Automotive · Aerial';
const pageDesc = isEN
  ? `Photography portfolio by Nico Henkel from Bavaria. ${allSessions.length} sessions with ${totalPhotos.toLocaleString('en-US')} photos covering Lost Places, Automotive and Aerial Photography.`
  : `Fotografieportfolio von Nico Henkel aus Bayern. ${allSessions.length} Sessions mit ${totalPhotos.toLocaleString('de-DE')} Fotos aus den Kategorien Lost Places, Automotive und Aerial Photography.`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "LumeraPixel",
      "description": "Photography portfolio by Nico Henkel – Lost Places, Automotive & Aerial Photography from Bavaria.",
      "inLanguage": isEN ? "en" : "de-DE",
      "author": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Nico Thomas Henkel",
      "alternateName": "MaximalNico",
      "url": siteUrl,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Blumenstraße 26",
        "addressLocality": "Neuching",
        "postalCode": "85467",
        "addressCountry": "DE"
      },
      "knowsAbout": ["Photography", "Lost Places", "Automotive Photography", "Aerial Photography", "Drone", "Fujifilm"],
      "sameAs": [`${siteUrl}`]
    },
    {
      "@type": "ImageGallery",
      "@id": `${siteUrl}/#gallery`,
      "name": "LumeraPixel Photo Gallery",
      "description": pageDesc,
      "url": siteUrl,
      "numberOfItems": allSessions.length,
      "author": { "@id": `${siteUrl}/#person` }
    }
  ]
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={`${siteUrl}/logos/lplong.svg`}
  canonical={canonicalUrl}
  {schema}
  hreflangDe={`${siteUrl}/`}
  hreflangEn={`${siteUrl}/en/`}
>
  <Nav />
  <main>
    <section class="masonry-home">
      <section class="fullscreen-header" aria-label="Header">
        <div class="fullscreen-header__frame">
          {headerImage && <img class="fullscreen-header__image" src={headerImage} alt={st(headerSession)} loading="eager" decoding="async" />}
          <div class="fullscreen-header__overlay">
            <div class="fullscreen-header__glasslab">
              <img src="/logos/lplong-white.svg" alt="LumeraPixel" class="fullscreen-header__logo" />
              <p class="fullscreen-header__sub">{t(lang, 'hero.tagline')}</p>
            </div>
          </div>
        </div>
        <a id="heroToFeaturedIndicator" class="fullscreen-header__scroll-indicator" href="#" aria-label="Zu Featured Sessions scrollen">
          <img src="/logos/phosphoricons/white/caret-down-thin.svg" alt="" />
        </a>
      </section>

      <section class="featured-split" id="featured-sessions" aria-label="Featured Sessions">
        <div class="featured-split__heading-lab">
          <h2 class="featured-split__heading">Featured Sessions</h2>
        </div>
        <div class="featured-split__grid">
          {featuredSessions.map((s: any) => {
            const cover = `${s.folder}/000.webp`;
            return (
              <a href={sessionPath(s.slug)} class="featured-split__item">
                <img src={cover} alt={st(s)} loading="lazy" decoding="async" />
                <span class="featured-split__overlay">
                  <span class="featured-split__cat">{sc(s)}</span>
                  <span class="featured-split__title">{st(s)}</span>
                </span>
              </a>
            );
          })}
        </div>
        <a id="featuredToLatestIndicator" class="fullscreen-header__scroll-indicator featured-split__scroll-indicator" href="#" aria-label="Zur neuesten Session scrollen">
          <img src="/logos/phosphoricons/white/caret-down-thin.svg" alt="" />
        </a>
      </section>

      <a
        id="latest-session-strip"
        class="latest-session-strip"
        href={sessionPath(headerSession.slug)}
        aria-label={isEN ? 'Open latest session' : 'Neueste Session öffnen'}
      >
        <img id="allSessionsSlideshowImage" src={`${headerSession.folder}/000.webp`} data-slides={allSessionCovers.join('|')} alt={st(headerSession)} loading="lazy" decoding="async" />
        <div class="masonry-home__filters-lab latest-session-strip__heading-lab">
          <h2 class="masonry-home__filters-title">{isEN ? 'ALL SESSIONS' : 'ALLE SESSIONS'}</h2>
        </div>
      </a>

      <section class="masonry-home__filters" aria-label="Session Filter">
        <div class="masonry-home__filters-controls">
          <button class="masonry-home__filter-btn is-active" data-session-filter="all" type="button">
            {isEN ? 'All' : 'Alle'}
          </button>
          {sessionCategories.map((category) => (
            <button class="masonry-home__filter-btn" data-session-filter={category} type="button">
              {category}
            </button>
          ))}
        </div>
      </section>

      <div class="masonry-home__grid">
        {sorted.map((s: any, i: number) => {
          const cover = `${s.folder}/000.webp`;
          const category = sc(s);
          return (
            <a href={sessionPath(s.slug)} class="masonry-card" data-category={category}>
              <img src={cover} alt={st(s)} loading={i < 4 ? 'eager' : 'lazy'} decoding="async" />
              <span class="masonry-card__overlay">
                <span class="masonry-card__pill masonry-card__pill--cat">{category}</span>
                <span class="masonry-card__pill masonry-card__pill--title">{st(s)}</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>

  </main>

  <!-- Footer -->
  <Footer />

</Base>

<style>
  main {
    background: #0f1118;
    min-height: 100svh;
    color: #f6f6f6;
    --masonry-gap: 7px;
  }

  .fullscreen-header {
    position: relative;
    height: calc(100svh - (var(--masonry-gap) * 2));
    min-height: calc(100svh - (var(--masonry-gap) * 2));
    margin: var(--masonry-gap);
    overflow: hidden;
    background: #000000;
    border-radius: 0 14px 0 14px;
    border: 1px solid #E31C8D;
  }

  .fullscreen-header__frame {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
    background: #000000;
  }

  .fullscreen-header__image {
    width: 100%;
    height: 100%;
    min-height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.06);
    transition: opacity 500ms ease;
  }

  .fullscreen-header__overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    align-content: center;
    text-align: center;
    gap: 1rem;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.42) 0%, rgba(0, 0, 0, 0.12) 22%, rgba(0, 0, 0, 0.12) 78%, rgba(0, 0, 0, 0.42) 100%);
    padding: 1.2rem;
  }

  .fullscreen-header__glasslab {
    display: grid;
    gap: 1rem;
    justify-items: center;
    padding: clamp(1rem, 2.3vw, 1.8rem) clamp(1.2rem, 3vw, 2.3rem);
    background: #000000;
    border: 1px solid #E31C8D;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: 0 14px 28px rgba(0,0,0,0.5);
    border-radius: 0 14px 0 14px;
    max-width: min(92vw, 52rem);
  }

  .fullscreen-header__scroll-indicator {
    position: absolute;
    left: 50%;
    bottom: 0.85rem;
    transform: translateX(-50%);
    width: 4.6rem;
    height: 4.6rem;
    border-radius: 0 14px 0 14px;
    border: 1px solid #808080;
    background: #000000;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    display: grid;
    place-items: center;
    box-shadow: 0 8px 20px rgba(0,0,0,0.42);
    z-index: 3;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }
  .fullscreen-header__scroll-indicator:hover {
    transform: translateX(-50%) scale(1.1);
    border-color: #E31C8D;
    box-shadow: 0 12px 26px rgba(0,0,0,0.5);
  }
  .fullscreen-header__scroll-indicator img {
    width: 2.9rem;
    height: 2.9rem;
    display: block;
  }

  .fullscreen-header__logo {
    width: clamp(240px, 40vw, 620px);
    height: auto;
  }

  .fullscreen-header__sub {
    font-size: clamp(1rem, 1.6vw, 1.4rem);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #ffffff;
  }

  .masonry-home__grid {
    columns: 4;
    column-gap: var(--masonry-gap);
    padding: var(--masonry-gap);
    background: #0f1118;
  }

  .latest-session-strip {
    margin: var(--masonry-gap);
    position: relative;
    display: block;
    height: calc(100svh / 3);
    overflow: hidden;
    border: 1px solid #E31C8D;
    border-radius: 0 14px 0 14px;
    scroll-margin-top: calc(var(--nav-h) + 1.2rem);
    outline: none;
  }
  .latest-session-strip:focus,
  .latest-session-strip:focus-visible,
  .latest-session-strip:target {
    outline: none;
    box-shadow: none;
  }
  .latest-session-strip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.72) contrast(1.04);
  }
  .latest-session-strip__heading-lab {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    pointer-events: none;
  }

  .masonry-home__filters {
    margin: var(--masonry-gap);
    margin-top: clamp(0.9rem, 2vw, 1.5rem);
    display: grid;
    justify-items: center;
    gap: 0.6rem;
  }

  .masonry-home__filters-lab {
    border: 1px solid #E31C8D;
    background: #000000;
    border-radius: 0 14px 0 14px;
    padding: 0.7rem 1.3rem;
  }

  .masonry-home__filters-title {
    margin: 0;
    font-size: clamp(1.12rem, 2.25vw, 1.75rem);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #ffffff;
    text-align: center;
  }

  .masonry-home__filters-controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.45rem;
  }

  .masonry-home__filter-btn {
    border: 1px solid #808080;
    background: #000000;
    color: #ffffff;
    border-radius: 0 14px 0 14px;
    padding: 0.5rem 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.76rem;
    cursor: pointer;
  }

  .masonry-home__filter-btn:hover,
  .masonry-home__filter-btn.is-active {
    border-color: #E31C8D;
  }

  .featured-split {
    margin: var(--masonry-gap);
    height: calc(100svh - (var(--masonry-gap) * 2));
    display: block;
    position: relative;
    overflow: hidden;
  }
  .featured-split__heading {
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.12rem, 2.25vw, 1.75rem);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-align: center;
  }
  .featured-split__heading-lab {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    border-radius: 0 14px 0 14px;
    border: 1px solid #E31C8D;
    background: #000000;
    padding: 0.7rem 1.3rem;
    z-index: 4;
    pointer-events: none;
  }
  .featured-split__grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: var(--masonry-gap);
    min-height: 0;
    height: 100%;
  }

  .featured-split__item {
    position: relative;
    overflow: hidden;
    border-radius: 0 14px 0 14px;
    border: 1px solid #E31C8D;
    background: #000000;
    min-height: 0;
    height: 100%;
    display: block;
  }
  .featured-split__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.04) saturate(1.02);
    transition: transform 420ms ease, filter 320ms ease;
  }
  .featured-split__overlay {
    position: absolute;
    inset: 0;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 0.45rem;
    padding: 1rem;
    background: linear-gradient(180deg, rgba(0,0,0,0.08) 32%, rgba(0,0,0,0.72) 100%);
  }
  .featured-split__cat,
  .featured-split__title {
    width: min(90%, max-content);
    text-align: center;
    border-radius: 0 14px 0 14px;
    border: 1px solid #E31C8D;
    background: #000000;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    text-transform: uppercase;
    color: #ffffff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .featured-split__cat {
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    padding: 0.44rem 0.72rem;
  }
  .featured-split__title {
    font-size: clamp(0.78rem, 1vw, 0.98rem);
    letter-spacing: 0.12em;
    padding: 0.58rem 0.86rem;
  }
  .featured-split__item:hover img {
    transform: scale(1.03);
    filter: brightness(0.86) contrast(1.06);
  }

  .featured-split__scroll-indicator {
    bottom: 0.75rem;
  }

  .masonry-card {
    position: relative;
    overflow: hidden;
    display: block;
    background: #111;
    break-inside: avoid;
    margin-bottom: var(--masonry-gap);
  }
  .masonry-card img {
    width: 100%;
    height: auto;
    object-fit: cover;
    transition: filter 320ms ease;
  }

  .masonry-card__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    padding: 0.8rem;
  }

  .masonry-card__pill {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    max-width: min(92%, 30rem);
    backdrop-filter: blur(14px) saturate(1.05);
    -webkit-backdrop-filter: blur(14px) saturate(1.05);
    border: 1px solid #E31C8D;
    background: linear-gradient(165deg, rgba(9,12,20,0.66), rgba(9,12,20,0.38));
    border-radius: 14px 0 14px 0;
    opacity: 0;
    transition: opacity 280ms ease, transform 280ms ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .masonry-card__pill--cat {
    top: 0.75rem;
    padding: 0.42rem 0.72rem;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #E31C8D;
    max-width: max-content;
  }

  :global([data-theme="dark"]) .featured-split__cat,
  :global([data-theme="dark"]) .masonry-card__pill--cat {
    border-color: #e31c8d;
    background: #000000;
    color: #e31c8d;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .masonry-card__pill--title {
    bottom: 0.75rem;
    padding: 0.58rem 0.86rem;
    font-size: clamp(0.76rem, 1vw, 0.92rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
  }

  .masonry-card:hover img {
    filter: brightness(0.82) contrast(1.05);
  }
  .masonry-card:hover .masonry-card__pill--cat,
  .masonry-card:hover .masonry-card__pill--title {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 1100px) {
    .masonry-home__grid { columns: 3; }
  }

  @media (max-width: 700px) {
    .featured-split {
      height: auto;
    }
    .featured-split__grid { grid-template-columns: 1fr; }
    .featured-split__item {
      min-height: 60svh;
    }
    .masonry-home__grid { columns: 2; }
  }

  @media (max-width: 480px) {
    .masonry-home__grid { columns: 1; }
  }

  :global([data-theme="light"]) main,
  :global([data-theme="dark"]) main {
    background: #0f1118;
    color: #f6f6f6;
  }
</style>

<script>
  // Random slideshow for the "All Sessions" strip.
  const allSessionsImg = document.getElementById('allSessionsSlideshowImage') as HTMLImageElement | null;
  if (allSessionsImg) {
    const slides = (allSessionsImg.dataset.slides || '')
      .split('|')
      .map((s) => s.trim())
      .filter(Boolean);

    if (slides.length > 1) {
      let current = allSessionsImg.src;
      setInterval(() => {
        const choices = slides.filter((slide) => !current.endsWith(slide));
        const nextPool = choices.length ? choices : slides;
        const next = nextPool[Math.floor(Math.random() * nextPool.length)];
        current = next;
        allSessionsImg.src = next;
      }, 2700);
    }
  }

  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.masonry-home__filter-btn'));
  const masonryCards = Array.from(document.querySelectorAll<HTMLElement>('.masonry-card'));

  function applySessionFilter(filterValue: string) {
    masonryCards.forEach((card) => {
      const category = card.dataset.category;
      const isVisible = filterValue === 'all' || category === filterValue;
      card.style.display = isVisible ? 'block' : 'none';
    });

    filterButtons.forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.sessionFilter === filterValue);
    });
  }

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      applySessionFilter(btn.dataset.sessionFilter || 'all');
    });
  });

  const heroToFeaturedIndicator = document.getElementById('heroToFeaturedIndicator') as HTMLAnchorElement | null;
  const firstFeaturedCard = document.querySelector<HTMLElement>('.featured-split__item');
  const featuredToLatestIndicator = document.getElementById('featuredToLatestIndicator') as HTMLAnchorElement | null;
  const latestSessionStrip = document.getElementById('latest-session-strip');

  heroToFeaturedIndicator?.addEventListener('click', (event) => {
    if (!firstFeaturedCard) return;
    event.preventDefault();
    const mainEl = document.querySelector('main');
    const masonryGapRaw = getComputedStyle(mainEl || document.documentElement).getPropertyValue('--masonry-gap');
    const masonryGap = Number.parseFloat(masonryGapRaw) || 0;
    const top = firstFeaturedCard.getBoundingClientRect().top + window.scrollY - masonryGap;
    window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
  });

  featuredToLatestIndicator?.addEventListener('click', (event) => {
    if (!latestSessionStrip) return;
    event.preventDefault();
    const mainEl = document.querySelector('main');
    const masonryGapRaw = getComputedStyle(mainEl || document.documentElement).getPropertyValue('--masonry-gap');
    const masonryGap = Number.parseFloat(masonryGapRaw) || 0;
    const top = latestSessionStrip.getBoundingClientRect().top + window.scrollY - masonryGap;
    window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
  });

</script>
