---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const sorted = [...allSessions].sort((a, b) => parseDMY(b.date) - parseDMY(a.date));
const totalPhotos = allSessions.reduce((s: number, ses: any) => s + (ses.images || 0), 0);
const categories = [...new Set(allSessions.map((s: any) => s.category))];

const featured = allSessions.filter((s: any) => s.featured).length >= 1
  ? allSessions.filter((s: any) => s.featured).slice(0, 3)
  : sorted.slice(0, 3);

const slideshowSessions = [...allSessions]
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);

// Lang helpers
const st = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const ss = (s: any) => isEN ? (s.subtitle_en || s.subtitle_de) : (s.subtitle_de || s.subtitle_en);
const sc = (s: any) => isEN ? (s.category_en || s.category) : (s.category_de || s.category);
const sessionPath = (slug: string) => isEN ? `/en/sessions/${slug}` : `/sessions/${slug}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

// SEO
const siteUrl = 'https://lumerapixel.com';
const canonicalUrl = isEN ? `${siteUrl}/en/` : `${siteUrl}/`;
const pageTitle = isEN
  ? 'LumeraPixel – Photography by MaximalNico | Lost Places · Automotive · Aerial'
  : 'LumeraPixel – Fotografie von MaximalNico | Lost Places · Automotive · Aerial';
const pageDesc = isEN
  ? `Photography portfolio by Nico Henkel from Bavaria. ${allSessions.length} sessions with ${totalPhotos.toLocaleString('en-US')} photos covering Lost Places, Automotive and Aerial Photography.`
  : `Fotografieportfolio von Nico Henkel aus Bayern. ${allSessions.length} Sessions mit ${totalPhotos.toLocaleString('de-DE')} Fotos aus den Kategorien Lost Places, Automotive und Aerial Photography.`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "LumeraPixel",
      "description": "Photography portfolio by Nico Henkel – Lost Places, Automotive & Aerial Photography from Bavaria.",
      "inLanguage": isEN ? "en" : "de-DE",
      "author": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Nico Thomas Henkel",
      "alternateName": "MaximalNico",
      "url": siteUrl,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Blumenstraße 26",
        "addressLocality": "Neuching",
        "postalCode": "85467",
        "addressCountry": "DE"
      },
      "knowsAbout": ["Photography", "Lost Places", "Automotive Photography", "Aerial Photography", "Drone", "Fujifilm"],
      "sameAs": [`${siteUrl}`]
    },
    {
      "@type": "ImageGallery",
      "@id": `${siteUrl}/#gallery`,
      "name": "LumeraPixel Photo Gallery",
      "description": pageDesc,
      "url": siteUrl,
      "numberOfItems": allSessions.length,
      "author": { "@id": `${siteUrl}/#person` }
    }
  ]
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={`${siteUrl}/logos/lplong.svg`}
  canonical={canonicalUrl}
  {schema}
  hreflangDe={`${siteUrl}/`}
  hreflangEn={`${siteUrl}/en/`}
>
  <Nav />

  <main>

    <!-- ══ HERO ══ -->
    <section class="hero" aria-label="Hero">

      <!-- Slideshow Box links -->
      <div class="hero__slideshow-wrap">
        <div class="hero__slideshow" id="slideshow">
          <div class="hero__vhs-glitch" aria-hidden="true"></div>
          {slideshowSessions.map((s: any, i: number) => {
            const cover = s.folder + '/000.webp';
            return (
              <img
                src={cover}
                alt=""
                class={`hero__slide ${i === 0 ? 'is-active' : ''}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            );
          })}
        </div>
      </div>

      <!-- Text rechts -->
      <div class="hero__content">
        <img src="/logos/lplong.svg" alt="LumeraPixel" class="hero__logo" />
        <p class="hero__tagline">{t(lang, 'hero.tagline')}</p>

        <!-- Stats inline rechts -->
        <div class="hero__stats">
          <div class="hero__stats-item">
            <span class="hero__stats-num">{allSessions.length}</span>
            <span class="hero__stats-label">{t(lang, 'stats.sessions')}</span>
          </div>
          <div class="hero__stats-sep" aria-hidden="true"></div>
          <div class="hero__stats-item">
            <span class="hero__stats-num">{totalPhotos.toLocaleString('de-DE')}</span>
            <span class="hero__stats-label">{t(lang, 'stats.photos')}</span>
          </div>
          <div class="hero__stats-sep" aria-hidden="true"></div>
          <div class="hero__stats-item">
            <span class="hero__stats-num">{categories.length}</span>
            <span class="hero__stats-label">{t(lang, 'stats.categories')}</span>
          </div>
        </div>

        <!-- Scroll hint -->
        <a href="#featured" class="scroll-hint" aria-label={t(lang, 'hero.tagline')}>
          <svg class="scroll-hint__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true">
            <rect width="256" height="256" fill="none"/>
            <polyline points="208 96 128 176 48 96" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/>
          </svg>
        </a>
      </div>

    </section>

    <!-- ══ FEATURED SESSIONS ══ -->
    <section class="featured-section" id="featured" aria-label="Featured Sessions">
      <div class="featured-section__head">
        <div class="featured-section__line" aria-hidden="true"></div>
        <h2 class="featured-section__title">{t(lang, 'section.highlights')}</h2>
        <div class="featured-section__line" aria-hidden="true"></div>
      </div>

      <div class="featured-grid">
        {featured.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          const [d, m, y] = s.date.split('.');
          const dateStr = new Date(+y, +m - 1, +d).toLocaleDateString(dateLocale, { month: 'long', year: 'numeric' });
          return (
            <a href={sessionPath(s.slug)} class="featured-card">
              <div class="featured-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
                <div class="featured-card__img-overlay"></div>
              </div>
              <div class="featured-card__body">
                <span class="featured-card__cat">{sc(s)}</span>
                <h3 class="featured-card__title">{st(s)}</h3>
                <span class="featured-card__date">{dateStr}</span>
              </div>
              <div class="featured-card__arrow" aria-hidden="true">
                <svg class="featured-card__arrow-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true"><rect width="256" height="256" fill="none"/><polyline points="96 48 176 128 96 208" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/></svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- ══ ALLE SESSIONS + FILTER + MASONRY ══ -->
    <section class="all-section" id="sessions" aria-label="Alle Sessions">

      <!-- Filter -->
      <div class="filter-bar reveal" id="filterBar">
        <button class="filter-btn is-active" data-cat="all">{t(lang, 'filter.all')}</button>
        {categories.map((cat: string) => (
          <button class="filter-btn" data-cat={cat}>{cat}</button>
        ))}
      </div>

      <div class="rg-line reveal" style="margin: 0 var(--page-x) var(--gap-md);"></div>

      <!-- Masonry Grid -->
      <div class="masonry-grid" id="masonryGrid">
        {sorted.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          return (
            <a href={sessionPath(s.slug)} class="session-card reveal" data-cat={s.category}>
              <div class="session-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
              </div>
              <div class="session-card__body glass">
                <h3 class="session-card__title">{st(s)}</h3>
                <span class="session-card__cat">{sc(s)}</span>
              </div>
            </a>
          );
        })}
      </div>

    </section>

  </main>

  <!-- Footer -->
  <Footer />

</Base>

<style>
  main {
    position: relative;
    isolation: isolate;
    --cut: 12px;
    --military-1: #171d15;
    --military-2: #222a20;
    --military-3: #2d3829;
    --pinky: #E31C8D;
    --pinky-soft: rgba(227, 28, 141, 0.26);
    --shape: polygon(var(--cut) 0, 100% 0, 100% calc(100% - var(--cut)), calc(100% - var(--cut)) 100%, 0 100%, 0 var(--cut));
  }

  .hero,
  .featured-section,
  .all-section { position: relative; }

  .hero {
    min-height: calc(100svh - var(--nav-h));
    padding: calc(var(--nav-h) + 1.2rem) var(--page-x) var(--gap-lg);
    display: grid;
    grid-template-columns: 1.3fr 0.8fr;
    gap: clamp(1rem, 2vw, 2rem);
    align-items: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      repeating-linear-gradient(0deg, rgba(255,255,255,0.03) 0 1px, transparent 1px 4px),
      radial-gradient(circle at 22% 12%, rgba(227, 28, 141, 0.18), transparent 32%);
    mix-blend-mode: screen;
    opacity: 0.8;
  }

  .hero__slideshow-wrap {
    background: linear-gradient(145deg, rgba(255,255,255,0.24), rgba(255,255,255,0.04));
    padding: 1px;
    clip-path: var(--shape);
    border-radius: 0 16px 0 16px;
    box-shadow: 0 22px 46px rgba(0,0,0,0.62);
  }

  .hero__slideshow {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    clip-path: var(--shape);
    border-radius: 0 14px 0 14px;
    background: #050706;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 680ms cubic-bezier(0.2, 0.6, 0, 1);
    filter: grayscale(0.55) sepia(0.2) saturate(0.9) contrast(1.18) brightness(0.58);
  }
  .hero__slide.is-active { opacity: 1; }

  .hero__vhs-glitch {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transform: translateX(-100%);
    background:
      repeating-linear-gradient(to bottom, rgba(255,255,255,0.08) 0 2px, transparent 2px 4px),
      linear-gradient(90deg, transparent 0 30%, rgba(227,28,141,0.5) 30% 38%, transparent 38% 100%);
    mix-blend-mode: screen;
  }
  .hero__vhs-glitch.is-glitch { animation: vhs-glitch 360ms steps(4, end) 1; }

  .hero__content {
    background: linear-gradient(160deg, rgba(24,31,22,0.92), rgba(14,20,14,0.9));
    border: 1px solid rgba(255,255,255,0.18);
    box-shadow: 0 14px 34px rgba(0,0,0,0.5);
    clip-path: var(--shape);
    border-radius: 0 18px 0 18px;
    padding: clamp(0.8rem, 2vw, 1.2rem);
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 0.8rem;
  }

  .hero__logo { height: clamp(2rem, 4vw, 3.3rem); filter: grayscale(1) brightness(1.7); }

  .hero__tagline {
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: clamp(0.74rem, 1.3vw, 0.96rem);
    color: rgba(255,255,255,0.75);
  }

  .hero__stats {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.18);
    clip-path: var(--shape);
    border-radius: 0 12px 0 12px;
    padding: 1px;
  }
  .hero__stats-item {
    background: linear-gradient(170deg, rgba(30,38,28,0.94), rgba(12,16,12,0.95));
    padding: 0.55rem 0.45rem;
    display: grid;
    gap: 0.08rem;
    clip-path: var(--shape);
    border-radius: 0 10px 0 10px;
  }
  .hero__stats-sep { display: none; }
  .hero__stats-num { font-size: clamp(1.06rem, 2vw, 1.5rem); line-height: 1; font-weight: 700; color: #fff; }
  .hero__stats-label { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.62); }

  .scroll-hint { position: absolute; bottom: 0.75rem; left: 50%; transform: translateX(-50%); color: var(--pinky); }
  .scroll-hint__arrow { width: 1.75rem; height: 1.75rem; }

  .featured-section { padding: var(--gap-md) var(--page-x); }
  .featured-section__head {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1rem;
  }
  .featured-section__line { height: 1px; background: linear-gradient(90deg, transparent, rgba(227, 28, 141, 0.6), transparent); }
  .featured-section__title { letter-spacing: 0.22em; text-transform: uppercase; font-size: clamp(0.95rem, 1.7vw, 1.3rem); }

  .featured-grid { display: grid; grid-template-columns: 1fr; gap: 0.8rem; }

  .featured-card {
    display: grid;
    grid-template-columns: 1.18fr 1fr;
    background: linear-gradient(150deg, rgba(27,34,24,0.95), rgba(13,18,13,0.95));
    border: 1px solid rgba(255,255,255,0.16);
    clip-path: var(--shape);
    border-radius: 0 18px 0 18px;
    overflow: hidden;
    box-shadow: 0 9px 24px rgba(0,0,0,0.48);
    transition: transform var(--flow), box-shadow var(--flow), border-color var(--flow);
  }
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 36px rgba(0,0,0,0.62);
    border-color: rgba(227,28,141,0.55);
  }

  .featured-card__img,
  .featured-card__img img { clip-path: var(--shape); border-radius: 0 14px 0 14px; }
  .featured-card__img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.55) sepia(0.2) contrast(1.14) brightness(0.63); }
  .featured-card__img-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, transparent 25%, rgba(16,21,16,0.92) 74%); }

  .featured-card__body { padding: 0.9rem 1rem 1rem; display: grid; gap: 0.4rem; align-content: center; }

  .featured-card__cat,
  .session-card__cat {
    width: fit-content;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.2rem 0.62rem;
    border: 1px solid rgba(227,28,141,0.55);
    color: #ffd6ec;
    background: rgba(227,28,141,0.14);
    clip-path: var(--shape);
    border-radius: 0 10px 0 10px;
  }

  .featured-card__title { font-size: clamp(1rem, 2vw, 1.42rem); line-height: 1.08; }
  .featured-card__date { font-size: 0.74rem; color: rgba(255,255,255,0.66); letter-spacing: 0.08em; }
  .featured-card__arrow { position: absolute; right: 0.7rem; bottom: 0.7rem; color: var(--pinky); }

  .all-section { padding: var(--gap-md) 0 var(--gap-xl); border-top: 1px solid rgba(255,255,255,0.14); }

  .filter-bar { display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0 var(--page-x); margin-bottom: 1rem; }

  .filter-btn {
    border: 1px solid rgba(255,255,255,0.22);
    background: linear-gradient(160deg, rgba(33,42,30,0.95), rgba(17,22,16,0.92));
    color: rgba(255,255,255,0.88);
    font-size: 0.66rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    padding: 0.5rem 0.85rem;
    clip-path: var(--shape);
    border-radius: 0 12px 0 12px;
    transition: transform var(--quick), border-color var(--quick), box-shadow var(--quick), color var(--quick);
  }
  .filter-btn:hover,
  .filter-btn.is-active {
    border-color: rgba(227,28,141,0.72);
    box-shadow: 0 0 0 1px rgba(227,28,141,0.26), 0 8px 18px rgba(0,0,0,0.58);
    transform: translateY(-2px);
    color: #ffe7f5;
  }

  .masonry-grid { columns: 3; column-gap: 0.75rem; padding: 0 var(--page-x); }
  .masonry-grid .session-card { break-inside: avoid; margin-bottom: 0.75rem; }

  .session-card {
    display: block;
    border: 1px solid rgba(255,255,255,0.15);
    background: linear-gradient(160deg, rgba(29,36,27,0.94), rgba(14,19,14,0.94));
    clip-path: var(--shape);
    border-radius: 0 16px 0 16px;
    overflow: hidden;
    box-shadow: 0 6px 17px rgba(0,0,0,0.45);
    transition: transform var(--flow), border-color var(--flow), box-shadow var(--flow);
  }
  .session-card:hover {
    transform: translateY(-3px);
    border-color: rgba(227,28,141,0.5);
    box-shadow: 0 16px 28px rgba(0,0,0,0.58);
  }

  .session-card__img img {
    width: 100%;
    display: block;
    filter: grayscale(0.55) sepia(0.2) contrast(1.12) brightness(0.66);
    transition: transform var(--flow), filter var(--flow);
  }
  .session-card:hover .session-card__img img { transform: scale(1.02); }

  .session-card__body {
    padding: 0.65rem 0.75rem 0.75rem;
    border-top: 1px solid rgba(255,255,255,0.12);
    display: grid;
    gap: 0.34rem;
    clip-path: var(--shape);
    border-radius: 0 12px 0 12px;
  }
  .session-card__title { font-size: clamp(0.9rem, 1.5vw, 1.08rem); line-height: 1.2; }

  .hero::after,
  .all-section::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.26) 1px, transparent 0);
    background-size: 3px 3px;
    mix-blend-mode: overlay;
    opacity: 0.18;
  }

  @media (max-width: 920px) {
    .hero { grid-template-columns: 1fr; }
    .hero__stats { grid-template-columns: 1fr; }
    .featured-card { grid-template-columns: 1fr; }
    .masonry-grid { columns: 2; }
  }

  @media (max-width: 640px) {
    .masonry-grid { columns: 1; }
    .filter-bar { justify-content: center; }
  }

  @keyframes vhs-glitch {
    0% { opacity: 0; transform: translateX(-100%); }
    16% { opacity: 0.9; transform: translateX(-25%); }
    45% { opacity: 0.62; transform: translateX(14%); }
    100% { opacity: 0; transform: translateX(100%); }
  }

  :global([data-theme="dark"]) {
    --bg: #0c120b;
    --text: #f7f8f7;
    --text-muted: rgba(247, 248, 247, 0.68);
    --border: rgba(255,255,255,0.16);
    --accent: #E31C8D;
    --wall-img: radial-gradient(circle at 18% 12%, rgba(227,28,141,0.16), transparent 28%), radial-gradient(circle at 76% 8%, rgba(123,144,111,0.2), transparent 30%), linear-gradient(160deg, #151b14 0%, #0d130c 100%);
  }

  :global([data-theme="light"]) .hero__slide,
  :global([data-theme="light"]) .featured-card__img img,
  :global([data-theme="light"]) .session-card__img img { filter: none; }

  :global([data-theme="light"]) .hero__slideshow-wrap,
  :global([data-theme="light"]) .hero__slideshow,
  :global([data-theme="light"]) .hero__content,
  :global([data-theme="light"]) .hero__stats,
  :global([data-theme="light"]) .hero__stats-item,
  :global([data-theme="light"]) .featured-card,
  :global([data-theme="light"]) .featured-card__img,
  :global([data-theme="light"]) .featured-card__img img,
  :global([data-theme="light"]) .session-card,
  :global([data-theme="light"]) .session-card__body,
  :global([data-theme="light"]) .filter-btn,
  :global([data-theme="light"]) .featured-card__cat,
  :global([data-theme="light"]) .session-card__cat {
    clip-path: none;
    border-radius: 8px;
  }

  :global([data-theme="light"]) .hero::after,
  :global([data-theme="light"]) .all-section::after,
  :global([data-theme="light"]) .hero::before { display: none; }
</style>

<script>
  // ── Scroll hint ──
  const scrollHint = document.querySelector('.scroll-hint') as HTMLElement;
  if (scrollHint) {
    window.addEventListener('scroll', () => {
      scrollHint.classList.toggle('scroll-hint--hidden', window.scrollY > 80);
    }, { passive: true });
  }

  // ── Slideshow ──
  const slides = document.querySelectorAll<HTMLElement>('.hero__slide');
  const glitchLayer = document.querySelector<HTMLElement>('.hero__vhs-glitch');
  let current = 0;
  if (slides.length > 1) {
    setInterval(() => {
      glitchLayer?.classList.remove('is-glitch');
      void glitchLayer?.offsetWidth;
      glitchLayer?.classList.add('is-glitch');
      slides[current].classList.remove('is-active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('is-active');
    }, 4600);
  }

  // ── Filter ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.session-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const cat = btn.dataset.cat;
      cards.forEach(card => {
        const match = cat === 'all' || card.dataset.cat === cat;
        card.style.display = match ? 'block' : 'none';
      });
    });
  });
</script>
