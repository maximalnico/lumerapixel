---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const sorted = [...allSessions].sort((a, b) => parseDMY(b.date) - parseDMY(a.date));
const totalPhotos = allSessions.reduce((s: number, ses: any) => s + (ses.images || 0), 0);
const categories = [...new Set(allSessions.map((s: any) => s.category))];

const featured = allSessions.filter((s: any) => s.featured).length >= 1
  ? allSessions.filter((s: any) => s.featured).slice(0, 3)
  : sorted.slice(0, 3);

const slideshowSessions = [...allSessions]
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);

// Lang helpers
const st = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const ss = (s: any) => isEN ? (s.subtitle_en || s.subtitle_de) : (s.subtitle_de || s.subtitle_en);
const sc = (s: any) => isEN ? (s.category_en || s.category) : (s.category_de || s.category);
const sessionPath = (slug: string) => isEN ? `/en/sessions/${slug}` : `/sessions/${slug}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

// SEO
const siteUrl = 'https://lumerapixel.com';
const canonicalUrl = isEN ? `${siteUrl}/en/` : `${siteUrl}/`;
const pageTitle = isEN
  ? 'LumeraPixel – Photography by MaximalNico | Lost Places · Automotive · Aerial'
  : 'LumeraPixel – Fotografie von MaximalNico | Lost Places · Automotive · Aerial';
const pageDesc = isEN
  ? `Photography portfolio by Nico Henkel from Bavaria. ${allSessions.length} sessions with ${totalPhotos.toLocaleString('en-US')} photos covering Lost Places, Automotive and Aerial Photography.`
  : `Fotografieportfolio von Nico Henkel aus Bayern. ${allSessions.length} Sessions mit ${totalPhotos.toLocaleString('de-DE')} Fotos aus den Kategorien Lost Places, Automotive und Aerial Photography.`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "LumeraPixel",
      "description": "Photography portfolio by Nico Henkel – Lost Places, Automotive & Aerial Photography from Bavaria.",
      "inLanguage": isEN ? "en" : "de-DE",
      "author": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Nico Thomas Henkel",
      "alternateName": "MaximalNico",
      "url": siteUrl,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Blumenstraße 26",
        "addressLocality": "Neuching",
        "postalCode": "85467",
        "addressCountry": "DE"
      },
      "knowsAbout": ["Photography", "Lost Places", "Automotive Photography", "Aerial Photography", "Drone", "Fujifilm"],
      "sameAs": [`${siteUrl}`]
    },
    {
      "@type": "ImageGallery",
      "@id": `${siteUrl}/#gallery`,
      "name": "LumeraPixel Photo Gallery",
      "description": pageDesc,
      "url": siteUrl,
      "numberOfItems": allSessions.length,
      "author": { "@id": `${siteUrl}/#person` }
    }
  ]
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={`${siteUrl}/logos/lplong.svg`}
  canonical={canonicalUrl}
  {schema}
  hreflangDe={`${siteUrl}/`}
  hreflangEn={`${siteUrl}/en/`}
>
  <Nav />

  <main>

    <!-- ══ HERO ══ -->
    <section class="hero" aria-label="Hero">

      <!-- Slideshow Box links -->
      <div class="hero__slideshow-wrap">
        <div class="hero__slideshow" id="slideshow">
          {slideshowSessions.map((s: any, i: number) => {
            const cover = s.folder + '/000.webp';
            return (
              <img
                src={cover}
                alt=""
                class={`hero__slide ${i === 0 ? 'is-active' : ''}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            );
          })}
        </div>
      </div>

      <!-- Text rechts -->
      <div class="hero__content">
        <img src="/logos/lplong-rainbow.svg" alt="LumeraPixel" class="hero__logo" />
        <p class="hero__tagline">{t(lang, 'hero.tagline')}</p>

        <!-- Stats inline rechts -->
        <div class="hero__stats">
          <div class="hero__stats-item">
            <span class="hero__stats-num">{allSessions.length}</span>
            <span class="hero__stats-label">{t(lang, 'stats.sessions')}</span>
          </div>
          <div class="hero__stats-sep" aria-hidden="true"></div>
          <div class="hero__stats-item">
            <span class="hero__stats-num">{totalPhotos.toLocaleString('de-DE')}</span>
            <span class="hero__stats-label">{t(lang, 'stats.photos')}</span>
          </div>
          <div class="hero__stats-sep" aria-hidden="true"></div>
          <div class="hero__stats-item">
            <span class="hero__stats-num">{categories.length}</span>
            <span class="hero__stats-label">{t(lang, 'stats.categories')}</span>
          </div>
        </div>

        <!-- Scroll hint -->
        <a href="#featured" class="scroll-hint" aria-label={t(lang, 'hero.tagline')}>
          <svg class="scroll-hint__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true">
            <defs>
              <linearGradient id="arrowGrad" x1="0" y1="128" x2="256" y2="128" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#ff0040"/>
                <stop offset="16.6%" stop-color="#ff8000"/>
                <stop offset="33.3%" stop-color="#ffcc00"/>
                <stop offset="50%" stop-color="#00e85a"/>
                <stop offset="66.6%" stop-color="#0090ff"/>
                <stop offset="83.3%" stop-color="#8c3fff"/>
                <stop offset="100%" stop-color="#ff2eaa"/>
              </linearGradient>
            </defs>
            <rect width="256" height="256" fill="none"/>
            <polyline points="208 96 128 176 48 96" fill="none" stroke="url(#arrowGrad)" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/>
          </svg>
        </a>
      </div>

    </section>

    <!-- ══ FEATURED SESSIONS ══ -->
    <section class="featured-section" id="featured" aria-label="Featured Sessions">
      <div class="featured-section__head">
        <div class="featured-section__line" aria-hidden="true"></div>
        <h2 class="featured-section__title">{t(lang, 'section.highlights')}</h2>
        <div class="featured-section__line" aria-hidden="true"></div>
      </div>

      <div class="featured-grid">
        {featured.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          const [d, m, y] = s.date.split('.');
          const dateStr = new Date(+y, +m - 1, +d).toLocaleDateString(dateLocale, { month: 'long', year: 'numeric' });
          return (
            <a href={sessionPath(s.slug)} class="featured-card">
              <div class="featured-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
                <div class="featured-card__img-overlay"></div>
              </div>
              <div class="featured-card__body">
                <span class="featured-card__cat">{sc(s)}</span>
                <h3 class="featured-card__title">{st(s)}</h3>
                <span class="featured-card__date">{dateStr}</span>
              </div>
              <div class="featured-card__arrow" aria-hidden="true">
                <img src="/logos/phosphoricons/caret-right-thin.svg" alt="" class="featured-card__arrow-img featured-card__arrow-img--default" />
                <svg class="featured-card__arrow-img featured-card__arrow-img--rainbow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true"><defs><linearGradient id="rg-fc" x1="0" y1="128" x2="256" y2="128" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#ff0040"/><stop offset="33%" stop-color="#ffcc00"/><stop offset="66%" stop-color="#0090ff"/><stop offset="100%" stop-color="#ff2eaa"/></linearGradient></defs><rect width="256" height="256" fill="none"/><polyline points="96 48 176 128 96 208" fill="none" stroke="url(#rg-fc)" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/></svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- ══ ALLE SESSIONS + FILTER + MASONRY ══ -->
    <section class="all-section" id="sessions" aria-label="Alle Sessions">

      <!-- Filter -->
      <div class="filter-bar reveal" id="filterBar">
        <button class="filter-btn is-active" data-cat="all">{t(lang, 'filter.all')}</button>
        {categories.map((cat: string) => (
          <button class="filter-btn" data-cat={cat}>{cat}</button>
        ))}
      </div>

      <div class="rg-line reveal" style="margin: 0 var(--page-x) var(--gap-md);"></div>

      <!-- Masonry Grid -->
      <div class="masonry-grid" id="masonryGrid">
        {sorted.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          return (
            <a href={sessionPath(s.slug)} class="session-card reveal" data-cat={s.category}>
              <div class="session-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
              </div>
              <div class="session-card__body glass">
                <h3 class="session-card__title">{st(s)}</h3>
                <span class="session-card__cat">{sc(s)}</span>
              </div>
            </a>
          );
        })}
      </div>

    </section>

  </main>

  <!-- Footer -->
  <Footer />

</Base>

<style>
  /* ══ GLOBAL BG ══ */


  /* ══ HERO ══ */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
  }

  /* ══ HERO — Slideshow links, Text+Stats rechts ══ */
  .hero {
    min-height: calc(100svh - var(--nav-h));
    padding: calc(var(--nav-h) + var(--gap-sm) + var(--gap-sm)) var(--page-x) var(--gap-lg);
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: var(--gap-lg);
    align-items: center;
    position: relative;
  }
  @media (max-width: 768px) {
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: var(--nav-h) var(--page-x) 0.3rem;
      gap: 0.27rem;
      min-height: 100svh;
    }
    .hero__slideshow {
      width: 88%;
      margin: 0 auto;
      aspect-ratio: 4/3;
      border-width: 4px;
      border-radius: 12px;
    }
    .hero__content { gap: 0.27rem; margin-top: 2.7rem; align-items: center; text-align: center;}
    .hero__logo { height: clamp(1.4rem, 5.5vw, 1.9rem); }
    .hero__tagline {
      font-size: clamp(0.6rem, 2.5vw, 0.78rem);
      margin-bottom: 0;
      letter-spacing: 0.14em;
    }
    .hero__stats {
      display: flex;
      flex-direction: row !important;
      border-radius: 10px;
      border-width: 1.5px;
    }
    .hero__stats-item {
      flex: 1;
      padding: 0.3rem 0.2rem;
      gap: 0.06rem;
    }
    .hero__stats-sep {
      width: 1px;
      height: 50%;
      align-self: center;
      background: var(--border-mid);
    }
    .hero__stats-num { font-size: clamp(0.9rem, 3.8vw, 1.15rem); }
    .hero__stats-label { font-size: 0.52rem; letter-spacing: 0.08em; }
    .scroll-hint {
      position: static;
      transform: none;
      animation: bob-mobile 2.5s ease-in-out infinite;
      margin-top: 0.15rem;
    }
    .scroll-hint__arrow { width: 26px; height: 26px; }
  }
  @keyframes bob-mobile {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  /* Slideshow Box */
  .hero__slideshow-wrap {
    padding: 3px;
    background: var(--rainbow);
    border-radius: 19px;
    flex-shrink: 0;
  }
  .hero__slideshow {
    position: relative;
    aspect-ratio: 4/3;
    border-radius: 16px;
    overflow: hidden;
    background: var(--bg);
  }
  .hero__slide {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
    filter: brightness(0.88) contrast(1.04);
  }
  .hero__slide.is-active { opacity: 1; }

  /* Text rechts */
  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
  }
  .hero__logo {
    height: clamp(2.8rem, 6vw, 4.5rem);
    width: auto;
    opacity: 0.95;
  }
  .hero__tagline {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(1.1rem, 2.4vw, 1.7rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--gap-sm);
  }

  /* Stats unter Text rechts */
  .hero__stats {
    display: flex;
    flex-direction: column;
    background: rgba(0,0,0,0.27);
    backdrop-filter: blur(27px);
    -webkit-backdrop-filter: blur(27px);
    border-radius: 14px;
    border: 2.7px solid rgba(0,0,0,0.37);
    box-shadow: 0 8px 32px 0 rgba(31,38,135,0.27);
    width: 100%;
  }
  .hero__stats-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(0.6rem, 1.4vw, 1rem) clamp(0.8rem, 2vw, 1.5rem);
    gap: 0.2rem;
  }
  .hero__stats-sep {
    height: 1px;
    width: 60%;
    background: var(--border-mid);
    align-self: center;
  }
  .hero__stats-num {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1;
    color: var(--text-muted);
  }
  .hero__stats-label {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(0.72rem, 0.95vw, 0.85rem);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: var(--gap-md);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    animation: bob 2.5s ease-in-out infinite;
    transition: opacity 0.4s ease;
    text-decoration: none;
  }
  .scroll-hint:hover { opacity: 0.7; }
  .scroll-hint__arrow { width: 52px; height: 52px; opacity: 0.85; }
  .scroll-hint--hidden { opacity: 0 !important; pointer-events: none; }
  @keyframes bob {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50%      { transform: translateX(-50%) translateY(6px); }
  }

  /* ══ FEATURED ══ */
  .featured-section {
    padding: var(--gap-lg) var(--page-x) var(--gap-md);
  }
  .featured-section__head {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--gap-md);
    margin-bottom: var(--gap-lg);
  }
  .featured-section__line {
    height: 1px;
    background: var(--rainbow);
  }
  .featured-section__title {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(1.2rem, 2.4vw, 2rem);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text);
    white-space: nowrap;
    text-align: center;
  }

  /* Featured Grid — 3 Karten */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-sm);
  }
  @media (max-width: 768px) { 
    .featured-grid { 
      display: flex;
      flex-direction: row;
      text-align: center;
    } 
    .featured-card {
      border-radius: 10px;
    }
    .featured-card__img {
      max-height: unset;
      aspect-ratio: 16/10;
      display: none;
    }
    .featured-card__img-overlay { display: none; }
    .featured-card__body {
      padding: 0.55rem 0.8rem 0.65rem;
      border-top: 1px solid var(--border);
      align-items: center;
      text-align: center;
    }
    .featured-card__cat {
      font-size: 0.7rem !important;
      font-weight: 277 !important;
      align-self: center !important;
      background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18)) !important;
      -webkit-background-clip: initial !important;
      background-clip: initial !important;
      -webkit-text-fill-color: initial !important;
    }
    .featured-card__title {
      font-size: 1rem !important;
      letter-spacing: normal !important;
      font-weight: 420 !important;
      color: var(--text) !important;
    }
    .featured-card__date { display: none; }
    .featured-card__arrow { display: none !important; }
  }

  .featured-card {
    display: flex;
    flex-direction: row-reverse;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    background: var(--bg-card);
    transition: transform var(--flow);
    text-decoration: none;
  }
  .featured-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 14px;
    padding: 1.5px;
    background: var(--rainbow);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 2;
  }
  .featured-card:hover {
    transform: translateY(-4px);
  }


  .featured-card__img {
    position: relative;
    aspect-ratio: 16/10;
    max-height: 50vh;
    overflow: hidden;
  }
  .featured-card__img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform var(--flow);
    filter: brightness(1) contrast(1.02) saturate(1);
  }
  .featured-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,15,0.85) 0%, transparent 50%);
  }

  .featured-card__body {
    padding: var(--gap-sm) var(--gap-md) var(--gap-sm);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }
  .featured-card__cat {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: inline-block;
    align-self: flex-start;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--text-muted);
    color: var(--text);
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
  }
  .featured-card__title {
    font-family: 'Switzer', sans-serif;
    font-weight: 420;
    font-size: clamp(1.2rem, 2.2vw, 1.7rem);
    letter-spacing: normal;
    line-height: 1.15;
    color: var(--text);
  }
  .featured-card__date {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: 1.00rem;
    letter-spacing: 0.07em;
    color: var(--text-muted);
  }
  .featured-card__arrow {
    position: absolute;
    bottom: var(--gap-sm);
    left: var(--gap-md);
    transition: transform var(--quick);
    display: flex;
  }
  .featured-card__arrow-img {
    width: 26px;
    height: 26px;
    display: block;
    filter: invert(1);
    opacity: 0.5;
  }
  .featured-card__arrow-img--rainbow { display: none; filter: none; opacity: 1; }
  :global([data-theme="light"]) .featured-card__arrow-img--default { filter: invert(0); }
  .featured-card:hover .featured-card__arrow { transform: translateX(4px); }
  .featured-card:hover .featured-card__arrow-img--default { display: none; }
  .featured-card:hover .featured-card__arrow-img--rainbow { display: block; }

  /* ══ ALL SESSIONS ══ */
  .all-section {
    padding: var(--gap-md) 0 var(--gap-xl);
    border-top: 1px solid var(--border);
  }


  /* Filter */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0 var(--page-x);
    margin-bottom: var(--gap-sm);
  }
  .filter-btn {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(0.78rem, 1vw, 0.9rem);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding: 0.55rem 1.4rem;
    border-radius: 999px;
    border: 1.5px solid var(--text-muted);
    color: var(--text);
    cursor: pointer;
    background: transparent;
  }
  .filter-btn:hover,
  .filter-btn.is-active {
    border-color: var(--text);
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
  }

  /* Masonry — CSS Columns */
  .masonry-grid {
    columns: 4;
    column-gap: 0.6rem;
    padding: 0 var(--page-x);
  }
  .masonry-grid .session-card {
    break-inside: avoid;
    margin-bottom: 0.6rem;
    display: block;
  }
  @media (max-width: 1100px) { .masonry-grid { columns: 3; } }
  @media (max-width: 700px)  { 
    .masonry-grid { 
      columns: 2; 
    } 
    .session-card__img img {
      height: auto;
      aspect-ratio: 16/10;
      object-fit: cover;
    }
  }
  @media (max-width: 440px) { 
    .masonry-grid { 
      columns: 2; 
    } 
    .session-card__img img {
