---
import Base from '../../layouts/Base.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const sorted = [...allSessions].sort((a, b) => parseDMY(b.date) - parseDMY(a.date));
const headerSession = sorted[0];
const headerImage = headerSession ? `${headerSession.folder}/000.webp` : '';
const totalPhotos = allSessions.reduce((s: number, ses: any) => s + (ses.images || 0), 0);
const categories = [...new Set(allSessions.map((s: any) => s.category))];

const featured = allSessions.filter((s: any) => s.featured).length >= 1
  ? allSessions.filter((s: any) => s.featured).slice(0, 3)
  : sorted.slice(0, 3);

const slideshowSessions = [...allSessions]
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);

// Lang helpers
const st = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const ss = (s: any) => isEN ? (s.subtitle_en || s.subtitle_de) : (s.subtitle_de || s.subtitle_en);
const sc = (s: any) => isEN ? (s.category_en || s.category) : (s.category_de || s.category);
const sessionPath = (slug: string) => isEN ? `/en/sessions/${slug}` : `/sessions/${slug}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

// SEO
const siteUrl = 'https://lumerapixel.com';
const canonicalUrl = isEN ? `${siteUrl}/en/` : `${siteUrl}/`;
const pageTitle = isEN
  ? 'LumeraPixel – Photography by MaximalNico | Lost Places · Automotive · Aerial'
  : 'LumeraPixel – Fotografie von MaximalNico | Lost Places · Automotive · Aerial';
const pageDesc = isEN
  ? `Photography portfolio by Nico Henkel from Bavaria. ${allSessions.length} sessions with ${totalPhotos.toLocaleString('en-US')} photos covering Lost Places, Automotive and Aerial Photography.`
  : `Fotografieportfolio von Nico Henkel aus Bayern. ${allSessions.length} Sessions mit ${totalPhotos.toLocaleString('de-DE')} Fotos aus den Kategorien Lost Places, Automotive und Aerial Photography.`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "LumeraPixel",
      "description": "Photography portfolio by Nico Henkel – Lost Places, Automotive & Aerial Photography from Bavaria.",
      "inLanguage": isEN ? "en" : "de-DE",
      "author": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Nico Thomas Henkel",
      "alternateName": "MaximalNico",
      "url": siteUrl,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Blumenstraße 26",
        "addressLocality": "Neuching",
        "postalCode": "85467",
        "addressCountry": "DE"
      },
      "knowsAbout": ["Photography", "Lost Places", "Automotive Photography", "Aerial Photography", "Drone", "Fujifilm"],
      "sameAs": [`${siteUrl}`]
    },
    {
      "@type": "ImageGallery",
      "@id": `${siteUrl}/#gallery`,
      "name": "LumeraPixel Photo Gallery",
      "description": pageDesc,
      "url": siteUrl,
      "numberOfItems": allSessions.length,
      "author": { "@id": `${siteUrl}/#person` }
    }
  ]
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={`${siteUrl}/logos/lplong.svg`}
  canonical={canonicalUrl}
  {schema}
  hreflangDe={`${siteUrl}/`}
  hreflangEn={`${siteUrl}/en/`}
>
  <main>
    <section class="masonry-home">
      <header class="masonry-home__topbar">
        <a href={isEN ? '/en/' : '/'} class="masonry-home__brand">
          <img src="/logos/lplong-rainbow.svg" alt="LumeraPixel" />
        </a>
        <nav class="masonry-home__menu" aria-label="Main Navigation">
          <a href="#">{t(lang, 'nav.home')}</a>
          <a href="#">{t(lang, 'section.highlights')}</a>
          <a href="#">{t(lang, 'nav.contact')}</a>
          <a href="#">{t(lang, 'nav.legal')}</a>
          <a href="#">{t(lang, 'nav.privacy')}</a>
        </nav>
        <a class="masonry-home__cta" href="#">{isEN ? 'View Work' : 'Galerie'}</a>
      </header>

      <section class="fullscreen-header" aria-label="Header">
        {headerImage && <img class="fullscreen-header__image" src={headerImage} alt={st(headerSession)} loading="eager" decoding="async" />}
        <div class="fullscreen-header__overlay">
          <img src="/logos/lplong-rainbow.svg" alt="LumeraPixel" class="fullscreen-header__logo" />
          <p class="fullscreen-header__sub">{t(lang, 'hero.tagline')}</p>
        </div>
      </section>

      <div class="masonry-home__grid">
        {sorted.map((s: any, i: number) => {
          const cover = `${s.folder}/000.webp`;
          return (
            <a href={sessionPath(s.slug)} class="masonry-card">
              <img src={cover} alt={st(s)} loading={i < 4 ? 'eager' : 'lazy'} decoding="async" />
              <span class="masonry-card__overlay">
                <span class="masonry-card__pill masonry-card__pill--cat">{sc(s)}</span>
                <span class="masonry-card__pill masonry-card__pill--title">{st(s)}</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>

  </main>

  <!-- Footer -->
  <Footer />

</Base>

<style>
  main {
    background: #0f1118;
    min-height: 100svh;
    color: #f6f6f6;
    --masonry-gap: 7px;
  }

  .masonry-home__topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--masonry-gap);
    padding: var(--masonry-gap);
    background: rgba(11, 13, 20, 0.95);
    border-bottom: 1px solid rgba(255,255,255,0.12);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .masonry-home__brand img {
    width: clamp(160px, 22vw, 260px);
    height: auto;
  }

  .masonry-home__menu {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--masonry-gap);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: clamp(0.58rem, 0.9vw, 0.72rem);
  }
  .masonry-home__menu a { color: rgba(255,255,255,0.86); }
  .masonry-home__menu a::after { content: '•'; margin-left: var(--masonry-gap); color: #f7be1f; }
  .masonry-home__menu a:last-child::after { display: none; }

  .masonry-home__cta {
    border: 1px solid rgba(255,255,255,0.28);
    color: #fff;
    padding: 0.62rem 1.1rem;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    transition: background 220ms ease;
  }
  .masonry-home__cta:hover { background: rgba(255,255,255,0.08); }

  .fullscreen-header {
    position: relative;
    height: 100svh;
    min-height: 100svh;
    overflow: hidden;
    margin: 0;
    background: #090b12;
  }

  .fullscreen-header__image {
    width: 100%;
    height: 100svh;
    min-height: 100svh;
    object-fit: cover;
    filter: contrast(1.04) saturate(1.03);
  }

  .fullscreen-header__overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    align-content: center;
    text-align: center;
    gap: 1rem;
    background:
      linear-gradient(90deg, rgba(227, 28, 141, 0.34) 0%, rgba(227, 28, 141, 0.0) 22%, rgba(227, 28, 141, 0.0) 78%, rgba(227, 28, 141, 0.34) 100%);
    padding: 1.2rem;
  }

  .fullscreen-header__logo {
    width: clamp(240px, 40vw, 620px);
    height: auto;
  }

  .fullscreen-header__sub {
    font-size: clamp(0.82rem, 1.2vw, 1.08rem);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.82);
  }

  .masonry-home__grid {
    columns: 4;
    column-gap: var(--masonry-gap);
    padding: var(--masonry-gap);
    background: #0f1118;
  }

  .masonry-card {
    position: relative;
    overflow: hidden;
    display: block;
    background: #111;
    break-inside: avoid;
    margin-bottom: var(--masonry-gap);
  }
  .masonry-card img {
    width: 100%;
    height: auto;
    object-fit: cover;
    transition: filter 320ms ease;
  }

  .masonry-card__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    padding: 0.8rem;
  }

  .masonry-card__pill {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    max-width: min(92%, 30rem);
    backdrop-filter: blur(14px) saturate(1.05);
    -webkit-backdrop-filter: blur(14px) saturate(1.05);
    border: 1px solid rgba(255,255,255,0.34);
    background: linear-gradient(165deg, rgba(9,12,20,0.66), rgba(9,12,20,0.38));
    border-radius: 14px 0 14px 0;
    opacity: 0;
    transition: opacity 280ms ease, transform 280ms ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .masonry-card__pill--cat {
    top: 0.75rem;
    padding: 0.42rem 0.72rem;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #E31C8D;
    max-width: max-content;
  }

  .masonry-card__pill--title {
    bottom: 0.75rem;
    padding: 0.58rem 0.86rem;
    font-size: clamp(0.76rem, 1vw, 0.92rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
  }

  .masonry-card:hover img {
    filter: brightness(0.82) contrast(1.05);
  }
  .masonry-card:hover .masonry-card__pill--cat,
  .masonry-card:hover .masonry-card__pill--title {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 1100px) {
    .masonry-home__topbar {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: var(--masonry-gap);
    }
    .masonry-home__menu { flex-wrap: wrap; }
    .fullscreen-header,
    .fullscreen-header__image {
      min-height: 100svh;
      height: 100svh;
    }
    .masonry-home__grid { columns: 3; }
  }

  @media (max-width: 700px) {
    .masonry-home__grid { columns: 2; }
  }

  @media (max-width: 480px) {
    .masonry-home__grid { columns: 1; }
    .masonry-home__cta { width: 100%; text-align: center; }
  }

  :global([data-theme="light"]) main,
  :global([data-theme="dark"]) main {
    background: #0f1118;
    color: #f6f6f6;
  }
</style>

<script>
  // Simple CSS-columns masonry, no custom sorting or JS layout logic.
</script>
