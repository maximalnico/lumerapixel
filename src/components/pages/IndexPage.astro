---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const sorted = [...allSessions].sort((a, b) => parseDMY(b.date) - parseDMY(a.date));
const totalPhotos = allSessions.reduce((s: number, ses: any) => s + (ses.images || 0), 0);
const categories = [...new Set(allSessions.map((s: any) => s.category))];

const featured = allSessions.filter((s: any) => s.featured).length >= 1
  ? allSessions.filter((s: any) => s.featured).slice(0, 3)
  : sorted.slice(0, 3);

const slideshowSessions = [...allSessions]
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);

// Lang helpers
const st = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const ss = (s: any) => isEN ? (s.subtitle_en || s.subtitle_de) : (s.subtitle_de || s.subtitle_en);
const sc = (s: any) => isEN ? (s.category_en || s.category) : (s.category_de || s.category);
const sessionPath = (slug: string) => isEN ? `/en/sessions/${slug}` : `/sessions/${slug}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

// SEO
const siteUrl = 'https://lumerapixel.com';
const canonicalUrl = isEN ? `${siteUrl}/en/` : `${siteUrl}/`;
const pageTitle = isEN
  ? 'LumeraPixel – Photography by MaximalNico | Lost Places · Automotive · Aerial'
  : 'LumeraPixel – Fotografie von MaximalNico | Lost Places · Automotive · Aerial';
const pageDesc = isEN
  ? `Photography portfolio by Nico Henkel from Bavaria. ${allSessions.length} sessions with ${totalPhotos.toLocaleString('en-US')} photos covering Lost Places, Automotive and Aerial Photography.`
  : `Fotografieportfolio von Nico Henkel aus Bayern. ${allSessions.length} Sessions mit ${totalPhotos.toLocaleString('de-DE')} Fotos aus den Kategorien Lost Places, Automotive und Aerial Photography.`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "LumeraPixel",
      "description": "Photography portfolio by Nico Henkel – Lost Places, Automotive & Aerial Photography from Bavaria.",
      "inLanguage": isEN ? "en" : "de-DE",
      "author": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Nico Thomas Henkel",
      "alternateName": "MaximalNico",
      "url": siteUrl,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Blumenstraße 26",
        "addressLocality": "Neuching",
        "postalCode": "85467",
        "addressCountry": "DE"
      },
      "knowsAbout": ["Photography", "Lost Places", "Automotive Photography", "Aerial Photography", "Drone", "Fujifilm"],
      "sameAs": [`${siteUrl}`]
    },
    {
      "@type": "ImageGallery",
      "@id": `${siteUrl}/#gallery`,
      "name": "LumeraPixel Photo Gallery",
      "description": pageDesc,
      "url": siteUrl,
      "numberOfItems": allSessions.length,
      "author": { "@id": `${siteUrl}/#person` }
    }
  ]
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={`${siteUrl}/logos/lplong.svg`}
  canonical={canonicalUrl}
  {schema}
  hreflangDe={`${siteUrl}/`}
  hreflangEn={`${siteUrl}/en/`}
>
  <Nav />

  <main>

    <!-- ══ HERO ══ -->
    <section class="hero" aria-label="Hero">

      <!-- Slideshow Box links -->
      <div class="hero__slideshow-wrap">
        <div class="hero__slideshow" id="slideshow">
          <div class="hero__vhs-glitch" aria-hidden="true"></div>
          {slideshowSessions.map((s: any, i: number) => {
            const cover = s.folder + '/000.webp';
            return (
              <img
                src={cover}
                alt=""
                class={`hero__slide ${i === 0 ? 'is-active' : ''}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            );
          })}
        </div>
      </div>

      <!-- Text rechts -->
      <div class="hero__content">
        <img src="/logos/lplong.svg" alt="LumeraPixel" class="hero__logo" />
        <p class="hero__tagline">{t(lang, 'hero.tagline')}</p>

        <!-- Stats inline rechts -->
        <div class="hero__stats">
          <div class="hero__stats-item">
            <span class="hero__stats-num">{allSessions.length}</span>
            <span class="hero__stats-label">{t(lang, 'stats.sessions')}</span>
          </div>
          <div class="hero__stats-sep" aria-hidden="true"></div>
          <div class="hero__stats-item">
            <span class="hero__stats-num">{totalPhotos.toLocaleString('de-DE')}</span>
            <span class="hero__stats-label">{t(lang, 'stats.photos')}</span>
          </div>
          <div class="hero__stats-sep" aria-hidden="true"></div>
          <div class="hero__stats-item">
            <span class="hero__stats-num">{categories.length}</span>
            <span class="hero__stats-label">{t(lang, 'stats.categories')}</span>
          </div>
        </div>

        <!-- Scroll hint -->
        <a href="#featured" class="scroll-hint" aria-label={t(lang, 'hero.tagline')}>
          <svg class="scroll-hint__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true">
            <rect width="256" height="256" fill="none"/>
            <polyline points="208 96 128 176 48 96" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/>
          </svg>
        </a>
      </div>

    </section>

    <!-- ══ FEATURED SESSIONS ══ -->
    <section class="featured-section" id="featured" aria-label="Featured Sessions">
      <div class="featured-section__head">
        <div class="featured-section__line" aria-hidden="true"></div>
        <h2 class="featured-section__title">{t(lang, 'section.highlights')}</h2>
        <div class="featured-section__line" aria-hidden="true"></div>
      </div>

      <div class="featured-grid">
        {featured.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          const [d, m, y] = s.date.split('.');
          const dateStr = new Date(+y, +m - 1, +d).toLocaleDateString(dateLocale, { month: 'long', year: 'numeric' });
          return (
            <a href={sessionPath(s.slug)} class="featured-card">
              <div class="featured-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
                <div class="featured-card__img-overlay"></div>
              </div>
              <div class="featured-card__body">
                <span class="featured-card__cat">{sc(s)}</span>
                <h3 class="featured-card__title">{st(s)}</h3>
                <span class="featured-card__date">{dateStr}</span>
              </div>
              <div class="featured-card__arrow" aria-hidden="true">
                <svg class="featured-card__arrow-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true"><rect width="256" height="256" fill="none"/><polyline points="96 48 176 128 96 208" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/></svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- ══ ALLE SESSIONS + FILTER + MASONRY ══ -->
    <section class="all-section" id="sessions" aria-label="Alle Sessions">

      <!-- Filter -->
      <div class="filter-bar reveal" id="filterBar">
        <button class="filter-btn is-active" data-cat="all">{t(lang, 'filter.all')}</button>
        {categories.map((cat: string) => (
          <button class="filter-btn" data-cat={cat}>{cat}</button>
        ))}
      </div>

      <div class="rg-line reveal" style="margin: 0 var(--page-x) var(--gap-md);"></div>

      <!-- Masonry Grid -->
      <div class="masonry-grid" id="masonryGrid">
        {sorted.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          return (
            <a href={sessionPath(s.slug)} class="session-card reveal" data-cat={s.category}>
              <div class="session-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
              </div>
              <div class="session-card__body glass">
                <h3 class="session-card__title">{st(s)}</h3>
                <span class="session-card__cat">{sc(s)}</span>
              </div>
            </a>
          );
        })}
      </div>

    </section>

  </main>

  <!-- Footer -->
  <Footer />

</Base>

<style>
  .hero,
  .featured-section,
  .all-section,
  .filter-bar,
  .masonry-grid,
  .featured-grid {
    position: relative;
    z-index: 1;
  }

  .hero {
    min-height: calc(100svh - var(--nav-h));
    padding: calc(var(--nav-h) + var(--gap-md)) var(--page-x) var(--gap-lg);
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: var(--gap-md);
    align-items: center;
  }

  .hero__slideshow-wrap {
    padding: 1px;
    border-radius: 2px;
    background: linear-gradient(135deg, rgba(255,255,255,0.35), rgba(255,255,255,0.04));
    clip-path: polygon(0 4%, 6% 0, 100% 0, 100% 96%, 95% 100%, 0 100%);
  }

  .hero__slideshow {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    border-radius: 2px;
    background: #000;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.9s ease;
    filter: grayscale(1) contrast(1.2) brightness(0.55);
  }
  .hero__slide.is-active { opacity: 1; }

  .hero__vhs-glitch {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    mix-blend-mode: screen;
    background:
      repeating-linear-gradient(to bottom, rgba(255,255,255,0.09) 0 2px, transparent 2px 4px),
      linear-gradient(90deg, transparent 0 24%, rgba(227,28,141,0.35) 24% 34%, transparent 34% 100%);
    transform: translateX(-100%);
  }

  .hero__vhs-glitch.is-glitch {
    animation: vhs-glitch 360ms steps(4, end) 1;
  }

  .hero__content { display: grid; gap: 1rem; justify-items: center; text-align: center; }
  .hero__logo { height: clamp(2.2rem, 5vw, 3.8rem); filter: grayscale(1) brightness(1.6); opacity: 0.9; }
  .hero__tagline {
    font-size: clamp(0.95rem, 1.8vw, 1.25rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .hero__stats {
    width: min(420px, 100%);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.18);
    clip-path: polygon(0 6%, 5% 0, 100% 0, 100% 94%, 94% 100%, 0 100%);
  }
  .hero__stats-item { background: rgba(0,0,0,0.82); padding: 0.8rem 0.6rem; }
  .hero__stats-sep { display: none; }
  .hero__stats-num { display: block; font-size: clamp(1.2rem, 2.5vw, 1.8rem); font-weight: 650; color: #fff; }
  .hero__stats-label { font-size: 0.72rem; letter-spacing: 0.17em; text-transform: uppercase; color: rgba(255,255,255,0.7); }

  .scroll-hint { color: rgba(255,255,255,0.8); position: absolute; bottom: 1.2rem; left: 50%; transform: translateX(-50%); }
  .scroll-hint__arrow { width: 2rem; height: 2rem; }

  .featured-section { padding: var(--gap-md) var(--page-x); }
  .featured-section__head { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.2rem; }
  .featured-section__line { flex: 1; height: 1px; background: rgba(255,255,255,0.25); }
  .featured-section__title { font-size: clamp(1rem, 2vw, 1.5rem); letter-spacing: 0.2em; text-transform: uppercase; }

  .featured-grid { display: grid; grid-template-columns: 1fr; gap: 0.8rem; }
  .featured-card {
    position: relative;
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(0,0,0,0.74);
    clip-path: polygon(0 2%, 3% 0, 100% 0, 100% 97%, 97% 100%, 0 100%);
    transition: transform var(--flow), border-color var(--flow);
  }
  .featured-card:hover { transform: translateY(-4px) scale(1.01); border-color: rgba(227,28,141,0.55); }
  .featured-card__img { min-height: 220px; }
  .featured-card__img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.2) brightness(0.52); }
  .featured-card__img-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, transparent 20%, rgba(0,0,0,0.9)); }
  .featured-card__body { position: relative; z-index: 1; padding: 1rem; display: grid; align-content: center; gap: 0.45rem; }
  .featured-card__cat,
  .session-card__cat {
    justify-self: start;
    padding: 0.22rem 0.7rem;
    border: 1px solid rgba(255,255,255,0.34);
    color: #fff;
    font-size: 0.67rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    clip-path: polygon(0 16%, 8% 0, 100% 0, 100% 82%, 92% 100%, 0 100%);
  }
  .featured-card__title { font-size: clamp(1.05rem, 2.2vw, 1.55rem); line-height: 1.1; }
  .featured-card__date { color: rgba(255,255,255,0.65); letter-spacing: 0.08em; font-size: 0.8rem; }
  .featured-card__arrow { position: absolute; right: 0.9rem; bottom: 0.9rem; color: #E31C8D; }
  .featured-card__arrow-img { width: 1.5rem; }

  .all-section { padding: var(--gap-md) 0 var(--gap-xl); border-top: 1px solid rgba(255,255,255,0.12); }
  .filter-bar { display: flex; flex-wrap: wrap; gap: 0.55rem; padding: 0 var(--page-x); margin-bottom: 1rem; }
  .filter-btn {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    background: rgba(0,0,0,0.8);
    border: 1px solid rgba(255,255,255,0.24);
    padding: 0.55rem 1rem;
    clip-path: polygon(0 18%, 10% 0, 100% 0, 100% 82%, 90% 100%, 0 100%);
    transition: transform var(--quick), border-color var(--quick), background var(--quick);
  }
  .filter-btn:hover,
  .filter-btn.is-active { border-color: #E31C8D; color: #fff; background: rgba(227,28,141,0.16); transform: translateY(-1px); }

  .masonry-grid { columns: 3; column-gap: 0.8rem; padding: 0 var(--page-x); }
  .masonry-grid .session-card { break-inside: avoid; margin-bottom: 0.8rem; }

  .session-card {
    display: block;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(0,0,0,0.7);
    overflow: hidden;
    clip-path: polygon(0 2.5%, 3% 0, 100% 0, 100% 97%, 97% 100%, 0 100%);
    transition: transform var(--flow), border-color var(--flow);
  }
  .session-card:hover { transform: translateY(-3px); border-color: rgba(227,28,141,0.46); }
  .session-card__img img { width: 100%; height: auto; display: block; filter: grayscale(1) contrast(1.16) brightness(0.58); transition: filter var(--flow); }
  .session-card:hover .session-card__img img { filter: grayscale(0.95) contrast(1.2) brightness(0.7); }
  .session-card__body { padding: 0.7rem 0.8rem 0.9rem; border-top: 1px solid rgba(255,255,255,0.14); display: grid; gap: 0.35rem; }
  .session-card__title { font-size: clamp(0.95rem, 1.6vw, 1.15rem); }

  @media (max-width: 920px) {
    .hero { grid-template-columns: 1fr; padding-top: calc(var(--nav-h) + var(--gap-sm)); }
    .masonry-grid { columns: 2; }
    .featured-card { grid-template-columns: 1fr; }
    .featured-card__img { min-height: 190px; }
  }
  @media (max-width: 640px) {
    .hero__stats { grid-template-columns: 1fr; }
    .masonry-grid { columns: 1; }
    .filter-bar { justify-content: center; }
  }

  @keyframes vhs-glitch {
    0% { opacity: 0; transform: translateX(-100%); }
    10% { opacity: 0.95; transform: translateX(-20%); }
    30% { opacity: 0.6; transform: translateX(10%); }
    60% { opacity: 0.9; transform: translateX(100%); }
    100% { opacity: 0; transform: translateX(100%); }
  }

  :global([data-theme="dark"]) {
    --bg: #050505;
    --bg-card: rgba(255,255,255,0.03);
    --border: rgba(255,255,255,0.12);
    --text: #f3f3f3;
    --text-muted: rgba(255,255,255,0.66);
    --accent: #E31C8D;
    --wall-img: radial-gradient(circle at 15% 20%, rgba(227,28,141,0.08), transparent 35%), radial-gradient(circle at 80% 0%, rgba(255,255,255,0.06), transparent 35%);
  }

  :global([data-theme="light"]) .hero__slide,
  :global([data-theme="light"]) .featured-card__img img,
  :global([data-theme="light"]) .session-card__img img { filter: none; }

  :global([data-theme="light"]) .filter-btn,
  :global([data-theme="light"]) .session-card,
  :global([data-theme="light"]) .featured-card {
    clip-path: none;
  }
</style>

<script>
  // ── Scroll hint ──
  const scrollHint = document.querySelector('.scroll-hint') as HTMLElement;
  if (scrollHint) {
    window.addEventListener('scroll', () => {
      scrollHint.classList.toggle('scroll-hint--hidden', window.scrollY > 80);
    }, { passive: true });
  }

  // ── Slideshow ──
  const slides = document.querySelectorAll<HTMLElement>('.hero__slide');
  const glitchLayer = document.querySelector<HTMLElement>('.hero__vhs-glitch');
  let current = 0;
  if (slides.length > 1) {
    setInterval(() => {
      glitchLayer?.classList.remove('is-glitch');
      void glitchLayer?.offsetWidth;
      glitchLayer?.classList.add('is-glitch');
      slides[current].classList.remove('is-active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('is-active');
    }, 4600);
  }

  // ── Filter ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.session-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const cat = btn.dataset.cat;
      cards.forEach(card => {
        const match = cat === 'all' || card.dataset.cat === cat;
        card.style.display = match ? 'block' : 'none';
      });
    });
  });
</script>
