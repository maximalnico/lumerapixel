---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const sorted = [...allSessions].sort((a, b) => parseDMY(b.date) - parseDMY(a.date));
const totalPhotos = allSessions.reduce((s: number, ses: any) => s + (ses.images || 0), 0);
const categories = [...new Set(allSessions.map((s: any) => s.category))];

const featured = allSessions.filter((s: any) => s.featured).length >= 1
  ? allSessions.filter((s: any) => s.featured).slice(0, 3)
  : sorted.slice(0, 3);

const slideshowSessions = [...allSessions]
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);

// Lang helpers
const st = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const ss = (s: any) => isEN ? (s.subtitle_en || s.subtitle_de) : (s.subtitle_de || s.subtitle_en);
const sc = (s: any) => isEN ? (s.category_en || s.category) : (s.category_de || s.category);
const sessionPath = (slug: string) => isEN ? `/en/sessions/${slug}` : `/sessions/${slug}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

// SEO
const siteUrl = 'https://lumerapixel.com';
const canonicalUrl = isEN ? `${siteUrl}/en/` : `${siteUrl}/`;
const pageTitle = isEN
  ? 'LumeraPixel – Photography by MaximalNico | Lost Places · Automotive · Aerial'
  : 'LumeraPixel – Fotografie von MaximalNico | Lost Places · Automotive · Aerial';
const pageDesc = isEN
  ? `Photography portfolio by Nico Henkel from Bavaria. ${allSessions.length} sessions with ${totalPhotos.toLocaleString('en-US')} photos covering Lost Places, Automotive and Aerial Photography.`
  : `Fotografieportfolio von Nico Henkel aus Bayern. ${allSessions.length} Sessions mit ${totalPhotos.toLocaleString('de-DE')} Fotos aus den Kategorien Lost Places, Automotive und Aerial Photography.`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "LumeraPixel",
      "description": "Photography portfolio by Nico Henkel – Lost Places, Automotive & Aerial Photography from Bavaria.",
      "inLanguage": isEN ? "en" : "de-DE",
      "author": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Nico Thomas Henkel",
      "alternateName": "MaximalNico",
      "url": siteUrl,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Blumenstraße 26",
        "addressLocality": "Neuching",
        "postalCode": "85467",
        "addressCountry": "DE"
      },
      "knowsAbout": ["Photography", "Lost Places", "Automotive Photography", "Aerial Photography", "Drone", "Fujifilm"],
      "sameAs": [`${siteUrl}`]
    },
    {
      "@type": "ImageGallery",
      "@id": `${siteUrl}/#gallery`,
      "name": "LumeraPixel Photo Gallery",
      "description": pageDesc,
      "url": siteUrl,
      "numberOfItems": allSessions.length,
      "author": { "@id": `${siteUrl}/#person` }
    }
  ]
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={`${siteUrl}/logos/lplong.svg`}
  canonical={canonicalUrl}
  {schema}
  hreflangDe={`${siteUrl}/`}
  hreflangEn={`${siteUrl}/en/`}
>
  <Nav />

  <main>

    <!-- ══ HERO ══ -->
    <section class="hero" aria-label="Hero">

      <!-- Slideshow Box links -->
      <div class="hero__slideshow-wrap">
        <div class="hero__slideshow" id="slideshow">
          <div class="hero__vhs-glitch" aria-hidden="true"></div>
          {slideshowSessions.map((s: any, i: number) => {
            const cover = s.folder + '/000.webp';
            return (
              <img
                src={cover}
                alt=""
                class={`hero__slide ${i === 0 ? 'is-active' : ''}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            );
          })}
        </div>
      </div>

      <!-- Text rechts -->
      <div class="hero__content">
        <img src="/logos/lplong.svg" alt="LumeraPixel" class="hero__logo" />
        <p class="hero__tagline">{t(lang, 'hero.tagline')}</p>

        <!-- Stats inline rechts -->
        <div class="hero__stats">
          <div class="hero__stats-item">
            <span class="hero__stats-num">{allSessions.length}</span>
            <span class="hero__stats-label">{t(lang, 'stats.sessions')}</span>
          </div>
          <div class="hero__stats-sep" aria-hidden="true"></div>
          <div class="hero__stats-item">
            <span class="hero__stats-num">{totalPhotos.toLocaleString('de-DE')}</span>
            <span class="hero__stats-label">{t(lang, 'stats.photos')}</span>
          </div>
          <div class="hero__stats-sep" aria-hidden="true"></div>
          <div class="hero__stats-item">
            <span class="hero__stats-num">{categories.length}</span>
            <span class="hero__stats-label">{t(lang, 'stats.categories')}</span>
          </div>
        </div>

        <!-- Scroll hint -->
        <a href="#featured" class="scroll-hint" aria-label={t(lang, 'hero.tagline')}>
          <svg class="scroll-hint__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true">
            <rect width="256" height="256" fill="none"/>
            <polyline points="208 96 128 176 48 96" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/>
          </svg>
        </a>
      </div>

    </section>

    <!-- ══ FEATURED SESSIONS ══ -->
    <section class="featured-section" id="featured" aria-label="Featured Sessions">
      <div class="featured-section__head">
        <div class="featured-section__line" aria-hidden="true"></div>
        <h2 class="featured-section__title">{t(lang, 'section.highlights')}</h2>
        <div class="featured-section__line" aria-hidden="true"></div>
      </div>

      <div class="featured-grid">
        {featured.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          const [d, m, y] = s.date.split('.');
          const dateStr = new Date(+y, +m - 1, +d).toLocaleDateString(dateLocale, { month: 'long', year: 'numeric' });
          return (
            <a href={sessionPath(s.slug)} class="featured-card">
              <div class="featured-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
                <div class="featured-card__img-overlay"></div>
              </div>
              <div class="featured-card__body">
                <span class="featured-card__cat">{sc(s)}</span>
                <h3 class="featured-card__title">{st(s)}</h3>
                <span class="featured-card__date">{dateStr}</span>
              </div>
              <div class="featured-card__arrow" aria-hidden="true">
                <svg class="featured-card__arrow-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true"><rect width="256" height="256" fill="none"/><polyline points="96 48 176 128 96 208" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/></svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- ══ ALLE SESSIONS + FILTER + MASONRY ══ -->
    <section class="all-section" id="sessions" aria-label="Alle Sessions">

      <!-- Filter -->
      <div class="filter-bar reveal" id="filterBar">
        <button class="filter-btn is-active" data-cat="all">{t(lang, 'filter.all')}</button>
        {categories.map((cat: string) => (
          <button class="filter-btn" data-cat={cat}>{cat}</button>
        ))}
      </div>

      <div class="rg-line reveal" style="margin: 0 var(--page-x) var(--gap-md);"></div>

      <!-- Masonry Grid -->
      <div class="masonry-grid" id="masonryGrid">
        {sorted.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          return (
            <a href={sessionPath(s.slug)} class="session-card reveal" data-cat={s.category}>
              <div class="session-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
              </div>
              <div class="session-card__body glass">
                <h3 class="session-card__title">{st(s)}</h3>
                <span class="session-card__cat">{sc(s)}</span>
              </div>
            </a>
          );
        })}
      </div>

    </section>

  </main>

  <!-- Footer -->
  <Footer />

</Base>

<style>
  main {
    position: relative;
    isolation: isolate;
    --eye-cut: 14px;
    --eye-shape: polygon(var(--eye-cut) 0, 100% 0, 100% calc(100% - var(--eye-cut)), calc(100% - var(--eye-cut)) 100%, 0 100%, 0 var(--eye-cut));
  }

  .hero,
  .featured-section,
  .all-section { position: relative; }

  .hero {
    min-height: calc(100svh - var(--nav-h));
    padding: calc(var(--nav-h) + var(--gap-md)) var(--page-x) var(--gap-lg);
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.8fr);
    gap: clamp(1rem, 3vw, 2.4rem);
    align-items: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 12% 35%, rgba(227, 28, 141, 0.13), transparent 25%),
      radial-gradient(circle at 85% 8%, rgba(255, 255, 255, 0.08), transparent 32%);
    mix-blend-mode: screen;
    z-index: -1;
  }

  .hero__slideshow-wrap {
    padding: 1px;
    background: linear-gradient(140deg, rgba(255,255,255,0.34), rgba(255,255,255,0.06));
    clip-path: var(--eye-shape);
    border-radius: 0 20px 0 20px;
    box-shadow: 0 18px 50px rgba(0,0,0,0.7);
  }

  .hero__slideshow {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #020202;
    clip-path: var(--eye-shape);
    border-radius: 0 18px 0 18px;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 700ms cubic-bezier(0.2, 0.7, 0, 1);
    filter: grayscale(1) brightness(0.44) contrast(1.35) saturate(0.6);
  }
  .hero__slide.is-active { opacity: 1; }

  .hero__vhs-glitch {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background:
      repeating-linear-gradient(to bottom, rgba(255,255,255,0.10) 0 2px, transparent 2px 4px),
      linear-gradient(90deg, transparent 0 22%, rgba(227,28,141,0.44) 22% 33%, transparent 33% 100%),
      linear-gradient(0deg, transparent 0 60%, rgba(255,255,255,0.17) 60% 64%, transparent 64% 100%);
    mix-blend-mode: screen;
    transform: translateX(-100%);
  }
  .hero__vhs-glitch.is-glitch { animation: vhs-glitch 390ms steps(5, end) 1; }

  .hero__content {
    display: grid;
    gap: 1rem;
    justify-items: center;
    text-align: center;
    padding: clamp(0.8rem, 2vw, 1.2rem);
    background: rgba(0,0,0,0.72);
    border: 1px solid rgba(255,255,255,0.2);
    clip-path: var(--eye-shape);
    border-radius: 0 20px 0 20px;
    box-shadow: 0 14px 34px rgba(0,0,0,0.62);
  }

  .hero__logo {
    height: clamp(2.1rem, 4vw, 3.4rem);
    filter: grayscale(1) brightness(1.8);
    opacity: 0.95;
  }

  .hero__tagline {
    font-size: clamp(0.82rem, 1.5vw, 1.05rem);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.78);
  }

  .hero__stats {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    padding: 1px;
    background: linear-gradient(125deg, rgba(255,255,255,0.32), rgba(255,255,255,0.08));
    clip-path: var(--eye-shape);
    border-radius: 0 14px 0 14px;
  }
  .hero__stats-item {
    background: rgba(0,0,0,0.88);
    padding: clamp(0.55rem, 1.2vw, 0.75rem);
    display: grid;
    gap: 0.2rem;
    clip-path: var(--eye-shape);
    border-radius: 0 12px 0 12px;
  }
  .hero__stats-sep { display: none; }
  .hero__stats-num { font-size: clamp(1.1rem, 2.2vw, 1.7rem); font-weight: 680; line-height: 1; }
  .hero__stats-label { font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.66); }

  .scroll-hint {
    position: absolute;
    left: 50%;
    bottom: 0.8rem;
    transform: translateX(-50%);
    color: #E31C8D;
    opacity: 0.72;
  }

  .featured-section { padding: var(--gap-md) var(--page-x); }
  .featured-section__head {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.7rem;
    align-items: center;
    margin-bottom: 1.2rem;
  }
  .featured-section__line { height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent); }
  .featured-section__title { text-transform: uppercase; letter-spacing: 0.22em; font-size: clamp(0.95rem, 1.9vw, 1.35rem); }

  .featured-grid { display: grid; grid-template-columns: 1fr; gap: 0.9rem; }
  .featured-card {
    position: relative;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    border: 1px solid rgba(255,255,255,0.2);
    background: linear-gradient(130deg, rgba(8,8,8,0.94), rgba(2,2,2,0.9));
    overflow: hidden;
    clip-path: var(--eye-shape);
    border-radius: 0 20px 0 20px;
    transition: transform var(--flow), box-shadow var(--flow), border-color var(--flow);
    box-shadow: 0 8px 26px rgba(0,0,0,0.44);
  }
  .featured-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 44px rgba(0,0,0,0.7);
    border-color: rgba(227,28,141,0.55);
  }

  .featured-card__img { min-height: 240px; }
  .featured-card__img,
  .featured-card__img img { clip-path: var(--eye-shape); border-radius: 0 18px 0 18px; }
  .featured-card__img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.32) brightness(0.46); }
  .featured-card__img-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, transparent 24%, rgba(0,0,0,0.93) 74%); }
  .featured-card__body { position: relative; z-index: 1; display: grid; align-content: center; gap: 0.5rem; padding: 1rem 1rem 1.2rem; }

  .featured-card__cat,
  .session-card__cat {
    font-size: 0.64rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    width: fit-content;
    color: #f8f8f8;
    padding: 0.24rem 0.72rem;
    border: 1px solid rgba(255,255,255,0.34);
    clip-path: var(--eye-shape);
    border-radius: 0 12px 0 12px;
    background: rgba(0,0,0,0.8);
  }

  .featured-card__title { font-size: clamp(1.04rem, 2.1vw, 1.5rem); line-height: 1.08; }
  .featured-card__date { color: rgba(255,255,255,0.66); font-size: 0.78rem; letter-spacing: 0.08em; }
  .featured-card__arrow { position: absolute; right: 0.8rem; bottom: 0.8rem; color: #E31C8D; }

  .all-section {
    padding: var(--gap-md) 0 var(--gap-xl);
    border-top: 1px solid rgba(255,255,255,0.14);
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding: 0 var(--page-x);
    margin-bottom: 1rem;
  }

  .filter-btn {
    position: relative;
    border: 1px solid rgba(255,255,255,0.28);
    background: linear-gradient(170deg, rgba(0,0,0,0.85), rgba(16,16,16,0.85));
    color: rgba(255,255,255,0.84);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.58rem 1rem;
    clip-path: var(--eye-shape);
    border-radius: 0 16px 0 16px;
    transition: transform var(--quick), border-color var(--quick), box-shadow var(--quick), background var(--quick);
    box-shadow: 0 2px 7px rgba(0,0,0,0.45);
  }
  .filter-btn:hover,
  .filter-btn.is-active {
    transform: translateY(-2px);
    border-color: rgba(227,28,141,0.75);
    box-shadow: 0 0 0 1px rgba(227,28,141,0.3), 0 8px 20px rgba(0,0,0,0.6);
    background: linear-gradient(170deg, rgba(26,0,14,0.96), rgba(12,12,12,0.9));
    color: #fff;
  }

  .masonry-grid { columns: 3; column-gap: 0.8rem; padding: 0 var(--page-x); }
  .masonry-grid .session-card { break-inside: avoid; margin-bottom: 0.8rem; }

  .session-card {
    display: block;
    border: 1px solid rgba(255,255,255,0.17);
    background: linear-gradient(160deg, rgba(10,10,10,0.94), rgba(1,1,1,0.92));
    overflow: hidden;
    clip-path: var(--eye-shape);
    border-radius: 0 18px 0 18px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.42);
    transition: transform var(--flow), box-shadow var(--flow), border-color var(--flow);
  }
  .session-card:hover {
    transform: translateY(-4px);
    border-color: rgba(227,28,141,0.52);
    box-shadow: 0 16px 28px rgba(0,0,0,0.66);
  }

  .session-card__img img {
    width: 100%;
    display: block;
    filter: grayscale(1) brightness(0.5) contrast(1.3);
    transition: filter var(--flow), transform var(--flow);
  }
  .session-card:hover .session-card__img img {
    filter: grayscale(1) brightness(0.58) contrast(1.34);
    transform: scale(1.02);
  }

  .session-card__body {
    padding: 0.72rem 0.82rem 0.86rem;
    border-top: 1px solid rgba(255,255,255,0.15);
    display: grid;
    gap: 0.38rem;
    clip-path: var(--eye-shape);
    border-radius: 0 14px 0 14px;
  }

  .session-card__title { font-size: clamp(0.92rem, 1.6vw, 1.1rem); line-height: 1.2; }

  .all-section::after,
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.22;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.36) 1px, transparent 0);
    background-size: 3px 3px;
    mix-blend-mode: overlay;
  }

  @media (max-width: 940px) {
    .hero { grid-template-columns: 1fr; }
    .featured-card { grid-template-columns: 1fr; }
    .featured-card__img { min-height: 200px; }
    .masonry-grid { columns: 2; }
  }

  @media (max-width: 640px) {
    .hero__stats { grid-template-columns: 1fr; }
    .masonry-grid { columns: 1; }
    .filter-bar { justify-content: center; }
  }

  @keyframes vhs-glitch {
    0% { opacity: 0; transform: translateX(-100%); }
    14% { opacity: 0.95; transform: translateX(-30%); }
    37% { opacity: 0.6; transform: translateX(0); }
    64% { opacity: 0.8; transform: translateX(40%); }
    100% { opacity: 0; transform: translateX(100%); }
  }

  :global([data-theme="dark"]) {
    --bg: #030303;
    --text: #f4f4f4;
    --text-muted: rgba(255,255,255,0.66);
    --accent: #E31C8D;
    --wall-img: radial-gradient(circle at 20% 10%, rgba(227,28,141,0.09), transparent 30%), radial-gradient(circle at 70% 30%, rgba(255,255,255,0.08), transparent 28%), linear-gradient(160deg, #050505 0%, #020202 100%);
  }

  :global([data-theme="light"]) .hero__slide,
  :global([data-theme="light"]) .featured-card__img img,
  :global([data-theme="light"]) .session-card__img img { filter: none; }

  :global([data-theme="light"]) .hero__content,
  :global([data-theme="light"]) .featured-card,
  :global([data-theme="light"]) .session-card,
  :global([data-theme="light"]) .filter-btn,
  :global([data-theme="light"]) .hero__stats,
  :global([data-theme="light"]) .hero__slideshow-wrap { clip-path: none; }

  :global([data-theme="light"]) .hero::after,
  :global([data-theme="light"]) .all-section::after { display: none; }
</style>

<script>
  // ── Scroll hint ──
  const scrollHint = document.querySelector('.scroll-hint') as HTMLElement;
  if (scrollHint) {
    window.addEventListener('scroll', () => {
      scrollHint.classList.toggle('scroll-hint--hidden', window.scrollY > 80);
    }, { passive: true });
  }

  // ── Slideshow ──
  const slides = document.querySelectorAll<HTMLElement>('.hero__slide');
  const glitchLayer = document.querySelector<HTMLElement>('.hero__vhs-glitch');
  let current = 0;
  if (slides.length > 1) {
    setInterval(() => {
      glitchLayer?.classList.remove('is-glitch');
      void glitchLayer?.offsetWidth;
      glitchLayer?.classList.add('is-glitch');
      slides[current].classList.remove('is-active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('is-active');
    }, 4600);
  }

  // ── Filter ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.session-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const cat = btn.dataset.cat;
      cards.forEach(card => {
        const match = cat === 'all' || card.dataset.cat === cat;
        card.style.display = match ? 'block' : 'none';
      });
    });
  });
</script>
