---
import Base from '../../layouts/Base.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const sorted = [...allSessions].sort((a, b) => parseDMY(b.date) - parseDMY(a.date));
const totalPhotos = allSessions.reduce((s: number, ses: any) => s + (ses.images || 0), 0);
const categories = [...new Set(allSessions.map((s: any) => s.category))];

const featured = allSessions.filter((s: any) => s.featured).length >= 1
  ? allSessions.filter((s: any) => s.featured).slice(0, 3)
  : sorted.slice(0, 3);
const collage = sorted.slice(0, 8);

const slideshowSessions = [...allSessions]
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);

// Lang helpers
const st = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const ss = (s: any) => isEN ? (s.subtitle_en || s.subtitle_de) : (s.subtitle_de || s.subtitle_en);
const sc = (s: any) => isEN ? (s.category_en || s.category) : (s.category_de || s.category);
const sessionPath = (slug: string) => isEN ? `/en/sessions/${slug}` : `/sessions/${slug}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

// SEO
const siteUrl = 'https://lumerapixel.com';
const canonicalUrl = isEN ? `${siteUrl}/en/` : `${siteUrl}/`;
const pageTitle = isEN
  ? 'LumeraPixel – Photography by MaximalNico | Lost Places · Automotive · Aerial'
  : 'LumeraPixel – Fotografie von MaximalNico | Lost Places · Automotive · Aerial';
const pageDesc = isEN
  ? `Photography portfolio by Nico Henkel from Bavaria. ${allSessions.length} sessions with ${totalPhotos.toLocaleString('en-US')} photos covering Lost Places, Automotive and Aerial Photography.`
  : `Fotografieportfolio von Nico Henkel aus Bayern. ${allSessions.length} Sessions mit ${totalPhotos.toLocaleString('de-DE')} Fotos aus den Kategorien Lost Places, Automotive und Aerial Photography.`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "LumeraPixel",
      "description": "Photography portfolio by Nico Henkel – Lost Places, Automotive & Aerial Photography from Bavaria.",
      "inLanguage": isEN ? "en" : "de-DE",
      "author": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Nico Thomas Henkel",
      "alternateName": "MaximalNico",
      "url": siteUrl,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Blumenstraße 26",
        "addressLocality": "Neuching",
        "postalCode": "85467",
        "addressCountry": "DE"
      },
      "knowsAbout": ["Photography", "Lost Places", "Automotive Photography", "Aerial Photography", "Drone", "Fujifilm"],
      "sameAs": [`${siteUrl}`]
    },
    {
      "@type": "ImageGallery",
      "@id": `${siteUrl}/#gallery`,
      "name": "LumeraPixel Photo Gallery",
      "description": pageDesc,
      "url": siteUrl,
      "numberOfItems": allSessions.length,
      "author": { "@id": `${siteUrl}/#person` }
    }
  ]
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={`${siteUrl}/logos/lplong.svg`}
  canonical={canonicalUrl}
  {schema}
  hreflangDe={`${siteUrl}/`}
  hreflangEn={`${siteUrl}/en/`}
>
  <main>
    <section class="clean-home">
      <div class="clean-home__frame">
        <header class="clean-home__header">
          <h1 class="clean-home__brand">LUMERAPIXEL</h1>
          <nav class="clean-home__nav" aria-label="Main Navigation">
            <a href="#">{t(lang, 'nav.home')}</a>
            <a href="#">{t(lang, 'section.highlights')}</a>
            <a href="#">{t(lang, 'nav.contact')}</a>
            <a href="#">{t(lang, 'nav.legal')}</a>
            <a href="#">{t(lang, 'nav.privacy')}</a>
          </nav>
          <div class="clean-home__social">
            <span>𝕏</span><span>f</span><span>in</span><span>⟡</span>
          </div>
        </header>

        <div class="clean-home__grid">
          {collage.map((s: any, i: number) => {
            const cover = `${s.folder}/000.webp`;
            return (
              <a href={sessionPath(s.slug)} class={`clean-home__item clean-home__item--${i + 1}`}>
                <img src={cover} alt={st(s)} loading="lazy" decoding="async" />
              </a>
            );
          })}
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <Footer />

</Base>

<style>
  main {
    min-height: 100svh;
    background: #efefef;
    color: #141414;
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  .clean-home {
    max-width: 1200px;
    margin: 0 auto;
    background: #f5f5f5;
    border: 1px solid #dbdbdb;
    border-radius: 4px;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .clean-home__frame {
    border: 1px solid #e1e1e1;
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 3.2vw, 2.4rem);
    background: #fff;
  }

  .clean-home__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
    margin-bottom: clamp(1.8rem, 4vw, 3rem);
  }

  .clean-home__brand {
    font-size: clamp(2rem, 5vw, 3.3rem);
    letter-spacing: 0.08em;
    font-weight: 650;
  }

  .clean-home__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.17em;
    color: #888;
  }
  .clean-home__nav a { color: inherit; }

  .clean-home__social {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: #666;
  }

  .clean-home__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: clamp(110px, 14vw, 180px);
    gap: 4px;
  }

  .clean-home__item { display: block; overflow: hidden; }
  .clean-home__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 320ms ease;
  }
  .clean-home__item:hover img { transform: scale(1.04); }

  .clean-home__item--1 { grid-column: 1; grid-row: span 3; }
  .clean-home__item--2 { grid-column: 2; grid-row: span 1; }
  .clean-home__item--3 { grid-column: 3; grid-row: span 1; }
  .clean-home__item--4 { grid-column: 2; grid-row: span 2; }
  .clean-home__item--5 { grid-column: 3; grid-row: span 1; }
  .clean-home__item--6 { grid-column: 3; grid-row: span 1; }
  .clean-home__item--7 { grid-column: 1; grid-row: span 1; }
  .clean-home__item--8 { grid-column: 2 / span 2; grid-row: span 1; }

  @media (max-width: 880px) {
    .clean-home__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 170px;
    }
    .clean-home__item,
    .clean-home__item--1,
    .clean-home__item--2,
    .clean-home__item--3,
    .clean-home__item--4,
    .clean-home__item--5,
    .clean-home__item--6,
    .clean-home__item--7,
    .clean-home__item--8 {
      grid-column: auto;
      grid-row: auto;
    }
  }

  @media (max-width: 560px) {
    .clean-home__grid { grid-template-columns: 1fr; grid-auto-rows: 210px; }
    .clean-home__nav { gap: 0.5rem; font-size: 0.68rem; }
  }

  :global([data-theme="dark"]) main,
  :global([data-theme="light"]) main {
    background: #efefef;
    color: #141414;
  }
</style>

<script>
  // Demo homepage layout: no extra runtime behavior required.
</script>
