---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import sessionsData from '/public/data/sessions.json';
import { t, type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const parseDMY = (d: string) => {
  const [day, month, year] = d.split('.');
  return new Date(+year, +month - 1, +day).getTime();
};

const allSessions: any[] = Array.isArray(sessionsData)
  ? sessionsData
  : (sessionsData as any).sessions ?? Object.values(sessionsData);

const sorted = [...allSessions].sort((a, b) => parseDMY(b.date) - parseDMY(a.date));
const totalPhotos = allSessions.reduce((s: number, ses: any) => s + (ses.images || 0), 0);
const categories = [...new Set(allSessions.map((s: any) => s.category))];

const featured = allSessions.filter((s: any) => s.featured).length >= 1
  ? allSessions.filter((s: any) => s.featured).slice(0, 3)
  : sorted.slice(0, 3);

const slideshowSessions = [...allSessions]
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);

// Lang helpers
const st = (s: any) => isEN ? (s.title_en || s.title_de) : (s.title_de || s.title_en);
const ss = (s: any) => isEN ? (s.subtitle_en || s.subtitle_de) : (s.subtitle_de || s.subtitle_en);
const sc = (s: any) => isEN ? (s.category_en || s.category) : (s.category_de || s.category);
const sessionPath = (slug: string) => isEN ? `/en/sessions/${slug}` : `/sessions/${slug}`;
const dateLocale = isEN ? 'en-US' : 'de-DE';

// SEO
const siteUrl = 'https://lumerapixel.com';
const canonicalUrl = isEN ? `${siteUrl}/en/` : `${siteUrl}/`;
const pageTitle = isEN
  ? 'LumeraPixel – Photography by MaximalNico | Lost Places · Automotive · Aerial'
  : 'LumeraPixel – Fotografie von MaximalNico | Lost Places · Automotive · Aerial';
const pageDesc = isEN
  ? `Photography portfolio by Nico Henkel from Bavaria. ${allSessions.length} sessions with ${totalPhotos.toLocaleString('en-US')} photos covering Lost Places, Automotive and Aerial Photography.`
  : `Fotografieportfolio von Nico Henkel aus Bayern. ${allSessions.length} Sessions mit ${totalPhotos.toLocaleString('de-DE')} Fotos aus den Kategorien Lost Places, Automotive und Aerial Photography.`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "LumeraPixel",
      "description": "Photography portfolio by Nico Henkel – Lost Places, Automotive & Aerial Photography from Bavaria.",
      "inLanguage": isEN ? "en" : "de-DE",
      "author": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Nico Thomas Henkel",
      "alternateName": "MaximalNico",
      "url": siteUrl,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Blumenstraße 26",
        "addressLocality": "Neuching",
        "postalCode": "85467",
        "addressCountry": "DE"
      },
      "knowsAbout": ["Photography", "Lost Places", "Automotive Photography", "Aerial Photography", "Drone", "Fujifilm"],
      "sameAs": [`${siteUrl}`]
    },
    {
      "@type": "ImageGallery",
      "@id": `${siteUrl}/#gallery`,
      "name": "LumeraPixel Photo Gallery",
      "description": pageDesc,
      "url": siteUrl,
      "numberOfItems": allSessions.length,
      "author": { "@id": `${siteUrl}/#person` }
    }
  ]
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={`${siteUrl}/logos/lplong.svg`}
  canonical={canonicalUrl}
  {schema}
  hreflangDe={`${siteUrl}/`}
  hreflangEn={`${siteUrl}/en/`}
>
  <Nav />

  <main>

    <!-- ══ HERO ══ -->
    <section class="hero" aria-label="Hero">

      <!-- Slideshow Box links -->
      <div class="hero__slideshow-wrap">
        <div class="hero__slideshow" id="slideshow">
          <div class="hero__vhs-glitch" aria-hidden="true"></div>
          {slideshowSessions.map((s: any, i: number) => {
            const cover = s.folder + '/000.webp';
            return (
              <img
                src={cover}
                alt=""
                class={`hero__slide ${i === 0 ? 'is-active' : ''}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            );
          })}
        </div>
      </div>

      <!-- Text rechts -->
      <div class="hero__content">
        <img src="/logos/lplong.svg" alt="LumeraPixel" class="hero__logo" />
        <p class="hero__tagline">{t(lang, 'hero.tagline')}</p>

        <!-- Scroll hint -->
        <a href="#featured" class="scroll-hint" aria-label={t(lang, 'hero.tagline')}>
          <svg class="scroll-hint__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true">
            <rect width="256" height="256" fill="none"/>
            <polyline points="208 96 128 176 48 96" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/>
          </svg>
        </a>
      </div>

    </section>

    <!-- ══ FEATURED SESSIONS ══ -->
    <section class="featured-section" id="featured" aria-label="Featured Sessions">
      <div class="featured-section__head">
        <div class="featured-section__line" aria-hidden="true"></div>
        <h2 class="featured-section__title">{t(lang, 'section.highlights')}</h2>
        <div class="featured-section__line" aria-hidden="true"></div>
      </div>

      <div class="featured-grid">
        {featured.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          const [d, m, y] = s.date.split('.');
          const dateStr = new Date(+y, +m - 1, +d).toLocaleDateString(dateLocale, { month: 'long', year: 'numeric' });
          return (
            <a href={sessionPath(s.slug)} class="featured-card">
              <div class="featured-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
                <div class="featured-card__img-overlay"></div>
              </div>
              <div class="featured-card__body">
                <span class="featured-card__cat">{sc(s)}</span>
                <h3 class="featured-card__title">{st(s)}</h3>
                <span class="featured-card__date">{dateStr}</span>
              </div>
              <div class="featured-card__arrow" aria-hidden="true">
                <svg class="featured-card__arrow-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true"><rect width="256" height="256" fill="none"/><polyline points="96 48 176 128 96 208" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="8"/></svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- ══ ALLE SESSIONS + FILTER + MASONRY ══ -->
    <section class="all-section" id="sessions" aria-label="Alle Sessions">

      <!-- Filter -->
      <div class="filter-bar reveal" id="filterBar">
        <button class="filter-btn is-active" data-cat="all">{t(lang, 'filter.all')}</button>
        {categories.map((cat: string) => (
          <button class="filter-btn" data-cat={cat}>{cat}</button>
        ))}
      </div>

      <div class="rg-line reveal" style="margin: 0 var(--page-x) var(--gap-md);"></div>

      <!-- Masonry Grid -->
      <div class="masonry-grid" id="masonryGrid">
        {sorted.map((s: any) => {
          const folder = s.folder;
          const cover = `${folder}/000.webp`;
          return (
            <a href={sessionPath(s.slug)} class="session-card reveal" data-cat={s.category}>
              <div class="session-card__img">
                <img src={cover} alt={s.title} loading="lazy" decoding="async" />
              </div>
              <div class="session-card__body glass">
                <h3 class="session-card__title">{st(s)}</h3>
                <span class="session-card__cat">{sc(s)}</span>
              </div>
            </a>
          );
        })}
      </div>

    </section>

  </main>

  <!-- Footer -->
  <Footer />

</Base>

<style>
  main {
    position: relative;
    isolation: isolate;
    --accent: #E31C8D;
    --accent-soft: color-mix(in srgb, var(--accent) 22%, transparent);
    --panel: color-mix(in srgb, #111319 86%, #ffffff 14%);
    --panel-2: color-mix(in srgb, #0f1015 92%, #ffffff 8%);
    --surface-border: color-mix(in srgb, #fff 18%, transparent);
    --radius-lg: 26px;
    --radius-md: 18px;
    --radius-sm: 12px;
    --shadow-1: 0 12px 34px rgba(0, 0, 0, 0.35);
    --shadow-2: 0 20px 44px rgba(0, 0, 0, 0.52);
  }

  .hero,
  .featured-section,
  .all-section { position: relative; }

  .hero {
    min-height: 100svh;
    padding: calc(var(--nav-h) + 0.6rem) var(--page-x) 1.2rem;
    display: block;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 15% 10%, color-mix(in srgb, var(--accent) 20%, transparent), transparent 34%),
      radial-gradient(circle at 85% 0%, rgba(255,255,255,0.10), transparent 34%);
    opacity: 0.85;
  }

  .hero__slideshow-wrap {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-lg);
    padding: 0;
    background: transparent;
    box-shadow: none;
  }

  .hero__slideshow {
    position: relative;
    height: 100%;
    width: 100%;
    overflow: hidden;
    border-radius: 0;
    background: #07080c;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 600ms ease;
    filter: grayscale(0.26) contrast(1.08) brightness(0.64);
  }
  .hero__slide.is-active { opacity: 1; }

  .hero__vhs-glitch {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transform: translateX(-100%);
    mix-blend-mode: screen;
    background:
      repeating-linear-gradient(to bottom, rgba(255,255,255,0.08) 0 2px, transparent 2px 4px),
      linear-gradient(90deg, transparent 0 28%, color-mix(in srgb, var(--accent) 58%, transparent) 28% 36%, transparent 36% 100%);
  }
  .hero__vhs-glitch.is-glitch { animation: vhs-glitch 320ms steps(4, end) 1; }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: min(760px, 92vw);
    margin-inline: auto;
    margin-top: clamp(3.5rem, 10vh, 7rem);
    place-items: center;
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.2rem;
    padding: clamp(1.2rem, 3.2vw, 2.5rem);
    border: 1px solid color-mix(in srgb, #fff 34%, transparent);
    border-radius: var(--radius-md);
    background: linear-gradient(165deg, color-mix(in srgb, var(--panel) 95%, transparent), color-mix(in srgb, var(--panel-2) 95%, transparent));
    backdrop-filter: blur(18px) saturate(1.1);
    -webkit-backdrop-filter: blur(18px) saturate(1.1);
    box-shadow: var(--shadow-2);
  }

  .hero__logo { height: clamp(3.2rem, 8vw, 6.5rem); filter: brightness(1.85); }
  .hero__tagline { font-size: clamp(1rem, 2.2vw, 1.45rem); letter-spacing: 0.26em; text-transform: uppercase; color: var(--text-muted); }

  .hero__stats {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }
  .hero__stats-item {
    padding: clamp(0.8rem, 1.8vw, 1.1rem) 0.6rem;
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--panel-2) 92%, transparent);
  }
  .hero__stats-sep { display: none; }
  .hero__stats-num { display: block; font-weight: 700; font-size: clamp(1.2rem, 2.8vw, 2rem); line-height: 1; }
  .hero__stats-label { font-size: clamp(0.62rem, 0.9vw, 0.78rem); letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); }

  .scroll-hint { position: absolute; bottom: max(0.85rem, env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%); color: var(--accent); z-index: 3; }
  .scroll-hint__arrow { width: 1.8rem; height: 1.8rem; }

  .featured-section { padding: var(--gap-md) var(--page-x); }
  .featured-section__head {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.1rem;
  }
  .featured-section__line { height: 1px; background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--accent) 68%, #fff 32%), transparent); }
  .featured-section__title { font-size: clamp(0.95rem, 1.8vw, 1.34rem); letter-spacing: 0.22em; text-transform: uppercase; }

  .featured-grid { display: grid; grid-template-columns: 1fr; gap: 0.85rem; }

  .featured-card {
    position: relative;
    container-type: inline-size;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: linear-gradient(155deg, color-mix(in srgb, var(--panel) 96%, transparent), color-mix(in srgb, var(--panel-2) 95%, transparent));
    box-shadow: var(--shadow-1);
    transition: transform var(--flow), box-shadow var(--flow), border-color var(--flow);
  }
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-2);
    border-color: color-mix(in srgb, var(--accent) 55%, #fff 45%);
  }

  .featured-card__img { min-height: 240px; }
  .featured-card__img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.3) contrast(1.08) brightness(0.76); }
  .featured-card__img-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, transparent 26%, color-mix(in srgb, #0b0d12 85%, transparent) 76%); }
  .featured-card__body { padding: 1rem 1rem 1.1rem; display: grid; align-content: center; gap: 0.44rem; }

  .featured-card__cat,
  .session-card__cat {
    width: fit-content;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 58%, #fff 42%);
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: #ffd8ee;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.22rem 0.64rem;
  }

  .featured-card__title { font-size: clamp(1.02rem, 2vw, 1.45rem); line-height: 1.08; }
  .featured-card__date { font-size: 0.75rem; letter-spacing: 0.08em; color: var(--text-muted); }
  .featured-card__arrow { position: absolute; right: 0.74rem; bottom: 0.74rem; color: var(--accent); }

  .all-section { padding: var(--gap-md) 0 var(--gap-xl); border-top: 1px solid var(--surface-border); }

  .filter-bar { display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0 var(--page-x); margin-bottom: 1rem; }
  .filter-btn {
    border: 1px solid var(--surface-border);
    border-radius: 999px;
    padding: 0.5rem 0.9rem;
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: color-mix(in srgb, var(--panel-2) 92%, transparent);
    color: rgba(255,255,255,0.88);
    transition: transform var(--quick), border-color var(--quick), box-shadow var(--quick), background var(--quick);
  }
  .filter-btn:hover,
  .filter-btn.is-active {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 65%, #fff 35%);
    background: color-mix(in srgb, var(--accent) 18%, var(--panel-2));
    box-shadow: 0 8px 18px rgba(0,0,0,0.4);
  }

  .masonry-grid { columns: 3; column-gap: 0.75rem; padding: 0 var(--page-x); }
  .masonry-grid .session-card { break-inside: avoid; margin-bottom: 0.75rem; }

  .session-card {
    display: block;
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: linear-gradient(160deg, color-mix(in srgb, var(--panel) 95%, transparent), color-mix(in srgb, var(--panel-2) 96%, transparent));
    box-shadow: 0 8px 18px rgba(0,0,0,0.34);
    transition: transform var(--flow), border-color var(--flow), box-shadow var(--flow);
  }
  .session-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 52%, #fff 48%);
    box-shadow: 0 16px 28px rgba(0,0,0,0.45);
  }

  .session-card__img img {
    width: 100%;
    display: block;
    filter: grayscale(0.28) contrast(1.06) brightness(0.8);
    transition: transform var(--flow);
  }
  .session-card:hover .session-card__img img { transform: scale(1.02); }

  .session-card__body {
    padding: 0.68rem 0.78rem 0.82rem;
    border-top: 1px solid var(--surface-border);
    display: grid;
    gap: 0.34rem;
  }
  .session-card__title { font-size: clamp(0.92rem, 1.5vw, 1.08rem); line-height: 1.2; }

  @container (max-width: 620px) {
    .featured-card__body { padding: 0.8rem; }
    .featured-card__title { font-size: 1.06rem; }
  }

  @media (max-width: 940px) {
    .hero { padding-top: calc(var(--nav-h) + 0.4rem); }
    .hero__stats { grid-template-columns: 1fr; }
    .hero__content { margin-top: clamp(2.5rem, 10vh, 5rem); }
    .featured-card { grid-template-columns: 1fr; }
    .featured-card__img { min-height: 190px; }
    .masonry-grid { columns: 2; }
  }

  @media (max-width: 640px) {
    .masonry-grid { columns: 1; }
    .filter-bar { justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide,
    .featured-card,
    .session-card,
    .filter-btn { transition: none !important; }
    .hero__vhs-glitch { display: none; }
    .scroll-hint { animation: none !important; }
  }

  @keyframes vhs-glitch {
    0% { opacity: 0; transform: translateX(-100%); }
    18% { opacity: 0.95; transform: translateX(-24%); }
    50% { opacity: 0.64; transform: translateX(18%); }
    100% { opacity: 0; transform: translateX(100%); }
  }

  :global([data-theme="dark"]) {
    --bg: #090b10;
    --text: #f5f7ff;
    --text-muted: rgba(245,247,255,0.66);
    --border: rgba(255,255,255,0.15);
    --accent: #E31C8D;
    --wall-img: radial-gradient(circle at 18% 10%, rgba(227,28,141,0.14), transparent 32%), radial-gradient(circle at 85% 0, rgba(255,255,255,0.08), transparent 34%), linear-gradient(160deg, #111420 0%, #0a0c13 100%);
  }

  :global([data-theme="light"]) .hero__slide,
  :global([data-theme="light"]) .featured-card__img img,
  :global([data-theme="light"]) .session-card__img img { filter: none; }

  :global([data-theme="light"]) .hero::before,
  :global([data-theme="light"]) .hero__vhs-glitch,
  :global([data-theme="light"]) .scroll-hint { opacity: 0.5; }
</style>

<script>
  // ── Scroll hint ──
  const scrollHint = document.querySelector('.scroll-hint') as HTMLElement;
  if (scrollHint) {
    window.addEventListener('scroll', () => {
      scrollHint.classList.toggle('scroll-hint--hidden', window.scrollY > 80);
    }, { passive: true });
  }

  // ── Slideshow ──
  const slides = document.querySelectorAll<HTMLElement>('.hero__slide');
  const glitchLayer = document.querySelector<HTMLElement>('.hero__vhs-glitch');
  let current = 0;
  if (slides.length > 1) {
    setInterval(() => {
      glitchLayer?.classList.remove('is-glitch');
      void glitchLayer?.offsetWidth;
      glitchLayer?.classList.add('is-glitch');
      slides[current].classList.remove('is-active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('is-active');
    }, 4600);
  }

  // ── Filter ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.session-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const cat = btn.dataset.cat;
      cards.forEach(card => {
        const match = cat === 'all' || card.dataset.cat === cat;
        card.style.display = match ? 'block' : 'none';
      });
    });
  });
</script>
