---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const siteUrl = 'https://lumerapixel.com';
const deUrl = `${siteUrl}/impressum`;
const enUrl = `${siteUrl}/en/site-notice`;
---
<Base
  title={isEN ? 'Site Notice – LumeraPixel' : 'Impressum – LumeraPixel'}
  canonical={isEN ? enUrl : deUrl}
  description={isEN
    ? 'Site Notice for LumeraPixel – Photography portfolio by Nico Thomas Henkel from Neuching, Bavaria.'
    : 'Impressum von LumeraPixel – Fotografieportfolio von Nico Thomas Henkel aus Neuching, Bayern.'}
  hreflangDe={deUrl}
  hreflangEn={enUrl}
>
  <Nav />

  <main class="legal-page">
    <div class="legal-wrap">

      <div class="legal-header">
        <h1 class="legal-header__title">{isEN ? 'Site Notice' : 'Impressum'}</h1>
      </div>

      {isEN ? (
        <>
          <div class="legal-box">
            <span class="legal-box__label">Information according to § 5 TMG</span>
            <p>
              Nico Thomas Henkel<br />
              MultaEnhavo<br />
              Blumenstraße 26<br />
              85467 Neuching
            </p>
          </div>

          <div class="legal-box">
            <span class="legal-box__label">Contact</span>
            <p>
              Phone: <a href="tel:+4915122268995">+49-151-22268995</a><br />
              E-mail: <a href="mailto:nico@multaenhavo.com">nico@multaenhavo.com</a>
            </p>
          </div>

          <div class="legal-box">
            <span class="legal-box__label">VAT ID</span>
            <p>Sales tax identification number according to Sect. 27 a of the Sales Tax Law:</p>
            <p class="legal-box__id">DE459009808</p>
          </div>

          <div class="legal-box">
            <span class="legal-box__label">Dispute Resolution</span>
            <p>We are not willing or obliged to participate in dispute resolution proceedings in front of a consumer arbitration board.</p>
          </div>
        </>
      ) : (
        <>
          <div class="legal-box">
            <span class="legal-box__label">Angaben gemäß § 5 TMG</span>
            <p>
              Nico Thomas Henkel<br />
              MultaEnhavo<br />
              Blumenstraße 26<br />
              85467 Neuching
            </p>
          </div>

          <div class="legal-box">
            <span class="legal-box__label">Kontakt</span>
            <p>
              Telefon: <a href="tel:+4915122268995">+49-151-22268995</a><br />
              E-Mail: <a href="mailto:nico@multaenhavo.com">nico@multaenhavo.com</a>
            </p>
          </div>

          <div class="legal-box">
            <span class="legal-box__label">Umsatzsteuer-ID</span>
            <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:</p>
            <p class="legal-box__id">DE459009808</p>
          </div>

          <div class="legal-box">
            <span class="legal-box__label">Verbraucherstreit&shy;beilegung / Universal&shy;schlichtungs&shy;stelle</span>
            <p>Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>
          </div>
        </>
      )}

    </div>
  </main>

  <Footer />
</Base>

<style>
  .legal-page {
    background: #000;
    min-height: 100svh;
    color: #fff;
  }

  .legal-wrap {
    max-width: 64ch;
    margin: 0 auto;
    padding: calc(var(--nav-h) + clamp(3rem, 8vh, 6rem)) var(--page-x) var(--gap-xl);
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .legal-header {
    display: flex;
    justify-content: center;
    padding-bottom: clamp(1.5rem, 4vh, 3rem);
  }
  .legal-header__title {
    border: 2.7px solid #E31C8D;
    border-radius: 0 14px 0 14px;
    background: #000;
    padding: clamp(0.8rem, 1.8vw, 1.2rem) clamp(1.2rem, 3vw, 2.2rem);
    font-weight: 750;
    font-size: clamp(1.9rem, 5vw, 3.7rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-align: center;
    color: #fff;
  }

  .legal-box {
    border: 2.7px solid #404040;
    border-radius: 0 14px 0 14px;
    background: #000;
    padding: clamp(1rem, 2.5vw, 1.6rem) clamp(1.2rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    text-align: center;
    transition: border-color 180ms ease;
  }
  .legal-box:hover {
    border-color: #E31C8D;
  }

  .legal-box__label {
    border: 2.7px solid #404040;
    border-radius: 0 14px 0 14px;
    background: #000;
    padding: 0.42rem 0.78rem;
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: #fff;
    transition: border-color 180ms ease;
  }
  .legal-box:hover .legal-box__label {
    border-color: #E31C8D;
  }

  .legal-box p {
    color: #bfbfbf;
    line-height: 1.8;
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
  }

  .legal-box a {
    color: #bfbfbf;
    border-bottom: 2px solid #404040;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .legal-box a:hover {
    color: #fff;
    border-color: #E31C8D;
  }

  .legal-box__id {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: 550;
    letter-spacing: 0.08em;
    color: #fff !important;
  }

  :global([data-theme="light"]) .legal-page { background: #fff; color: #000; }
  :global([data-theme="light"]) .legal-header__title { background: #fff; color: #000; }
  :global([data-theme="light"]) .legal-box { background: #fff; }
  :global([data-theme="light"]) .legal-box__label { background: #fff; color: #000; }
  :global([data-theme="light"]) .legal-box p { color: #404040; }
  :global([data-theme="light"]) .legal-box a { color: #404040; }
  :global([data-theme="light"]) .legal-box a:hover { color: #000; }
  :global([data-theme="light"]) .legal-box__id { color: #000 !important; }
</style>
