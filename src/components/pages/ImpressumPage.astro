---
import Base from '../../layouts/Base.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { type Lang } from '../../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEN = lang === 'en';

const siteUrl = 'https://lumerapixel.com';
const deUrl = `${siteUrl}/impressum`;
const enUrl = `${siteUrl}/en/site-notice`;
---
<Base
  title={isEN ? 'Site Notice – LumeraPixel' : 'Impressum – LumeraPixel'}
  canonical={isEN ? enUrl : deUrl}
  description={isEN
    ? 'Site Notice for LumeraPixel – Photography portfolio by Nico Thomas Henkel from Neuching, Bavaria.'
    : 'Impressum von LumeraPixel – Fotografieportfolio von Nico Thomas Henkel aus Neuching, Bayern.'}
  hreflangDe={deUrl}
  hreflangEn={enUrl}
>
  <Nav />

  <main class="legal-page">
    <div class="legal-wrap">

      <div class="legal-header">
        <div class="legal-header__divider" aria-hidden="true"></div>
        <h1 class="legal-header__title">{isEN ? 'Site Notice' : 'Impressum'}</h1>
      </div>

      {isEN ? (
        <>
          <div class="glass-box">
            <h2 class="glass-box__title section-num">Information according to § 5 TMG</h2>
            <p>
              Nico Thomas Henkel<br />
              MultaEnhavo<br />
              Blumenstraße 26<br />
              85467 Neuching
            </p>
          </div>

          <div class="glass-box">
            <h2 class="glass-box__title section-num">Contact</h2>
            <p>
              Phone: <a href="tel:+4915122268995">+49-151-22268995</a><br />
              E-mail: <a href="mailto:nico@multaenhavo.com">nico@multaenhavo.com</a>
            </p>
          </div>

          <div class="glass-box">
            <h2 class="glass-box__title section-num">VAT ID</h2>
            <p>Sales tax identification number according to Sect. 27 a of the Sales Tax Law:</p>
            <p class="ust-id">DE459009808</p>
          </div>

          <div class="glass-box">
            <h2 class="glass-box__title section-num">Dispute Resolution</h2>
            <p>We are not willing or obliged to participate in dispute resolution proceedings in front of a consumer arbitration board.</p>
          </div>
        </>
      ) : (
        <>
          <div class="glass-box">
            <h2 class="glass-box__title section-num">Angaben gemäß § 5 TMG</h2>
            <p>
              Nico Thomas Henkel<br />
              MultaEnhavo<br />
              Blumenstraße 26<br />
              85467 Neuching
            </p>
          </div>

          <div class="glass-box">
            <h2 class="glass-box__title section-num">Kontakt</h2>
            <p>
              Telefon: <a href="tel:+4915122268995">+49-151-22268995</a><br />
              E-Mail: <a href="mailto:nico@multaenhavo.com">nico@multaenhavo.com</a>
            </p>
          </div>

          <div class="glass-box">
            <h2 class="glass-box__title section-num">Umsatzsteuer-ID</h2>
            <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:</p>
            <p class="ust-id">DE459009808</p>
          </div>

          <div class="glass-box">
            <h2 class="glass-box__title section-num">Verbraucherstreit&shy;beilegung / Universal&shy;schlichtungs&shy;stelle</h2>
            <p>Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>
          </div>
        </>
      )}

    </div>
  </main>

  <Footer />
</Base>

<style>
  .legal-page { min-height: 100svh; }

  .legal-wrap {
    max-width: 80ch;
    margin: 0 auto;
    padding: calc(var(--nav-h) + clamp(3rem, 8vh, 6rem)) var(--page-x) var(--gap-xl);
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .legal-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding-bottom: var(--gap-md);
  }
  .legal-header__divider {
    width: clamp(3rem, 8vw, 5rem);
    height: 2.7px;
    background: var(--rainbow);
    border-radius: 7px;
    opacity: 0.9;
    margin-bottom: 0.2rem;
  }
  .legal-header__title {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(2.8rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: -0.025em;
    color: var(--text);
  }

  .glass-box {
    background: rgba(0,0,0,0.27);
    backdrop-filter: blur(27px);
    -webkit-backdrop-filter: blur(27px);
    border: 2.7px solid rgba(0,0,0,0.37);
    box-shadow: 0 8px 32px 0 rgba(31,38,135,0.27);
    border-radius: 7px;
    padding: var(--gap-md) var(--gap-lg);
    display: grid;
    gap: 0.6rem;
    text-align: center;
    justify-items: center;
  }
  .glass-box__title {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text);
    text-align: center;
    width: 100%;
  }
  .section-num {
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
    border-radius: 7px;
    border: 2.7px solid var(--text-muted);
    padding: 0.55rem 1.4rem;
  }
  :global([data-theme="dark"]) .section-num {
    background: linear-gradient(277deg, rgba(255,0,0,0.32), rgba(255,119,0,0.32), rgba(255,238,0,0.32), rgba(0,204,0,0.32), rgba(0,136,255,0.32), rgba(136,0,255,0.32));
  }
  .glass-box p {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    color: var(--text-muted);
    line-height: 1.8;
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    text-align: center;
  }
  .glass-box a {
    color: var(--text-muted);
    border-bottom: 2.7px solid var(--border-mid);
    transition: color var(--quick), border-color var(--quick);
  }
  .glass-box a:hover {
    background: var(--rainbow);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    border-image: linear-gradient(277deg, #ff0000, #ff7700, #ffee00, #00cc00, #0088ff, #8800ff) 1;
  }

  .ust-id {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  :global([data-theme="light"]) .glass-box {
    background: rgba(255,255,255,0.27);
    border-color: rgba(255,255,255,0.37);
  }
  :global([data-theme="light"]) .glass-box p,
  :global([data-theme="light"]) .glass-box a {
    color: var(--text-muted);
  }
  :global([data-theme="light"]) .glass-box a:hover {
    background: var(--rainbow);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    border-image: linear-gradient(277deg, #ff0000, #ff7700, #ffee00, #00cc00, #0088ff, #8800ff) 1;
  }
</style>