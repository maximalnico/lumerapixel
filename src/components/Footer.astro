---
import { getLangFromUrl, t } from '../i18n';
const lang = getLangFromUrl(Astro.url);
---
<footer class="lp-footer">
  <div class="lp-footer__line"></div>
  <div class="lp-footer__inner">
    <img src="/logos/lplong-rainbow.svg" alt="LumeraPixel" class="lp-footer__logo" />
    <p class="lp-footer__copy">{t(lang, 'footer.copy')}</p>
  </div>
</footer>

<style>
  .lp-footer {
    padding: var(--gap-sm) var(--page-x) var(--gap-sm);
  }
  .lp-footer__line {
    height: 1px;
    background: var(--rainbow);
    margin-bottom: var(--gap-sm);
  }
  .lp-footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }
  .lp-footer__logo {
    height: clamp(1.2rem, 2.5vw, 1.9rem);
    width: auto;
    margin-bottom: 0.1rem;
  }
  .lp-footer__copy {
    font-family: 'GeneralSans', sans-serif;
    font-weight: 277;
    font-size: clamp(0.88rem, 1.3vw, 1.05rem);
    color: var(--text);
    letter-spacing: 0.06em;
  }
</style>
