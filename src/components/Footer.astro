---
import { getLangFromUrl, t } from '../i18n';
const lang = getLangFromUrl(Astro.url);
---
<footer class="lp-footer">
  <div class="lp-footer__line"></div>
  <div class="lp-footer__inner">
    <img src="/logos/lplong-rainbow.svg" alt="LumeraPixel" class="lp-footer__logo" />
    <p class="lp-footer__copy">{t(lang, 'footer.copy')}</p>
    <p class="lp-footer__credits">Typography by <a href="https://fontshare.com/fonts/switzer" target="_blank" rel="noopener">Fontshare</a> · Icons by <a href="https://phosphoricons.com/" target="_blank" rel="noopener">Phosphor</a> (MIT)</p>
  </div>
</footer>

<style>
  .lp-footer {
    padding: var(--gap-sm) var(--page-x) var(--gap-sm);
  }
  .lp-footer__line {
    height: 2.7px;
    background: var(--rainbow);
    margin-bottom: var(--gap-sm);
  }
  .lp-footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }
  .lp-footer__logo {
    height: clamp(1.2rem, 2.5vw, 1.9rem);
    width: auto;
    margin-bottom: 0.1rem;
  }
  .lp-footer__copy {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(0.88rem, 1.3vw, 1.05rem);
    color: var(--text);
    letter-spacing: 0.06em;
  }
  .lp-footer__credits {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(0.78rem, 1.05vw, 0.88rem);
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }
  .lp-footer__credits a {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .lp-footer__credits a:hover {
    color: var(--text);
  }
</style>
