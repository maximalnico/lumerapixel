---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="404 – Seite nicht gefunden · LumeraPixel">
  <Nav />

  <div class="page-wrap">
    <main class="not-found">
      <div class="not-found__wrap">

        <div class="not-found__header">
          <div class="not-found__divider" aria-hidden="true"></div>
          <h1 class="not-found__code">404</h1>
          <p class="not-found__title">Seite nicht gefunden</p>
        </div>

        <div class="glass-box">
          <p>Die gesuchte Seite existiert nicht oder wurde verschoben.</p>
          <a href="/" class="not-found__btn">
            <img src="/logos/phosphoricons/caret-left-thin.svg" class="not-found__btn-icon" alt="" />
            Zurück zur Startseite
          </a>
        </div>

      </div>
    </main>

    <Footer />
  </div>
</Base>

<style>
  .page-wrap {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }

  .not-found {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-h) + var(--gap-sm)) var(--page-x) var(--gap-sm);
  }

  .not-found__wrap {
    width: min(480px, 100%);
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .not-found__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
    padding-bottom: var(--gap-md);
  }

  .not-found__divider {
    width: clamp(3rem, 8vw, 5rem);
    height: 2px;
    background: var(--rainbow);
    border-radius: 7px;
    opacity: 0.9;
    margin-bottom: 0.2rem;
  }

  .not-found__code {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(5rem, 18vw, 9rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    background: var(--rainbow);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .not-found__title {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .glass-box {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 2.7px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    border-radius: 7px;
    padding: var(--gap-md) var(--gap-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-md);
    text-align: center;
  }

  .glass-box p {
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    color: var(--text-muted);
    line-height: 1.7;
  }

  .not-found__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Switzer', sans-serif;
    font-weight: 277;
    font-size: clamp(0.78rem, 1vw, 0.9rem);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text);
    padding: 0.55rem 1.4rem;
    border: 1.5px solid var(--text-muted);
    border-radius: 7px;
    background: transparent;
    cursor: pointer;
    transition: background var(--quick), border-color var(--quick);
    text-decoration: none;
  }
  .not-found__btn:hover {
    border-color: var(--text);
    background: linear-gradient(277deg, rgba(255,0,0,0.18), rgba(255,119,0,0.18), rgba(255,238,0,0.18), rgba(0,204,0,0.18), rgba(0,136,255,0.18), rgba(136,0,255,0.18));
  }

  .not-found__btn-icon {
    width: 1rem;
    height: 1rem;
    opacity: 0.8;
    filter: invert(1);
  }
</style>

<style is:global>
  [data-theme="light"] .not-found__btn { border-color: rgba(10,10,15,0.35); color: rgba(10,10,15,0.85); }
  [data-theme="dark"] .not-found__btn:hover { background: linear-gradient(277deg, rgba(255,0,0,0.32), rgba(255,119,0,0.32), rgba(255,238,0,0.32), rgba(0,204,0,0.32), rgba(0,136,255,0.32), rgba(136,0,255,0.32)); }
  [data-theme="light"] .not-found__btn-icon { filter: invert(0); }
</style>
