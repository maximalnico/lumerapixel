---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://lumerapixel.com';
---
<Base
  title="Impressum – LumeraPixel"
  canonical={`${siteUrl}/impressum`}
  description="Impressum von LumeraPixel – Fotografieportfolio von Nico Thomas Henkel aus Neuching, Bayern."
  hreflangDe={`${siteUrl}/impressum`}
  hreflangEn={`${siteUrl}/en/site-notice`}
>
  <Nav />

  <main class="legal-page">

    <div class="legal-hero">
      <div class="legal-hero__body">
        <div class="legal-hero__inner">
          <h1 class="legal-hero__title">Impressum</h1>
        </div>
      </div>
    </div>

    <div class="legal-sections">

      <div class="legal-box">
        <span class="legal-box__label">Angaben gemäß § 5 TMG</span>
        <p>
          Nico Thomas Henkel<br />
          MultaEnhavo<br />
          Blumenstraße 26<br />
          85467 Neuching
        </p>
      </div>

      <div class="legal-box">
        <span class="legal-box__label">Kontakt</span>
        <p>
          Telefon: <a href="tel:+4915122268995">+49-151-22268995</a><br />
          E-Mail: <a href="mailto:nico@multaenhavo.com">nico@multaenhavo.com</a>
        </p>
      </div>

      <div class="legal-box">
        <span class="legal-box__label">Umsatzsteuer-ID</span>
        <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:</p>
        <p class="legal-box__id">DE459009808</p>
      </div>

      <div class="legal-box">
        <span class="legal-box__label">Verbraucherstreit&shy;beilegung / Universal&shy;schlichtungs&shy;stelle</span>
        <p>Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>
      </div>

    </div>

  </main>

  <Footer />
</Base>

<style>
  .legal-page {
    background: #000;
    min-height: 100svh;
    color: #fff;
    --gap: 7px;
  }

  /* ── Hero ── */
  .legal-hero {
    margin: var(--gap);
  }
  .legal-hero__body {
    height: calc(100svh - (var(--gap) * 2));
    border: 2.7px solid #E31C8D;
    border-radius: 0 14px 0 14px;
    background: #000;
    display: grid;
    place-items: center;
  }
  .legal-hero__inner {
    border: 2.7px solid #E31C8D;
    border-radius: 0 14px 0 14px;
    background: #000;
    padding: clamp(0.8rem, 1.8vw, 1.2rem) clamp(1.2rem, 3vw, 2.2rem);
    text-align: center;
  }
  .legal-hero__title {
    font-weight: 750;
    font-size: clamp(1.9rem, 5vw, 3.7rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: #fff;
  }

  /* ── Sections ── */
  .legal-sections {
    padding: var(--gap);
    padding-top: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap);
  }

  .legal-box {
    border: 2.7px solid #404040;
    border-radius: 0 14px 0 14px;
    background: #000;
    padding: clamp(1rem, 2.5vw, 1.6rem) clamp(1.2rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    text-align: center;
    transition: border-color 180ms ease;
  }
  .legal-box:hover {
    border-color: #E31C8D;
  }

  .legal-box__label {
    border: 2.7px solid #404040;
    border-radius: 0 14px 0 14px;
    background: #000;
    padding: 0.42rem 0.78rem;
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: #fff;
    transition: border-color 180ms ease;
  }
  .legal-box:hover .legal-box__label {
    border-color: #E31C8D;
  }

  .legal-box p {
    color: #bfbfbf;
    line-height: 1.8;
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
  }

  .legal-box a {
    color: #bfbfbf;
    border-bottom: 2px solid #404040;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .legal-box a:hover {
    color: #fff;
    border-color: #E31C8D;
  }

  .legal-box__id {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-weight: 550;
    letter-spacing: 0.08em;
    color: #fff !important;
  }

  /* ── Light theme ── */
  :global([data-theme="light"]) .legal-page { background: #fff; color: #000; }
  :global([data-theme="light"]) .legal-hero__body { background: #fff; }
  :global([data-theme="light"]) .legal-hero__inner { background: #fff; }
  :global([data-theme="light"]) .legal-hero__title { color: #000; }
  :global([data-theme="light"]) .legal-box { background: #fff; }
  :global([data-theme="light"]) .legal-box__label { background: #fff; color: #000; }
  :global([data-theme="light"]) .legal-box p { color: #404040; }
  :global([data-theme="light"]) .legal-box a { color: #404040; }
  :global([data-theme="light"]) .legal-box a:hover { color: #000; }
  :global([data-theme="light"]) .legal-box__id { color: #000 !important; }
</style>
