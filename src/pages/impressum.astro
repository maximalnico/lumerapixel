---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Impressum – LumeraPixel" canonical="https://lumerapixel.com/impressum" description="Impressum von LumeraPixel – Fotografieportfolio von Nico Thomas Henkel aus Neuching, Bayern." />
  <Nav />

  <main class="legal-page">
    <div class="legal-wrap">

      <div class="legal-header">
        <div class="legal-header__divider" aria-hidden="true"></div>
        <h1 class="legal-header__title">Impressum</h1>
      </div>

      <div class="glass-box">
        <h2 class="glass-box__title">Angaben gemäß § 5 TMG</h2>
        <p>
          Nico Thomas Henkel<br />
          MultaEnhavo<br />
          Blumenstraße 26<br />
          85467 Neuching
        </p>
      </div>

      <div class="glass-box">
        <h2 class="glass-box__title">Kontakt</h2>
        <p>
          Telefon: <a href="tel:+4915122268995">+49-151-22268995</a><br />
          E-Mail: <a href="mailto:hello@multaenhavo.com">hello@multaenhavo.com</a>
        </p>
      </div>

      <div class="glass-box">
        <h2 class="glass-box__title">Umsatzsteuer-ID</h2>
        <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:</p>
        <p class="ust-id">DE459009808</p>
      </div>

      <div class="glass-box">
        <h2 class="glass-box__title">Verbraucherstreit&shy;beilegung / Universal&shy;schlichtungs&shy;stelle</h2>
        <p>Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>
      </div>

    </div>
  </main>

  <Footer />
</Base>

<style>
  .legal-page { min-height: 100svh; }

  .legal-wrap {
    max-width: 80ch;
    margin: 0 auto;
    padding: calc(var(--nav-h) + clamp(3rem, 8vh, 6rem)) var(--page-x) var(--gap-xl);
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .legal-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding-bottom: var(--gap-md);
  }
  .legal-header__divider {
    width: clamp(3rem, 8vw, 5rem);
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
    opacity: 0.9;
    margin-bottom: 0.2rem;
  }
  .legal-header__title {
    font-family: 'GeneralSans', sans-serif;
    font-weight: 277;
    font-size: clamp(2.8rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: -0.025em;
    color: var(--text);
  }

  .glass-box {
    background: rgba(0,0,0,0.27);
    backdrop-filter: blur(27px);
    -webkit-backdrop-filter: blur(27px);
    border: 2.7px solid rgba(0,0,0,0.37);
    box-shadow: 0 8px 32px 0 rgba(31,38,135,0.27);
    border-radius: 16px;
    padding: var(--gap-md) var(--gap-lg);
    display: grid;
    gap: 0.6rem;
    text-align: center;
    justify-items: center;
  }
  .glass-box__title {
    font-family: 'GeneralSans', sans-serif;
    font-weight: 277;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(128,128,128,0.25);
    margin-bottom: 0.2rem;
    text-align: center;
    width: 100%;
  }
  .glass-box p {
    font-family: 'GeneralSans', sans-serif;
    font-weight: 277;
    color: var(--text-muted);
    line-height: 1.8;
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    text-align: center;
  }
  .glass-box a {
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-mid);
    transition: color var(--quick), border-color var(--quick);
  }
  .glass-box a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .ust-id {
    font-family: 'GeneralSans', sans-serif;
    font-weight: 277;
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    letter-spacing: 0.08em;
    color: var(--accent);
  }

  :global([data-theme="dark"]) { --accent: #66ff00; }
  :global([data-theme="light"]) { --accent: #9900ff; }

  :global([data-theme="light"]) .glass-box {
    background: rgba(255,255,255,0.27);
    border-color: rgba(255,255,255,0.37);
  }
  :global([data-theme="light"]) .glass-box p,
  :global([data-theme="light"]) .glass-box a {
    color: var(--text-muted);
  }
  :global([data-theme="light"]) .glass-box a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>