---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  schema?: object;
  hreflangDe?: string;
  hreflangEn?: string;
}
const {
  title = 'LumeraPixel – Fotografie by MaximalNico',
  description = 'Lost Places, Automotive & Aerial Photography. LumeraPixel ist das Foto-Projekt von MaximalNico – Nico Henkel aus Bayern.',
  ogImage = 'https://lumerapixel.com/logos/lplong.svg',
  ogType = 'website',
  canonical,
  schema,
  hreflangDe,
  hreflangEn,
} = Astro.props;
const canonicalURL = canonical ?? Astro.url.href;
---
<!doctype html>
<html lang="de" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Nico Henkel" />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <link rel="canonical" href={canonicalURL} />

  <!-- OpenGraph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="LumeraPixel" />
  <meta property="og:locale" content="de_DE" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Performance -->
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://lumerapixel.com" />

  <!-- hreflang -->
  {hreflangDe && <link rel="alternate" hreflang="de" href={hreflangDe} />}
  {hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
  {hreflangDe && hreflangEn && <link rel="alternate" hreflang="x-default" href={hreflangDe} />}

  <!-- Schema.org JSON-LD -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- Favicon -->
  <link rel="icon" id="favicon" href="/logos/lplogo-rainbow.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/logos/lplogo-rainbow.svg" />

  <!-- Theme init: vor render setzen um FOUC zu verhindern -->
  <script is:inline>
    (function() {
      const mode = localStorage.getItem('lp-theme-mode') || 'auto';
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = mode === 'auto' ? (prefersDark ? 'dark' : 'light') : mode;
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>

  <style is:global>

    /* ── FONTS ── */
    @font-face {
      font-family: 'Satoshi';
      src: url('/fonts/Switzer-Variable.woff2') format('woff2');
      font-weight: 400 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Satoshi';
      src: url('/fonts/Switzer-VariableItalic.woff2') format('woff2');
      font-weight: 400 900;
      font-style: italic;
      font-display: swap;
    }

    /* ── DARK TOKENS ── */
    :root,
    [data-theme="dark"] {
      --accent: #66ff00;
      --accent: #66ff00;
      --bg:            #0a0a0f;
      --bg-card:       rgba(255,255,255,0.04);
      --bg-card-hover: rgba(255,255,255,0.07);
      --border:        rgba(255,255,255,0.09);
      --border-mid:    rgba(255,255,255,0.16);
      --text:          #ffffff;
      --text-muted:    rgba(255,255,255,0.65);
      --text-dim:      rgba(255,255,255,0.35);
      --glass-bg:      rgba(0,0,0,0.27);
      --glass-blur:    blur(27px);
      --glass-border:  rgba(0,0,0,0.37);
      --glass-shadow:  0 8px 32px 0 rgba(31,38,135,0.27);
      --scrollbar:     rgba(255,255,255,0.12);
      --wall-img:      url('/logos/lpwall-dark.svg');
    }

    /* ── LIGHT TOKENS ── */
    [data-theme="light"] {
      --accent: #9900ff;
      --bg:            #f0f4f8;
      --bg-card:       rgba(0,0,0,0.04);
      --bg-card-hover: rgba(0,0,0,0.07);
      --border:        rgba(0,0,0,0.09);
      --border-mid:    rgba(0,0,0,0.18);
      --text:          #0a0a0f;
      --text-muted:    rgba(10,10,15,0.65);
      --text-dim:      rgba(10,10,15,0.35);
      --glass-bg:      rgba(255,255,255,0.27);
      --glass-blur:    blur(27px);
      --glass-border:  rgba(255,255,255,0.37);
      --glass-shadow:  0 8px 32px 0 rgba(31,38,135,0.27);
      --scrollbar:     rgba(0,0,0,0.15);
      --wall-img:      url('/logos/lpwall-light.svg');
    }

    /* ── SPACING & TRANSITIONS (theme-unabhängig) ── */
    :root {
      color-scheme: light dark;
      --rainbow: linear-gradient(277deg, #ff0000, #ff7700, #ffee00, #00cc00, #0088ff, #8800ff);
      --gap-xs:  clamp(0.25rem, 1vw,  0.5rem);
      --gap-sm:  clamp(0.5rem,  2vw,  1rem);
      --gap-md:  clamp(1rem,    3vw,  2rem);
      --gap-lg:  clamp(2rem,    5vw,  4rem);
      --gap-xl:  clamp(3rem,    8vw,  7rem);
      --page-x:  clamp(1.25rem, 5vw, 4rem);
      --nav-h:   111.283px;
      --quick:   180ms ease-out;
      --flow:    340ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    @media (max-width: 768px) {
      :root { --nav-h: 3rem; }
    }

    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html {
      scroll-behavior: smooth;
      scrollbar-width: thin;
      scrollbar-color: var(--scrollbar) transparent;
      background-color: var(--bg);
    }
    body {
      background-color: var(--bg);
      background-image: var(--wall-img);
      background-attachment: fixed;
      background-size: cover;
      background-position: center center;
      background-repeat: no-repeat;
      color: var(--text);
      font-family: 'Satoshi';
      font-size: clamp(0.9rem, 1.3vw, 1.05rem);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      transition: background-color 0.3s ease, color 0.3s ease;
    }
    img, video, svg { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    button, input { font: inherit; color: inherit; background: none; border: none; outline: none; appearance: none; }
    ul { list-style: none; }

    /* ── GLASS ── */
    [data-theme="light"] .glass {
      background: rgba(255,255,255,0.27);
      border-color: rgba(255,255,255,0.37);
    }
    .glass {
      background: var(--glass-bg);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 2.7px solid var(--glass-border);
      box-shadow: var(--glass-shadow);
    }

    /* ── RAINBOW UTILS ── */
    .rg {
      background: var(--rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .rg-line {
      height: 2.7px;
      background: var(--rainbow);
      opacity: 0.55;
      border-radius: 7px;
    }
    .rg-border { position: relative; }
    .rg-border::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 7px;
      padding: 1.5px;
      background: var(--rainbow);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: destination-out;
      mask-composite: exclude;
      pointer-events: none;
    }

    /* ── TYPOGRAPHY ── */
    .font-display { font-family: 'Satoshi'; font-weight: 700; letter-spacing: -0.02em; }
    .t-micro {
      font-family: 'Satoshi'; font-weight: 600;
      font-size: clamp(0.65rem, 1vw, 0.8rem);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--scrollbar); border-radius: 7px; }

    /* ── REVEAL ANIMATION ── */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease-out, transform 0.5s var(--flow);
    }
    .reveal.is-visible { opacity: 1; transform: translateY(0); }

    /* ── KEYFRAMES ── */
    @keyframes rainbow-shift {
      0%   { background-position: 0% 50%; }
      100% { background-position: 200% 50%; }
    }
    @keyframes rainbow-glow {
      0%   { box-shadow: 0 0 0 1.5px #ff0000, 0 0 16px rgba(255,0,0,0.25); }
      16%  { box-shadow: 0 0 0 1.5px #ff7700, 0 0 16px rgba(255,119,0,0.25); }
      33%  { box-shadow: 0 0 0 1.5px #ffee00, 0 0 16px rgba(255,238,0,0.25); }
      50%  { box-shadow: 0 0 0 1.5px #00cc00, 0 0 16px rgba(0,204,0,0.25); }
      66%  { box-shadow: 0 0 0 1.5px #0088ff, 0 0 16px rgba(0,136,255,0.25); }
      83%  { box-shadow: 0 0 0 1.5px #8800ff, 0 0 16px rgba(136,0,255,0.25); }
      100% { box-shadow: 0 0 0 1.5px #ff0000, 0 0 16px rgba(255,0,0,0.25); }
    }
    @keyframes bob {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50%       { transform: translateX(-50%) translateY(5px); }
    }

  </style>
</head>
<body>
  <slot />
  <script>
    // ── Reveal on scroll ──
    const revealEls = document.querySelectorAll('.reveal');
    if (revealEls.length) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
        });
      }, { threshold: 0.08 });
      revealEls.forEach(el => io.observe(el));
    }

    // ── Theme toggle ──
    window.__toggleTheme = function() {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('lp-theme', next);
      // Icon updaten
      document.querySelectorAll('.theme-toggle__icon').forEach(el => {
        (el as HTMLElement).textContent = next === 'dark' ? '☀️' : '🌙';
      });
    };

    window.__updateFavicon = function(_theme: string) {};
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (!localStorage.getItem('lp-theme')) {
        const theme = e.matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        (window as any).__updateFavicon?.(theme);
      }
    });
  </script>
</body>
</html>
