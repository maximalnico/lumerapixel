---
import '../styles/tailwind.css';
import { ClientRouter } from 'astro:transitions';
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  articleDate?: string;
  canonical?: string;
  schema?: object;
  hreflangDe?: string;
  hreflangEn?: string;
  htmlLang?: string;
}
const {
  title = 'LumeraPixel – Fotografie by MaximalNico',
  description = 'Lost Places, Automotive & Aerial Photography. LumeraPixel ist das Foto-Projekt von MaximalNico – Nico Henkel aus Bayern.',
  ogImage = 'https://lumerapixel.com/logos/lplong.svg',
  ogImageAlt = 'LumeraPixel',
  ogType = 'website',
  articleDate,
  canonical,
  schema,
  hreflangDe,
  hreflangEn,
  htmlLang = 'de',
} = Astro.props;
const canonicalURL = canonical ?? Astro.url.href;
const ogLocale = htmlLang === 'en' ? 'en_US' : 'de_DE';
---
<!doctype html>
<html lang={htmlLang} data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" id="metaThemeColor" content="#000000" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Nico Henkel" />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
  <ClientRouter />

  <!-- OpenGraph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="LumeraPixel" />
  <meta property="og:locale" content={ogLocale} />
  {ogType === 'article' && <meta property="article:author" content="Nico Henkel" />}
  {ogType === 'article' && articleDate && <meta property="article:published_time" content={articleDate} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <!-- Performance -->
  <link rel="preconnect" href="https://lumerapixel.b-cdn.net" />
  <link rel="dns-prefetch" href="https://lumerapixel.b-cdn.net" />
  <link rel="preload" href="/fonts/Satoshi-Variable.woff2" as="font" type="font/woff2" crossorigin />

  <!-- hreflang -->
  {hreflangDe && <link rel="alternate" hreflang="de" href={hreflangDe} />}
  {hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
  {hreflangDe && hreflangEn && <link rel="alternate" hreflang="x-default" href={hreflangDe} />}

  <!-- Schema.org JSON-LD -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- Favicon -->
  <link rel="icon" id="favicon" href="/logos/lplogo-black.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/logos/lplogo-black.svg" />

  <!-- Theme init: prevent FOUC and persist across View Transitions -->
  <script is:inline>
    (function() {
      localStorage.removeItem('lp-theme');
      const stored = localStorage.getItem('lp-theme-mode');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = (stored === 'dark' || stored === 'light') ? stored : (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);

      const updateFavicon = (mode) => {
        const favicon = document.getElementById('favicon');
        if (favicon) favicon.setAttribute('href', mode === 'dark' ? '/logos/lplogo-white.svg' : '/logos/lplogo-black.svg');
        const themeMeta = document.getElementById('metaThemeColor');
        if (themeMeta) themeMeta.setAttribute('content', mode === 'dark' ? '#000000' : '#ffffff');
      };

      window.__updateFavicon = updateFavicon;
      updateFavicon(theme);

      // Preserve data-theme across View Transitions swaps
      document.addEventListener('astro:before-swap', (e) => {
        const current = document.documentElement.getAttribute('data-theme');
        if (current) e.newDocument.documentElement.setAttribute('data-theme', current);
      });
    })();
  </script>

  <style is:global>

    /* ── FONTS ── */
    @font-face {
      font-family: 'Satoshi';
      src: url('/fonts/Satoshi-Variable.woff2') format('woff2');
      font-weight: 300 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Satoshi';
      src: url('/fonts/Satoshi-VariableItalic.woff2') format('woff2');
      font-weight: 300 900;
      font-style: italic;
      font-display: swap;
    }

    /* ── DARK TOKENS ── */
    :root,
    [data-theme="dark"] {
      --accent: #404040;
      --bg:            #000000;
      --bg-card:       rgba(255,255,255,0.04);
      --bg-card-hover: rgba(255,255,255,0.07);
      --border:        rgba(255,255,255,0.09);
      --border-mid:    rgba(255,255,255,0.16);
      --text:          #ffffff;
      --text-muted:    rgba(255,255,255,0.65);
      --text-dim:      rgba(255,255,255,0.35);
      --glass-bg:      rgba(0,0,0,0.27);
      --glass-blur:    blur(27px);
      --glass-border:  rgba(0,0,0,0.37);
      --glass-shadow:  0 8px 32px 0 rgba(31,38,135,0.27);
      --scrollbar:     rgba(255,255,255,0.12);
      --wall-img:      url('/logos/lpwall-dark.svg');
    }

    /* ── LIGHT TOKENS ── */
    [data-theme="light"] {
      --accent: #E31C8D;
      --bg:            #ffffff;
      --bg-card:       rgba(0,0,0,0.04);
      --bg-card-hover: rgba(0,0,0,0.07);
      --border:        rgba(0,0,0,0.09);
      --border-mid:    rgba(0,0,0,0.18);
      --text:          #000000;
      --text-muted:    rgba(10,10,15,0.65);
      --text-dim:      rgba(10,10,15,0.35);
      --glass-bg:      rgba(255,255,255,0.27);
      --glass-blur:    blur(27px);
      --glass-border:  rgba(255,255,255,0.37);
      --glass-shadow:  0 8px 32px 0 rgba(31,38,135,0.27);
      --scrollbar:     rgba(0,0,0,0.15);
      --wall-img:      url('/logos/lpwall-light.svg');
    }

    /* ── SPACING & TRANSITIONS (theme-unabhängig) ── */
    :root {
      color-scheme: light dark;
      --rainbow: linear-gradient(277deg, #404040, #404040, #ffffff, #404040, #404040, #404040);
      --gap-xs:  clamp(0.25rem, 1vw,  0.5rem);
      --gap-sm:  clamp(0.5rem,  2vw,  1rem);
      --gap-md:  clamp(1rem,    3vw,  2rem);
      --gap-lg:  clamp(2rem,    5vw,  4rem);
      --gap-xl:  clamp(3rem,    8vw,  7rem);
      --page-x:  clamp(1.25rem, 5vw, 4rem);
      --nav-h:   111.283px;
      --quick:   180ms ease-out;
      --flow:    340ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    @media (max-width: 820px) {
      :root { --nav-h: 3rem; }
    }

    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html {
      scroll-behavior: smooth;
      scrollbar-width: thin;
      scrollbar-color: var(--scrollbar) transparent;
      background-color: var(--bg);
    }
    body {
      background-color: var(--bg);
      background-image: var(--wall-img);
      background-attachment: fixed;
      background-size: cover;
      background-position: center center;
      background-repeat: no-repeat;
      color: var(--text);
      font-family: 'Satoshi';
      font-size: clamp(0.9rem, 1.3vw, 1.05rem);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      transition: background-color 0.3s ease, color 0.3s ease;
    }
    img, video, svg { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    button, input { font: inherit; color: inherit; background: none; border: none; outline: none; appearance: none; }
    ul { list-style: none; }

    /* ── FOCUS ── */
    :focus-visible {
      outline: 2.7px solid #E31C8D;
      outline-offset: 3px;
      border-radius: 4px;
    }

    /* ── GLASS ── */
    [data-theme="light"] .glass {
      background: rgba(255,255,255,0.27);
      border-color: rgba(255,255,255,0.37);
    }
    .glass {
      background: var(--glass-bg);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 2.7px solid var(--glass-border);
      box-shadow: var(--glass-shadow);
    }

    /* ── RAINBOW UTILS ── */
    .rg {
      background: var(--rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .rg-line {
      height: 2.7px;
      background: var(--rainbow);
      opacity: 0.55;
      border-radius: 7px;
    }
    .rg-border { position: relative; }
    .rg-border::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 7px;
      padding: 1.5px;
      background: var(--rainbow);
      -webkit-mask: linear-gradient(#ffffff 0 0) content-box, linear-gradient(#ffffff 0 0);
      -webkit-mask-composite: destination-out;
      mask-composite: exclude;
      pointer-events: none;
    }

    /* ── TYPOGRAPHY ── */
    .font-display { font-family: 'Satoshi'; font-weight: 750; letter-spacing: -0.02em; }
    .t-micro {
      font-family: 'Satoshi'; font-weight: 600;
      font-size: clamp(0.65rem, 1vw, 0.8rem);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--scrollbar); border-radius: 7px; }

    /* ── REVEAL ANIMATION ── */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease-out, transform 0.5s var(--flow);
    }
    .reveal.is-visible { opacity: 1; transform: translateY(0); }

    /* ── KEYFRAMES ── */
    @keyframes rainbow-shift {
      0%   { background-position: 0% 50%; }
      100% { background-position: 200% 50%; }
    }
    @keyframes rainbow-glow {
      0%   { box-shadow: 0 0 0 1.5px #404040, 0 0 16px rgba(255,0,0,0.25); }
      16%  { box-shadow: 0 0 0 1.5px #404040, 0 0 16px rgba(255,119,0,0.25); }
      33%  { box-shadow: 0 0 0 1.5px #ffffff, 0 0 16px rgba(255,238,0,0.25); }
      50%  { box-shadow: 0 0 0 1.5px #404040, 0 0 16px rgba(0,204,0,0.25); }
      66%  { box-shadow: 0 0 0 1.5px #404040, 0 0 16px rgba(0,136,255,0.25); }
      83%  { box-shadow: 0 0 0 1.5px #404040, 0 0 16px rgba(136,0,255,0.25); }
      100% { box-shadow: 0 0 0 1.5px #404040, 0 0 16px rgba(255,0,0,0.25); }
    }
    @keyframes bob {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50%       { transform: translateX(-50%) translateY(5px); }
    }

  </style>
</head>
<body>
  <slot />
<script>
  // Re-initialize reveal animation on every page load
  function initReveal() {
    const revealEls = document.querySelectorAll('.reveal:not(.is-visible)');
    if (!revealEls.length) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.08 });
    revealEls.forEach(el => io.observe(el));
  }
  document.addEventListener('astro:page-load', initReveal);

  // System theme change listener — registered once
  window.__updateFavicon = window.__updateFavicon || function(_theme: string) {};
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    const saved = localStorage.getItem('lp-theme-mode');
    if (saved === 'dark' || saved === 'light') return;
    const theme = e.matches ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', theme);
    (window as any).__updateFavicon?.(theme);
  });
</script>
</body>
</html>
